<!DOCTYPE html>
<html xmlns:th="http://www.thymeleaf.org">
<head>
<meta charset="UTF-8">
<title>Notifications</title>

<style>
body{
font-family:Arial;
background:#f4f6f9;
padding:20px;
}
.card{
background:white;
padding:15px;
margin-bottom:10px;
border-radius:8px;
box-shadow:0 0 8px #ddd;
}
.time{
font-size:12px;
color:gray;
}
</style>
</head>

<body>

<h2>Notifications 🔔</h2>

<div th:if="${notifications.size()==0}">
No notifications yet.
</div>

<div class="card"
th:each="n : ${notifications}">

<p th:text="${n.message}"></p>

<p class="time"
th:text="${#temporals.format(n.createdDate,'dd-MM-yyyy HH:mm')}"></p>

</div>

</body>
</html>