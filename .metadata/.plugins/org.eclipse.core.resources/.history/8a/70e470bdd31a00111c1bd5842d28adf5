<!DOCTYPE html>
<html xmlns:th="http://www.thymeleaf.org">
<head>
<title>Users</title>

<style>

body{
font-family:Arial;
background:#f4f6f9;
}

.container{
width:90%;
margin:auto;
margin-top:40px;
}

table{
width:100%;
border-collapse:collapse;
background:white;
}

th,td{
padding:10px;
border:1px solid #ddd;
text-align:center;
}

button{
padding:6px 12px;
background:#dc2626;
color:white;
border:none;
cursor:pointer;
}

</style>

</head>

<body>

<div class="container">

<h2>Users Management</h2>

<table>

<tr>
<th>ID</th>
<th>Name</th>
<th>Email</th>
<th>Phone</th>
<th>Role</th>
<th>Action</th>
</tr>

<tr th:each="user : ${users}">

<td th:text="${user.id}"></td>
<td th:text="${user.fullName}"></td>
<td th:text="${user.email}"></td>
<td th:text="${user.phone}"></td>
<td th:text="${user.role}"></td>

<td>

<a th:href="@{'/admin/delete-user/' + ${user.id}}">
<button>Delete</button>
</a>

</td>

</tr>

</table>

</div>

</body>
</html>