<!DOCTYPE html>
<html xmlns:th="http://www.thymeleaf.org">

<head>

<meta charset="UTF-8">
<title>Business Verification</title>

<style>

body{
font-family:Arial;
background:#f1f5f9;
padding:30px;
}

.card{
background:white;
padding:25px;
border-radius:10px;
box-shadow:0 5px 15px rgba(0,0,0,0.1);
max-width:700px;
}

h2{
margin-bottom:20px;
}

input{
padding:10px;
margin:10px 0;
width:100%;
border:1px solid #ccc;
border-radius:5px;
}

button{
padding:10px 20px;
background:#2563eb;
color:white;
border:none;
border-radius:6px;
cursor:pointer;
}

button:hover{
background:#1e40af;
}

table{
width:100%;
margin-top:20px;
border-collapse:collapse;
}

th{
background:#0f172a;
color:white;
padding:10px;
}

td{
padding:10px;
border-bottom:1px solid #ddd;
text-align:center;
}

.badge{
padding:5px 10px;
border-radius:10px;
font-size:12px;
font-weight:bold;
}

.pending{
background:#fef3c7;
color:#92400e;
}

.approved{
background:#dcfce7;
color:#166534;
}

.rejected{
background:#fee2e2;
color:#991b1b;
}

</style>

</head>

<body>

<div class="card">

<h2>Business Verification 📄</h2>

<!-- DOCUMENT UPLOAD FORM -->

<form th:action="@{/submit-verification}"
      method="post"
      enctype="multipart/form-data">

<input type="text"
name="documentName"
placeholder="Document Name (GST, PAN, License)"
required>

<input type="file"
name="file"
required>

<button type="submit">
Submit Verification
</button>

</form>

<hr>

<h3>Your Verification Requests</h3>

<table>

<tr>
<th>Document</th>
<th>Status</th>
<th>Submitted</th>
</tr>

<tr th:each="v : ${verifications}">

<td th:text="${v.documentName}"></td>

<td>

<span th:if="${v.status=='PENDING'}"
class="badge pending">
Pending
</span>

<span th:if="${v.status=='APPROVED'}"
class="badge approved">
Approved
</span>

<span th:if="${v.status=='REJECTED'}"
class="badge rejected">
Rejected
</span>

</td>

<td th:text="${#temporals.format(v.createdDate,'dd-MM-yyyy HH:mm')}"></td>

</tr>

</table>

</div>

</body>
</html>