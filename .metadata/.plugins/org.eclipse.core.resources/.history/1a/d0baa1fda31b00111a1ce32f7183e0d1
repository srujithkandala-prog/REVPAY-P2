<!DOCTYPE html>
<html xmlns:th="http://www.thymeleaf.org">

<head>
    <title>RevPay Admin Dashboard</title>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons/font/bootstrap-icons.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Sora:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        :root {
            --primary: #3b82f6;
            --primary-dark: #1e40af;
            --primary-light: #dbeafe;
            --success: #10b981;
            --warning: #f59e0b;
            --danger: #ef4444;
            --gray-50: #f9fafb;
            --gray-100: #f3f4f6;
            --gray-200: #e5e7eb;
            --gray-300: #d1d5db;
            --gray-400: #9ca3af;
            --gray-500: #6b7280;
            --gray-600: #4b5563;
            --gray-700: #374151;
            --gray-800: #1f2937;
            --gray-900: #111827;
            --sidebar-bg: #0f172a;
            --card-shadow: 0 4px 6px rgba(0, 0, 0, 0.07), 0 10px 13px -3px rgba(0, 0, 0, 0.08);
            --card-shadow-lg: 0 20px 25px -5px rgba(0, 0, 0, 0.1);
        }

        body {
            font-family: 'Sora', sans-serif;
            background: linear-gradient(135deg, var(--gray-50) 0%, #f0f4f8 100%);
            color: var(--gray-800);
            line-height: 1.6;
        }

        /* ===== SIDEBAR ===== */
        .sidebar {
            width: 260px;
            height: 100vh;
            background: linear-gradient(180deg, var(--sidebar-bg) 0%, #0d1425 100%);
            color: white;
            position: fixed;
            left: 0;
            top: 0;
            padding: 32px 24px;
            overflow-y: auto;
            z-index: 1000;
            border-right: 1px solid rgba(255, 255, 255, 0.08);
        }

        .sidebar::-webkit-scrollbar {
            width: 6px;
        }

        .sidebar::-webkit-scrollbar-track {
            background: transparent;
        }

        .sidebar::-webkit-scrollbar-thumb {
            background: rgba(255, 255, 255, 0.1);
            border-radius: 3px;
        }

        .sidebar::-webkit-scrollbar-thumb:hover {
            background: rgba(255, 255, 255, 0.2);
        }

        .sidebar-brand {
            display: flex;
            align-items: center;
            gap: 12px;
            margin-bottom: 40px;
            font-weight: 700;
            font-size: 16px;
            letter-spacing: -0.5px;
            background: linear-gradient(135deg, #60a5fa 0%, #3b82f6 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }

        .sidebar-brand i {
            font-size: 20px;
        }

        .nav-section {
            margin-bottom: 32px;
        }

        .nav-section-label {
            font-size: 11px;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 1px;
            color: rgba(255, 255, 255, 0.5);
            margin-bottom: 16px;
            display: block;
        }

        .sidebar a {
            display: flex;
            align-items: center;
            gap: 12px;
            color: rgba(255, 255, 255, 0.7);
            text-decoration: none;
            font-size: 14px;
            padding: 10px 12px;
            border-radius: 8px;
            margin-bottom: 8px;
            transition: all 0.3s ease;
            position: relative;
        }

        .nav-icon-wrapper {
            display: flex;
            align-items: center;
            justify-content: center;
            width: 36px;
            height: 36px;
            background: rgba(59, 130, 246, 0.1);
            border-radius: 8px;
            transition: all 0.3s ease;
            font-size: 16px;
            color: rgba(59, 130, 246, 0.8);
        }

        .sidebar a:hover .nav-icon-wrapper {
            background: rgba(59, 130, 246, 0.2);
            transform: scale(1.05);
            color: rgba(59, 130, 246, 1);
        }

        .sidebar a.active .nav-icon-wrapper {
            background: linear-gradient(135deg, #3b82f6, #1e40af);
            color: white;
            box-shadow: 0 4px 12px rgba(59, 130, 246, 0.4);
        }

        .sidebar a:hover {
            color: white;
            background: rgba(59, 130, 246, 0.15);
            padding-left: 16px;
        }

        .sidebar a.active {
            color: white;
            background: rgba(59, 130, 246, 0.25);
            border-left: 3px solid var(--primary);
            padding-left: 12px;
        }

        .sidebar hr {
            border: none;
            height: 1px;
            background: rgba(255, 255, 255, 0.08);
            margin: 24px 0;
        }

        .sidebar-footer {
            position: absolute;
            bottom: 24px;
            left: 24px;
            right: 24px;
        }

        .logout-btn {
            display: flex;
            align-items: center;
            gap: 12px;
            width: 100%;
            padding: 10px 12px;
            border-radius: 8px;
            background: rgba(239, 68, 68, 0.08);
            color: #fca5a5;
            text-decoration: none;
            font-size: 14px;
            transition: all 0.3s ease;
            border: 1px solid rgba(239, 68, 68, 0.2);
        }

        .logout-btn:hover {
            background: rgba(239, 68, 68, 0.12);
            color: white;
            border-color: rgba(239, 68, 68, 0.4);
        }

        /* ===== MAIN CONTENT ===== */
        .content {
            margin-left: 260px;
            padding: 40px;
            min-height: 100vh;
        }

        .header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 40px;
        }

        .header h1 {
            font-size: 32px;
            font-weight: 700;
            color: var(--gray-900);
            letter-spacing: -1px;
        }

        .status-badge {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            padding: 8px 16px;
            background: rgba(16, 185, 129, 0.1);
            color: var(--success);
            border-radius: 20px;
            font-size: 13px;
            font-weight: 600;
        }

        .status-badge::before {
            content: '';
            width: 8px;
            height: 8px;
            background: var(--success);
            border-radius: 50%;
            animation: pulse 2s infinite;
        }

        @keyframes pulse {
            0%, 100% { opacity: 1; }
            50% { opacity: 0.5; }
        }

        /* ===== METRIC CARDS ===== */
        .metrics-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
            gap: 24px;
            margin-bottom: 40px;
        }

        .metric-card {
            background: white;
            border-radius: 12px;
            padding: 24px;
            box-shadow: var(--card-shadow);
            transition: all 0.3s ease;
            border: 1px solid rgba(0, 0, 0, 0.05);
            position: relative;
            overflow: hidden;
        }

        .metric-card::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 3px;
            background: linear-gradient(90deg, var(--primary), var(--primary-light));
            opacity: 0;
            transition: opacity 0.3s ease;
        }

        .metric-card:hover {
            box-shadow: var(--card-shadow-lg);
            transform: translateY(-4px);
        }

        .metric-card:hover::before {
            opacity: 1;
        }

        .metric-label {
            font-size: 13px;
            font-weight: 500;
            color: var(--gray-500);
            text-transform: uppercase;
            letter-spacing: 0.5px;
            margin-bottom: 12px;
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .metric-value {
            font-size: 28px;
            font-weight: 700;
            color: var(--gray-900);
            margin-bottom: 4px;
            font-family: 'JetBrains Mono', monospace;
        }

        .metric-subtitle {
            font-size: 12px;
            color: var(--gray-400);
        }

        .metric-icon {
            position: absolute;
            right: 24px;
            top: 24px;
            font-size: 32px;
            opacity: 0.08;
        }

        .metric-card-1 .metric-label { color: #3b82f6; }
        .metric-card-2 .metric-label { color: #10b981; }
        .metric-card-3 .metric-label { color: #f59e0b; }
        .metric-card-4 .metric-label { color: #ef4444; }

        /* ===== CHART SECTION ===== */
        .chart-section {
            background: white;
            border-radius: 12px;
            padding: 28px;
            box-shadow: var(--card-shadow);
            margin-bottom: 40px;
            border: 1px solid rgba(0, 0, 0, 0.05);
        }

        .chart-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 28px;
            padding-bottom: 16px;
            border-bottom: 1px solid var(--gray-100);
        }

        .chart-title {
            font-size: 18px;
            font-weight: 700;
            color: var(--gray-900);
        }

        .chart-subtitle {
            font-size: 13px;
            color: var(--gray-500);
        }

        .chart-legend {
            display: flex;
            align-items: center;
            gap: 8px;
            font-size: 12px;
            color: var(--gray-600);
        }

        .chart-legend-dot {
            width: 10px;
            height: 10px;
            background: var(--primary);
            border-radius: 2px;
        }

        #revenueChart {
            max-height: 320px;
        }

        /* ===== TRANSACTIONS TABLE ===== */
        .table-section {
            background: white;
            border-radius: 12px;
            padding: 28px;
            box-shadow: var(--card-shadow);
            border: 1px solid rgba(0, 0, 0, 0.05);
        }

        .table-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 24px;
            padding-bottom: 16px;
            border-bottom: 1px solid var(--gray-100);
        }

        .table-title {
            font-size: 18px;
            font-weight: 700;
            color: var(--gray-900);
        }

        .view-all-link {
            font-size: 13px;
            color: var(--primary);
            text-decoration: none;
            font-weight: 600;
            transition: all 0.3s ease;
            display: flex;
            align-items: center;
            gap: 6px;
        }

        .view-all-link:hover {
            color: var(--primary-dark);
            gap: 10px;
        }

        .table-container {
            overflow-x: auto;
        }

        .table {
            width: 100%;
            border-collapse: collapse;
        }

        .table thead {
            background: var(--gray-50);
        }

        .table th {
            padding: 16px 12px;
            text-align: left;
            font-size: 12px;
            font-weight: 600;
            color: var(--gray-600);
            text-transform: uppercase;
            letter-spacing: 0.5px;
            border: none;
        }

        .table td {
            padding: 16px 12px;
            font-size: 14px;
            color: var(--gray-700);
            border-bottom: 1px solid var(--gray-100);
        }

        .table tbody tr:hover {
            background: var(--gray-50);
        }

        .table tbody tr:last-child td {
            border-bottom: none;
        }

        .email-badge {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            font-size: 13px;
            color: var(--gray-700);
        }

        .email-badge::before {
            content: '';
            width: 6px;
            height: 6px;
            background: var(--primary);
            border-radius: 50%;
        }

        .amount-value {
            font-family: 'JetBrains Mono', monospace;
            font-weight: 600;
            color: var(--gray-900);
        }

        .empty-state {
            text-align: center;
            padding: 48px 24px;
            color: var(--gray-400);
        }

        .empty-state i {
            font-size: 48px;
            margin-bottom: 16px;
            opacity: 0.5;
        }

        /* ===== SCROLLBAR STYLING ===== */
        ::-webkit-scrollbar {
            width: 8px;
            height: 8px;
        }

        ::-webkit-scrollbar-track {
            background: transparent;
        }

        ::-webkit-scrollbar-thumb {
            background: rgba(0, 0, 0, 0.1);
            border-radius: 4px;
        }

        ::-webkit-scrollbar-thumb:hover {
            background: rgba(0, 0, 0, 0.2);
        }

        /* ===== RESPONSIVE ===== */
        @media (max-width: 1024px) {
            .metrics-grid {
                grid-template-columns: repeat(2, 1fr);
            }

            .content {
                padding: 24px;
            }
        }

        @media (max-width: 768px) {
            .sidebar {
                width: 240px;
                padding: 20px;
            }

            .content {
                margin-left: 240px;
                padding: 20px;
            }

            .header {
                flex-direction: column;
                align-items: flex-start;
                gap: 16px;
            }

            .header h1 {
                font-size: 24px;
            }

            .metrics-grid {
                grid-template-columns: 1fr;
            }

            .chart-section,
            .table-section {
                padding: 20px;
            }
        }

        @media (max-width: 640px) {
            .sidebar {
                width: 100%;
                height: auto;
                position: static;
                border-right: none;
                border-bottom: 1px solid rgba(255, 255, 255, 0.08);
                padding: 16px;
            }

            .sidebar-footer {
                position: static;
                margin-top: 20px;
            }

            .content {
                margin-left: 0;
                padding: 16px;
            }

            .table-container {
                font-size: 12px;
            }

            .table th,
            .table td {
                padding: 12px 8px;
            }
        }

    </style>
</head>

<body>

    <!-- SIDEBAR -->
    <div class="sidebar">
        <div class="sidebar-brand">
            <i class="bi bi-lightning-charge-fill"></i>
            RevPay
        </div>

        <div class="nav-section">
            <span class="nav-section-label">Overview</span>
            <a href="/admin-dashboard" class="active nav-item">
                <span class="nav-icon-wrapper">
                    <i class="bi bi-speedometer2"></i>
                </span>
                Dashboard
            </a>
            <a href="/admin/users" class="nav-item">
                <span class="nav-icon-wrapper">
                    <i class="bi bi-people-fill"></i>
                </span>
                Users
            </a>
        </div>

        <div class="nav-section">
            <span class="nav-section-label">Finance</span>
            <a href="/admin/transactions" class="nav-item">
                <span class="nav-icon-wrapper">
                    <i class="bi bi-arrow-left-right"></i>
                </span>
                Transactions
            </a>
            <a href="/admin/loans" class="nav-item">
                <span class="nav-icon-wrapper">
                    <i class="bi bi-bank2"></i>
                </span>
                Loans
            </a>
            <a href="/admin/revenue" class="nav-item">
                <span class="nav-icon-wrapper">
                    <i class="bi bi-graph-up"></i>
                </span>
                Revenue
            </a>
        </div>

        <div class="nav-section">
            <span class="nav-section-label">Monitoring</span>
            <a href="/admin/system-health" class="nav-item">
                <span class="nav-icon-wrapper">
                    <i class="bi bi-cpu"></i>
                </span>
                System Health
            </a>
            <a href="/admin/live-transactions" class="nav-item">
                <span class="nav-icon-wrapper">
                    <i class="bi bi-broadcast"></i>
                </span>
                Live Monitor
            </a>
            <a href="/admin/fraud-alerts" class="nav-item">
                <span class="nav-icon-wrapper">
                    <i class="bi bi-shield-exclamation"></i>
                </span>
                Fraud Alerts
            </a>
            <a href="/admin/reports" class="nav-item">
                <span class="nav-icon-wrapper">
                    <i class="bi bi-file-earmark-text"></i>
                </span>
                Reports
            </a>
        </div>

        <div class="sidebar-footer">
            <a href="/logout" class="logout-btn">
                <i class="bi bi-box-arrow-right"></i> Logout
            </a>
        </div>
    </div>

    <!-- MAIN CONTENT -->
    <div class="content">

        <div class="header">
            <h1>Dashboard</h1>
            <span class="status-badge">Live</span>
        </div>

        <!-- METRIC CARDS -->
        <div class="metrics-grid">
            <div class="metric-card metric-card-1">
                <i class="bi bi-people-fill metric-icon"></i>
                <div class="metric-label">
                    <i class="bi bi-people-fill"></i> Total Users
                </div>
                <div class="metric-value" th:text="${totalUsers}">0</div>
                <div class="metric-subtitle">Active accounts</div>
            </div>

            <div class="metric-card metric-card-2">
                <i class="bi bi-arrow-left-right metric-icon"></i>
                <div class="metric-label">
                    <i class="bi bi-arrow-left-right"></i> Transactions
                </div>
                <div class="metric-value" th:text="${totalTransactions}">0</div>
                <div class="metric-subtitle">All time</div>
            </div>

            <div class="metric-card metric-card-3">
                <i class="bi bi-bank2 metric-icon"></i>
                <div class="metric-label">
                    <i class="bi bi-bank2"></i> Loans
                </div>
                <div class="metric-value" th:text="${totalLoans}">0</div>
                <div class="metric-subtitle">Total issued</div>
            </div>

            <div class="metric-card metric-card-4">
                <i class="bi bi-hourglass-split metric-icon"></i>
                <div class="metric-label">
                    <i class="bi bi-hourglass-split"></i> Pending Loans
                </div>
                <div class="metric-value" th:text="${pendingLoans}">0</div>
                <div class="metric-subtitle">Awaiting review</div>
            </div>
        </div>

        <!-- REVENUE CHART -->
        <div class="chart-section">
            <div class="chart-header">
                <div>
                    <div class="chart-title">Revenue Analytics</div>
                    <div class="chart-subtitle">Monthly revenue overview — current year</div>
                </div>
                <div class="chart-legend">
                    <div class="chart-legend-dot"></div>
                    <span>Revenue</span>
                </div>
            </div>
            <canvas id="revenueChart"></canvas>
        </div>

        <!-- TRANSACTIONS TABLE -->
        <div class="table-section">
            <div class="table-header">
                <div>
                    <div class="table-title">Recent Transactions</div>
                    <div class="chart-subtitle">Latest payment activity across the platform</div>
                </div>
                <a href="#" class="view-all-link">
                    View all
                    <i class="bi bi-arrow-right"></i>
                </a>
            </div>

            <div class="table-container">
                <table class="table">
                    <thead>
                        <tr>
                            <th>Sender</th>
                            <th>Receiver</th>
                            <th>Amount</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr th:each="t : ${transactions}">
                            <td>
                                <span class="email-badge" th:text="${t.senderEmail}"></span>
                            </td>
                            <td>
                                <span class="email-badge" th:text="${t.receiverEmail}"></span>
                            </td>
                            <td>
                                <span class="amount-value" th:text="${t.amount}"></span>
                            </td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>

    </div>

    <!-- CHART SCRIPT -->
    <script>
        const ctx = document.getElementById('revenueChart');
        
        if (ctx) {
            new Chart(ctx, {
                type: 'line',
                data: {
                    labels: ['Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun'],
                    datasets: [{
                        label: 'Revenue',
                        data: [1000, 2000, 1500, 3000, 4500, 6000],
                        borderColor: '#3b82f6',
                        backgroundColor: 'rgba(59, 130, 246, 0.08)',
                        fill: true,
                        tension: 0.4,
                        pointRadius: 5,
                        pointBackgroundColor: '#3b82f6',
                        pointBorderColor: 'white',
                        pointBorderWidth: 2,
                        pointHoverRadius: 7
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: true,
                    plugins: {
                        legend: {
                            display: false
                        },
                        filler: {
                            propagate: true
                        }
                    },
                    scales: {
                        y: {
                            beginAtZero: true,
                            grid: {
                                drawBorder: false,
                                color: 'rgba(0, 0, 0, 0.05)'
                            },
                            ticks: {
                                font: {
                                    family: '"Sora", sans-serif',
                                    size: 12
                                },
                                color: '#9ca3af',
                                padding: 12
                            }
                        },
                        x: {
                            grid: {
                                display: false,
                                drawBorder: false
                            },
                            ticks: {
                                font: {
                                    family: '"Sora", sans-serif',
                                    size: 12
                                },
                                color: '#9ca3af',
                                padding: 12
                            }
                        }
                    }
                }
            });
        }
    </script>

</body>

</html>