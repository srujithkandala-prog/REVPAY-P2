<!DOCTYPE html>
<html xmlns:th="http://www.thymeleaf.org">

<head>
<meta charset="UTF-8">
<title>Business Dashboard</title>

<!-- ICON LIBRARY -->
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">

<style>

body{
margin:0;
font-family:'Segoe UI',Tahoma,Geneva,Verdana,sans-serif;
background:#f1f5f9;
color:#334155;
}

/* ===== MAIN LAYOUT ===== */

.container{
display:flex;
height:100vh;
overflow:hidden;
}

/* ===== SIDEBAR ===== */

.sidebar{
width:240px;
background:linear-gradient(180deg,#0f172a,#020617);
color:white;
display:flex;
flex-direction:column;
box-shadow:3px 0 20px rgba(0,0,0,0.1);
}

.sidebar h2{
text-align:center;
padding:22px 0;
margin:0;
font-weight:600;
letter-spacing:1px;
border-bottom:1px solid #1e293b;
background:#020617;
}

/* MENU */

.menu{
flex:1;
overflow-y:auto;
padding-top:10px;
}

/* MENU LINKS */

.sidebar a{
display:block;
color:#cbd5f5;
padding:12px 20px;
text-decoration:none;
font-size:14px;
border-left:3px solid transparent;
transition:all 0.25s ease;
}

.sidebar a i{
margin-right:10px;
}

.sidebar a:hover{
background:#1e293b;
border-left:3px solid #38bdf8;
color:white;
padding-left:24px;
}

/* SCROLLBAR */

.menu::-webkit-scrollbar{
width:6px;
}

.menu::-webkit-scrollbar-thumb{
background:#475569;
border-radius:10px;
}

/* ===== MAIN ===== */

.main{
flex:1;
overflow-y:auto;
padding:30px;
}

/* PAGE TITLE */

.main h2{
margin-bottom:20px;
font-weight:600;
color:#1e293b;
}

/* ===== CARDS ===== */

.card{
background:white;
padding:25px;
border-radius:12px;
box-shadow:0 8px 20px rgba(0,0,0,0.05);
margin-bottom:25px;
transition:transform 0.2s ease,box-shadow 0.2s ease;
}

.card:hover{
transform:translateY(-3px);
box-shadow:0 12px 25px rgba(0,0,0,0.08);
}

.big{
font-size:34px;
color:#16a34a;
font-weight:bold;
margin-top:10px;
}

h1{
font-size:38px;
margin:10px 0;
}

/* ===== TABLE ===== */

table{
width:100%;
border-collapse:collapse;
margin-top:10px;
background:white;
border-radius:10px;
overflow:hidden;
}

th{
background:#0f172a;
color:white;
font-weight:500;
font-size:14px;
}

table,th,td{
border:1px solid #e2e8f0;
padding:12px;
text-align:left;
}

td{
font-size:14px;
}

tr:nth-child(even){
background:#f8fafc;
}

tr:hover{
background:#eef2ff;
transition:0.2s;
}

/* ===== RESPONSIVE ===== */

@media (max-width:900px){

.sidebar{
width:200px;
}

.main{
padding:20px;
}

.big{
font-size:26px;
}

}

</style>

</head>

<body>

<div class="container">

<!-- ================= SIDEBAR ================= -->

<div class="sidebar">

<h2>RevPay Business</h2>

<div class="menu">

<a href="/business-dashboard"><i class="fa-solid fa-chart-line"></i>Dashboard</a>
<a href="/profile"><i class="fa-solid fa-user"></i>Profile</a>
<a href="/send-money"><i class="fa-solid fa-paper-plane"></i>Send Money</a>
<a href="/add-money"><i class="fa-solid fa-wallet"></i>Add Money</a>
<a href="/request-money"><i class="fa-solid fa-hand-holding-dollar"></i>Request Money</a>
<a href="/incoming-requests"><i class="fa-solid fa-arrow-down"></i>Incoming Requests</a>
<a href="/outgoing-requests"><i class="fa-solid fa-arrow-up"></i>Outgoing Requests</a>
<a href="/withdraw-money"><i class="fa-solid fa-money-bill-wave"></i>Withdraw Money</a>
<a href="/transactions"><i class="fa-solid fa-money-check-dollar"></i>Transactions</a>
<a href="/transactions-history"><i class="fa-solid fa-clock-rotate-left"></i>Transaction History</a>
<a href="/create-invoice"><i class="fa-solid fa-file-invoice"></i>Create Invoice</a>
<a href="/invoices"><i class="fa-solid fa-file-lines"></i>Invoices</a>
<a href="/apply-loan"><i class="fa-solid fa-coins"></i>Apply Loan</a>
<a href="/my-loans"><i class="fa-solid fa-landmark"></i>My Loans</a>

<a th:href="@{/business/loan-repayments}">
<i class="fa-solid fa-calendar-check"></i>Loan Repayments
</a>

<a href="/payment-methods"><i class="fa-solid fa-credit-card"></i>Payment Methods</a>
<a href="/notifications"><i class="fa-solid fa-bell"></i>Notifications</a>
<a href="/logout"><i class="fa-solid fa-right-from-bracket"></i>Logout</a>

</div>

</div>

<!-- ================= MAIN ================= -->

<div class="main">

<h2>
Welcome Business,
<span th:text="${user.fullName}"></span> 🚀
</h2>

<!-- WALLET -->

<div class="card">

<div style="
background:#f8fafc;
padding:20px;
border-radius:10px;
margin-bottom:20px;
">

<h2>Wallet Balance 💰</h2>

<h1 style="color:#2c7be5;">
₹ <span th:text="${wallet}"></span>
</h1>

</div>

<h3>Total Revenue</h3>

<div class="big">
₹ <span th:text="${revenue}"></span>
</div>

</div>

<!-- TRANSACTIONS -->

<div class="card">

<h3>Recent Payments</h3>

<table th:if="${transactions.size()>0}">

<tr>
<th>Sender</th>
<th>Receiver</th>
<th>Amount</th>
<th>Date</th>
</tr>

<tr th:each="t,iter : ${transactions}" th:if="${iter.index<5}">

<td th:text="${t.senderEmail}"></td>
<td th:text="${t.receiverEmail}"></td>
<td>₹ <span th:text="${t.amount}"></span></td>

<td th:text="${#temporals.format(t.transactionDate,'dd-MM-yyyy HH:mm')}"></td>

</tr>

</table>

<p th:if="${transactions.size()==0}">
No transactions yet.
</p>

</div>

</div>

</div>

</body>
</html>