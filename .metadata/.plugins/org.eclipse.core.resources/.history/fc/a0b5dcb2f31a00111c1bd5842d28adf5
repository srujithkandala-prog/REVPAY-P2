<!DOCTYPE html>
<html xmlns:th="http://www.thymeleaf.org" lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>RevPay — Dashboard</title>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
<style>
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
:root {
    --navy-dark:   #0f172a;
    --navy-subtle: #1e293b;
    --navy-mid:    #111827;
    --accent-blue: #2563eb;
    --gold:        #eab308;
    --white:       #ffffff;
    --glass:       rgba(255,255,255,0.03);
    --border:      rgba(255,255,255,0.08);
    --muted:       rgba(255,255,255,0.5);
    --sidebar-w:   230px;
}
body {
    font-family: 'Inter', sans-serif;
    background: var(--navy-dark);
    color: var(--white);
    line-height: 1.6;
    display: flex; 
    min-height: 100vh;
    width: 100%;
    -webkit-font-smoothing: antialiased;
}
/* ── SIDEBAR ── */
.sidebar {
    width: var(--sidebar-w);
    background: var(--navy-subtle);
    border-right: 1px solid var(--border);
    position: fixed; top: 0; left: 0; bottom: 0;
    z-index: 50; overflow-y: auto;
    display: flex; flex-direction: column;
}
/* ── MAIN CONTENT AREA ── */
.main {
    margin-left: var(--sidebar-w); /* Pushes content to the right of sidebar */
    flex: 1; 
    display: flex; 
    flex-direction: column; 
    min-width: 0; /* Important for flex-box stability */
    min-height: 100vh;
}
.sidebar-logo {
    display: flex; align-items: center; gap: 11px;
    padding: 22px 20px 18px;
    text-decoration: none; position: relative; z-index: 1;
    border-bottom: 1px solid var(--border); margin-bottom: 8px;
}
.logo-box {
    width: 36px; height: 36px;
    background: var(--white); color: var(--navy-dark);
    border-radius: 8px;
    display: flex; align-items: center; justify-content: center;
    font-weight: 800; font-size: 16px;
    border: 2px solid var(--gold);
    flex-shrink: 0;
}
.logo-text { display: flex; flex-direction: column; }
.logo-text .s-name { color: white; font-size: 15px; font-weight: 800; }
.logo-text .s-tag  {
    font-size: 9px; font-weight: 700; letter-spacing: 1.5px;
    text-transform: uppercase; color: var(--gold);
    display: block; margin-top: 1px;
}
.nav-section {
    padding: 12px 20px 4px;
    font-size: 10px; font-weight: 700;
    color: rgba(255,255,255,0.2);
    letter-spacing: 2px; text-transform: uppercase;
}
.nav-item {
    display: flex; align-items: center; gap: 10px;
    padding: 9px 12px; margin: 1px 8px;
    text-decoration: none;
    font-size: 13px; font-weight: 500;
    color: rgba(255,255,255,0.5);
    border-radius: 6px;
    transition: all 0.2s;
}
.nav-icon {
    width: 28px; height: 28px; border-radius: 6px;
    background: rgba(255,255,255,0.04);
    display: flex; align-items: center; justify-content: center;
    font-size: 13px; flex-shrink: 0;
}
.nav-item.active {
    color: white; background: rgba(37,99,235,0.15);
    border: 1px solid rgba(37,99,235,0.25);
}
.nav-item.active .nav-icon { background: var(--accent-blue); }

/* ── TOPBAR ── */
.topbar {
    background: rgba(15,23,42,0.95);
    backdrop-filter: blur(10px);
    border-bottom: 1px solid var(--border);
    padding: 14px 32px;
    display: flex; align-items: center; justify-content: space-between;
    position: sticky; top: 0; z-index: 30;
}
.topbar-title { font-size: 16px; font-weight: 800; }
.topbar-sub   { font-size: 12px; color: var(--muted); }
.topbar-right { display: flex; align-items: center; gap: 10px; }
.tb-avatar {
    width: 34px; height: 34px; border-radius: 7px;
    background: var(--accent-blue);
    color: white; font-weight: 800; font-size: 14px;
    display: flex; align-items: center; justify-content: center;
}

/* ── CONTENT ── */
.content { padding: 28px 32px; flex: 1; }
.welcome-banner {
    background: linear-gradient(135deg, var(--navy-subtle) 0%, #0f1f38 100%);
    border: 1px solid var(--border);
    border-radius: 16px; padding: 26px 30px;
    display: flex; align-items: center; justify-content: space-between;
    margin-bottom: 20px;
}
.grad-card {
    border-radius: 16px; padding: 24px 26px;
    margin-bottom: 20px;
    background: linear-gradient(135deg, #1d4ed8 0%, #5b21b6 100%);
}
.grad-amount { font-size: 34px; font-weight: 800; margin-bottom: 18px; }
.grid-3 { display: grid; grid-template-columns: repeat(3, 1fr); gap: 14px; margin-bottom: 20px; }
.stat-card { background: var(--navy-subtle); border: 1px solid var(--border); border-radius: 12px; padding: 20px; }
.card { background: var(--navy-subtle); border: 1px solid var(--border); border-radius: 14px; padding: 22px; margin-bottom: 20px; }

/* ── QUICK ACTIONS ── */
.quick-grid { display: grid; grid-template-columns: repeat(5, 1fr); gap: 10px; }
.quick-item {
    display: flex; flex-direction: column; align-items: center; gap: 7px;
    padding: 14px 6px; border-radius: 10px; border: 1px solid var(--border);
    text-decoration: none; color: white;
}
.quick-icon { font-size: 17px; margin-bottom: 5px; }

/* ── TRANSACTIONS ── */
.txn-row { display: flex; align-items: center; gap: 12px; padding: 12px 0; border-bottom: 1px solid rgba(255,255,255,0.04); }
.amt-credit { color: #34d399; }
.amt-debit  { color: #f87171; }

@media (max-width: 768px) {
    .sidebar { display: none; }
    .main { margin-left: 0; }
}
</style>
</head>
<body>

<aside class="sidebar">
  <a th:href="@{/dashboard}" class="sidebar-logo">
    <div class="logo-box">R</div>
    <div class="logo-text">
      <span class="s-name">RevPay</span>
      <span class="s-tag">Personal</span>
    </div>
  </a>
  <div class="nav-section">Main</div>
  <a th:href="@{/dashboard}" class="nav-item active"><div class="nav-icon">🏠</div>Dashboard</a>
  <a th:href="@{/profile}"   class="nav-item"><div class="nav-icon">👤</div>Profile</a>
  <div class="nav-section">Payments</div>
  <a th:href="@{/send-money}"    class="nav-item"><div class="nav-icon">💸</div>Send Money</a>
  <a th:href="@{/add-money}"     class="nav-item"><div class="nav-icon">➕</div>Add Money</a>
  <div class="sidebar-bottom" style="margin-top:auto">
    <a th:href="@{/logout}" class="nav-item" style="color:#ef4444"><div class="nav-icon">🚪</div>Logout</a>
  </div>
</aside>

<div class="main">
  <div class="topbar">
    <div>
      <div class="topbar-title">Dashboard</div>
      <div class="topbar-sub" th:text="${#dates.format(#dates.createNow(),'EEEE, dd MMMM yyyy')}">Monday, 08 June 2026</div>
    </div>
    <div class="topbar-right">
      <span class="tb-badge" style="background:rgba(37,99,235,0.1); color:#93c5fd; padding:4px 8px; border-radius:4px; font-size:10px;">PERSONAL</span>
      <div class="tb-avatar" th:text="${username != null and !username.isEmpty() ? #strings.substring(username,0,1).toUpperCase() : 'U'}">U</div>
    </div>
  </div>

  <div class="content">
    <div class="welcome-banner">
      <div class="welcome-text">
        <h2>Welcome back, <span th:text="${username != null ? username : 'User'}">Guest</span> 👋</h2>
        <p>Here's your financial overview for today.</p>
      </div>
    </div>

    <div class="grad-card">
      <div style="font-size:11px; opacity:0.7; text-transform:uppercase; letter-spacing:1px">Wallet Balance</div>
      <div class="grad-amount">₹<span th:text="${walletBalance != null ? walletBalance : '0.00'}">0.00</span></div>
      <div style="display:flex; gap:10px">
        <a th:href="@{/add-money}" style="background:white; color:black; padding:8px 16px; border-radius:6px; text-decoration:none; font-size:12px; font-weight:bold">+ Add Money</a>
      </div>
    </div>

    <div class="grid-3">
      <div class="stat-card">
        <div style="color:#f87171; font-size:10px; font-weight:bold">OUTGOING</div>
        <div style="font-size:20px; font-weight:800">₹<span th:text="${totalSent != null ? totalSent : '0.0'}">0.0</span></div>
      </div>
      <div class="stat-card">
        <div style="color:#34d399; font-size:10px; font-weight:bold">INCOMING</div>
        <div style="font-size:20px; font-weight:800">₹<span th:text="${totalReceived != null ? totalReceived : '0.0'}">0.0</span></div>
      </div>
      <div class="stat-card">
        <div style="color:#93c5fd; font-size:10px; font-weight:bold">TRANSACTIONS</div>
        <div style="font-size:20px; font-weight:800" th:text="${totalTransactions != null ? totalTransactions : '0'}">0</div>
      </div>
    </div>

    <div class="card">
      <h3 style="font-size:14px; margin-bottom:15px">Quick Actions</h3>
      <div class="quick-grid">
        <a th:href="@{/send-money}" class="quick-item"><span>💸</span><span style="font-size:10px">Send</span></a>
        <a th:href="@{/request-money}" class="quick-item"><span>📧</span><span style="font-size:10px">Request</span></a>
        <a th:href="@{/add-money}" class="quick-item"><span>➕</span><span style="font-size:10px">Add</span></a>
        <a th:href="@{/payment-methods}" class="quick-item"><span>💳</span><span style="font-size:10px">Cards</span></a>
        <a th:href="@{/transaction-history}" class="quick-item"><span>📜</span><span style="font-size:10px">History</span></a>
      </div>
    </div>

    <div class="card">
      <h3 style="font-size:14px; margin-bottom:15px">Recent Transactions</h3>
      
      <div th:if="${recentTransactions == null or #lists.isEmpty(recentTransactions)}" style="text-align:center; padding:20px; color:var(--muted)">
        <p>No transactions found.</p>
      </div>

      <div th:each="txn : ${recentTransactions}" class="txn-row">
        <div style="flex:1">
          <div style="font-size:13px; font-weight:700" th:text="${txn.type}">Type</div>
          <div style="font-size:11px; color:var(--muted)" th:text="${txn.date}">Date</div>
        </div>
        <div class="txn-amount" 
             th:classappend="${txn.type == 'credit' or txn.type == 'RECEIVE'} ? 'amt-credit' : 'amt-debit'"
             th:text="${(txn.type == 'credit' or txn.type == 'RECEIVE' ? '+' : '-') + ' ₹' + txn.amount}">
          ₹0.00
        </div>
      </div>
    </div>
  </div>
</div>

</body>
</html>