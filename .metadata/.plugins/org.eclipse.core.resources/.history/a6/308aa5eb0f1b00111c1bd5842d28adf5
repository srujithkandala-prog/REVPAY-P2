<!DOCTYPE html>
<html xmlns:th="http://www.thymeleaf.org" lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>RevPay — Transactions History</title>

<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">

<style>

/* CORE THEME */

*, *::before, *::after { box-sizing:border-box;margin:0;padding:0;}

:root{
--navy-dark:#0f172a;
--navy-subtle:#1e293b;
--accent-blue:#2563eb;
--gold:#eab308;
--white:#ffffff;
--border:rgba(255,255,255,0.08);
--muted:rgba(255,255,255,0.5);
--sidebar-w:230px;
}

body{
font-family:'Inter',sans-serif;
background:var(--navy-dark);
color:var(--white);
display:flex;
min-height:100vh;
}

/* SIDEBAR */

.sidebar{
width:var(--sidebar-w);
background:var(--navy-subtle);
border-right:1px solid var(--border);
position:fixed;
top:0;left:0;bottom:0;
display:flex;
flex-direction:column;
}

.sidebar-logo{
display:flex;
align-items:center;
gap:10px;
padding:20px;
border-bottom:1px solid var(--border);
text-decoration:none;
}

.logo-box{
width:36px;height:36px;
background:white;color:black;
border-radius:8px;
display:flex;
align-items:center;
justify-content:center;
font-weight:800;
}

.logo-text .s-name{font-weight:800;}
.logo-text .s-tag{font-size:10px;color:var(--gold);}

.nav-section{
padding:12px 20px;
font-size:10px;
letter-spacing:2px;
color:rgba(255,255,255,0.2);
}

.nav-item{
display:flex;
align-items:center;
gap:10px;
padding:9px 12px;
margin:2px 8px;
text-decoration:none;
color:rgba(255,255,255,0.6);
border-radius:6px;
}

.nav-item:hover{background:rgba(255,255,255,0.05);}

.nav-item.active{
background:rgba(37,99,235,0.15);
color:white;
}

.nav-icon{
width:26px;height:26px;
display:flex;
align-items:center;
justify-content:center;
}

.sidebar-bottom{margin-top:auto;padding-bottom:20px}

/* MAIN */

.main{
margin-left:var(--sidebar-w);
flex:1;
display:flex;
flex-direction:column;
}

/* TOPBAR */

.topbar{
background:rgba(15,23,42,0.95);
border-bottom:1px solid var(--border);
padding:14px 30px;
display:flex;
align-items:center;
justify-content:space-between;
}

.tb-avatar{
width:34px;
height:34px;
border-radius:8px;
background:var(--accent-blue);
display:flex;
align-items:center;
justify-content:center;
font-weight:700;
}

/* CONTENT */

.content{
padding:30px;
}

/* TOOLBAR */

.txn-toolbar{
display:flex;
gap:12px;
margin-bottom:20px;
}

.txn-toolbar input{
padding:10px;
border-radius:8px;
border:1px solid var(--border);
background:#0f172a;
color:white;
}

.btn-export{
background:var(--accent-blue);
border:none;
padding:10px 18px;
border-radius:8px;
color:white;
cursor:pointer;
}

/* CARD */

.card{
background:var(--navy-subtle);
border:1px solid var(--border);
border-radius:14px;
padding:20px;
}

/* TABLE */

table{
width:100%;
border-collapse:collapse;
}

thead th{
text-align:left;
font-size:11px;
color:var(--muted);
padding:14px;
border-bottom:1px solid var(--border);
}

tbody td{
padding:14px;
border-bottom:1px solid rgba(255,255,255,0.05);
}

.amount-cell{
color:var(--gold);
font-weight:700;
}

.date-cell{
font-size:12px;
color:var(--muted);
}

.status{
background:#2563eb;
padding:4px 8px;
border-radius:6px;
font-size:11px;
}

</style>
</head>

<body>

<!-- SIDEBAR -->

<aside class="sidebar">

<a th:href="@{/dashboard}" class="sidebar-logo">
<div class="logo-box">R</div>
<div class="logo-text">
<span class="s-name">RevPay</span>
<span class="s-tag">PERSONAL</span>
</div>
</a>

<div class="nav-section">Main</div>
<a th:href="@{/dashboard}" class="nav-item"><div class="nav-icon">🏠</div>Dashboard</a>
<a th:href="@{/profile}" class="nav-item"><div class="nav-icon">👤</div>Profile</a>

<div class="nav-section">Payments</div>
<a th:href="@{/send-money}" class="nav-item"><div class="nav-icon">💸</div>Send Money</a>
<a th:href="@{/add-money}" class="nav-item"><div class="nav-icon">➕</div>Add Money</a>
<a th:href="@{/request-money}" class="nav-item"><div class="nav-icon">📩</div>Request Money</a>
<a th:href="@{/withdraw-money}" class="nav-item"><div class="nav-icon">🏦</div>Withdraw</a>

<div class="nav-section">History</div>
<a th:href="@{/transactions}" class="nav-item"><div class="nav-icon">🔄</div>Transactions</a>
<a th:href="@{/transactions-history}" class="nav-item active"><div class="nav-icon">📋</div>Transaction History</a>

<div class="sidebar-bottom">
<a th:href="@{/logout}" class="nav-item"><div class="nav-icon">🚪</div>Logout</a>
</div>

</aside>

<!-- MAIN -->

<div class="main">

<div class="topbar">

<div>
<div style="font-weight:800;font-size:16px;">Transaction History</div>
<div style="font-size:12px;color:var(--muted);" th:text="${#dates.format(#dates.createNow(),'EEEE, dd MMMM yyyy')}"></div>
</div>

<div class="tb-avatar"
th:text="${username != null ? #strings.substring(username,0,1).toUpperCase() : 'U'}">
</div>

</div>

<div class="content">

<!-- SEARCH + EXPORT -->

<div class="txn-toolbar">
<input type="text" id="searchTxn" placeholder="Search transactions...">
<button class="btn-export" onclick="exportCSV()">Export CSV</button>
</div>

<div class="card">

<div th:if="${transactions == null or #lists.isEmpty(transactions)}"
style="text-align:center;padding:40px;color:var(--muted);">
No transactions found.
</div>

<table id="txnTable" th:if="${transactions != null and !#lists.isEmpty(transactions)}">

<thead>
<tr>
<th>Sender</th>
<th>Receiver</th>
<th>Amount</th>
<th>Date</th>
<th>Status</th>
</tr>
</thead>

<tbody>

<tr th:each="t : ${transactions}">
<td th:text="${t.senderEmail}"></td>
<td th:text="${t.receiverEmail}"></td>

<td class="amount-cell">
₹ <span th:text="${t.amount}"></span>
</td>

<td class="date-cell"
th:text="${#temporals.format(t.transactionDate,'dd-MM-yyyy HH:mm')}">
</td>

<td>
<span class="status"
th:text="${t.type}">
</span>
</td>

</tr>

</tbody>
</table>

</div>

</div>
</div>

<script>

function exportCSV(){

let table=document.getElementById("txnTable");

let csv=[];

for(let i=0;i<table.rows.length;i++){

let row=[],cols=table.rows[i].querySelectorAll("td,th");

for(let j=0;j<cols.length;j++)
row.push(cols[j].innerText);

csv.push(row.join(","));

}

let file=new Blob([csv.join("\n")],{type:"text/csv"});

let a=document.createElement("a");

a.href=URL.createObjectURL(file);
a.download="transactions.csv";
a.click();

}

</script>

</body>
</html>