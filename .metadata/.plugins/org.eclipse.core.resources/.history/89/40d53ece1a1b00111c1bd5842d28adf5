<!DOCTYPE html>
<html xmlns:th="http://www.thymeleaf.org">

<head>
<meta charset="UTF-8">
<title>Outgoing Requests</title>

<link rel="stylesheet"
href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">

<style>

body{
margin:0;
font-family:'Segoe UI',sans-serif;

/* Professional background */
background:linear-gradient(135deg,#f1f5f9,#e2e8f0);

color:#334155;
}

/* ===== LAYOUT ===== */

.container{
display:flex;
height:100vh;
}

/* ===== SIDEBAR ===== */

.sidebar{
width:240px;
background:linear-gradient(180deg,#0f172a,#020617);
color:white;
display:flex;
flex-direction:column;
}

.sidebar h2{
text-align:center;
padding:20px;
margin:0;
border-bottom:1px solid #1e293b;
}

.sidebar a{
display:block;
color:#cbd5f5;
padding:12px 20px;
text-decoration:none;
border-left:3px solid transparent;
transition:0.25s;
}

.sidebar a i{
margin-right:10px;
}

.sidebar a:hover{
background:#1e293b;
border-left:3px solid #38bdf8;
padding-left:25px;
color:white;
}

/* ===== MAIN AREA ===== */

.main{
flex:1;
padding:40px;
overflow:auto;
}

/* HEADER */

.header{
display:flex;
justify-content:space-between;
align-items:center;
margin-bottom:25px;
}

.header h2{
margin:0;
}

/* DASHBOARD BUTTON */

.dashboard-btn{
background:#16a34a;
color:white;
padding:8px 15px;
border-radius:6px;
text-decoration:none;
font-size:14px;
}

.dashboard-btn:hover{
background:#15803d;
}

/* CARD */

.card{
background:white;
padding:30px;
border-radius:12px;
box-shadow:0 10px 30px rgba(0,0,0,0.08);
}

/* TABLE */

table{
width:100%;
border-collapse:collapse;
margin-top:15px;
}

th{
background:#0f172a;
color:white;
padding:12px;
}

td{
padding:12px;
border-bottom:1px solid #e2e8f0;
}

tr:hover{
background:#f8fafc;
}

/* STATUS BADGES */

.status{
padding:4px 10px;
border-radius:12px;
font-size:12px;
font-weight:bold;
}

.pending{
background:#fef3c7;
color:#92400e;
}

.accepted{
background:#dcfce7;
color:#166534;
}

.declined{
background:#fee2e2;
color:#991b1b;
}

.cancelled{
background:#e5e7eb;
color:#374151;
}

/* CANCEL BUTTON */

button{
padding:6px 12px;
background:#ef4444;
color:white;
border:none;
border-radius:6px;
cursor:pointer;
font-size:13px;
}

button:hover{
background:#dc2626;
}

</style>

</head>

<body>

<div class="container">

<!-- SIDEBAR -->

<div class="sidebar">

<h2>RevPay Business</h2>

<a href="/business-dashboard"><i class="fa-solid fa-chart-line"></i>Dashboard</a>
<a href="/profile"><i class="fa-solid fa-user"></i>Profile</a>
<a href="/send-money"><i class="fa-solid fa-paper-plane"></i>Send Money</a>
<a href="/request-money"><i class="fa-solid fa-hand-holding-dollar"></i>Request Money</a>
<a href="/incoming-requests"><i class="fa-solid fa-arrow-down"></i>Incoming Requests</a>
<a href="/outgoing-requests"><i class="fa-solid fa-arrow-up"></i>Outgoing Requests</a>
<a href="/transactions"><i class="fa-solid fa-money-bill-transfer"></i>Transactions</a>
<a href="/logout"><i class="fa-solid fa-right-from-bracket"></i>Logout</a>

</div>

<!-- MAIN CONTENT -->

<div class="main">

<div class="header">

<h2>Outgoing Money Requests 📤</h2>

<a href="/business-dashboard" class="dashboard-btn">
<i class="fa-solid fa-arrow-left"></i> Dashboard
</a>

</div>

<div class="card">

<table>

<tr>
<th>Receiver</th>
<th>Amount</th>
<th>Purpose</th>
<th>Status</th>
<th>Action</th>
</tr>

<tr th:each="r : ${requests}">

<td th:text="${r.receiverEmail}"></td>

<td>
₹ <span th:text="${r.amount}"></span>
</td>

<td th:text="${r.purpose}"></td>

<td>

<span th:if="${r.status=='PENDING'}"
class="status pending">Pending</span>

<span th:if="${r.status=='ACCEPTED'}"
class="status accepted">Accepted</span>

<span th:if="${r.status=='DECLINED'}"
class="status declined">Declined</span>

<span th:if="${r.status=='CANCELLED'}"
class="status cancelled">Cancelled</span>

</td>

<td>

<form th:if="${r.status=='PENDING'}"
th:action="@{/cancel-request/{id}(id=${r.id})}"
method="get">

<button type="submit">
<i class="fa-solid fa-xmark"></i> Cancel
</button>

</form>

</td>

</tr>

</table>

</div>

</div>

</div>

</body>
</html>