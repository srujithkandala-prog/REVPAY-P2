<!DOCTYPE html>
<html xmlns:th="http://www.thymeleaf.org">

<head>
<meta charset="UTF-8">
<title>My Loans</title>

<link rel="stylesheet"
href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">

<style>

body{
margin:0;
font-family:'Segoe UI',sans-serif;
background:#f1f5f9;
color:#334155;
}

/* LAYOUT */

.wrapper{
display:flex;
height:100vh;
}

/* SIDEBAR */

.sidebar{
width:240px;
background:linear-gradient(180deg,#0f172a,#020617);
color:white;
display:flex;
flex-direction:column;
}

.sidebar h2{
text-align:center;
padding:20px;
margin:0;
border-bottom:1px solid #1e293b;
}

.sidebar a{
display:block;
padding:12px 20px;
color:#cbd5f5;
text-decoration:none;
border-left:3px solid transparent;
transition:0.2s;
}

.sidebar a:hover{
background:#1e293b;
border-left:3px solid #38bdf8;
color:white;
}

/* MAIN */

.main{
flex:1;
padding:40px;
}

/* HEADER */

.header{
display:flex;
justify-content:space-between;
align-items:center;
margin-bottom:20px;
}

/* DASHBOARD BUTTON */

.dashboard-btn{
background:#16a34a;
color:white;
padding:8px 15px;
border-radius:6px;
text-decoration:none;
}

.dashboard-btn:hover{
background:#15803d;
}

/* CARD */

.card{
background:white;
padding:25px;
border-radius:12px;
box-shadow:0 10px 25px rgba(0,0,0,0.08);
}

/* TABLE */

table{
width:100%;
border-collapse:collapse;
margin-top:10px;
}

th{
background:#0f172a;
color:white;
padding:12px;
}

td{
padding:12px;
border-bottom:1px solid #e2e8f0;
}

tr:hover{
background:#f8fafc;
}

/* STATUS BADGES */

.badge{
padding:4px 10px;
border-radius:12px;
font-size:12px;
font-weight:bold;
}

.pending{
background:#fef3c7;
color:#92400e;
}

.approved{
background:#dcfce7;
color:#166534;
}

.rejected{
background:#fee2e2;
color:#991b1b;
}

</style>

</head>

<body>

<div class="wrapper">

<!-- SIDEBAR -->

<div class="sidebar">

<h2>RevPay Business</h2>

<a href="/business-dashboard"><i class="fa-solid fa-chart-line"></i> Dashboard</a>
<a href="/send-money"><i class="fa-solid fa-paper-plane"></i> Send Money</a>
<a href="/transactions-history"><i class="fa-solid fa-clock"></i> Transactions</a>
<a href="/create-invoice"><i class="fa-solid fa-file-invoice"></i> Create Invoice</a>
<a href="/apply-loan"><i class="fa-solid fa-landmark"></i> Apply Loan</a>
<a href="/my-loans"><i class="fa-solid fa-coins"></i> My Loans</a>
<a href="/logout"><i class="fa-solid fa-right-from-bracket"></i> Logout</a>

</div>

<!-- MAIN -->

<div class="main">

<div class="header">

<h2>My Loan Applications</h2>

<a href="/business-dashboard" class="dashboard-btn">
← Dashboard
</a>

</div>

<div class="card">

<table>

<tr>
<th>Amount</th>
<th>Purpose</th>
<th>Tenure</th>
<th>Interest %</th>
<th>EMI</th>
<th>Months</th>
<th>Repayment</th>
<th>Status</th>
</tr>

<tr th:each="l : ${loans}">

<td>₹ <span th:text="${l.amount}"></span></td>

<td th:text="${l.purpose}"></td>

<td th:text="${l.tenureMonths} + ' months'"></td>

<td th:text="${l.interestRate} + '%'"></td>

<td>
₹ <span th:text="${#numbers.formatDecimal(l.emi,1,2)}"></span>
</td>

<td th:text="${l.totalMonths}"></td>

<td>

<span th:if="${l.emi != null}">
Monthly EMI: ₹
<span th:text="${#numbers.formatDecimal(l.emi,1,2)}"></span>
</span>

</td>

<td>

<span th:if="${l.status=='PENDING'}"
class="badge pending">Pending</span>

<span th:if="${l.status=='APPROVED'}"
class="badge approved">Approved</span>

<span th:if="${l.status=='REJECTED'}"
class="badge rejected">Rejected</span>

</td>

</tr>

</table>

</div>

</div>

</div>

</body>
</html>