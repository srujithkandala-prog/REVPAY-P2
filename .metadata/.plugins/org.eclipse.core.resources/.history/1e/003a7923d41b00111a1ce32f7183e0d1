<!DOCTYPE html>
<html xmlns:th="http://www.thymeleaf.org">

<head>

<title>Transaction Report</title>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<style>

body{
font-family:Arial;
background:#f4f6f9;
padding:30px;
}

.top{
display:flex;
justify-content:space-between;
align-items:center;
}

button{
background:#2563eb;
color:white;
border:none;
padding:8px 14px;
border-radius:6px;
cursor:pointer;
}

table{
width:100%;
border-collapse:collapse;
margin-top:20px;
background:white;
}

th,td{
padding:10px;
border:1px solid #ddd;
}

th{
background:#0f172a;
color:white;
}

.card{
background:white;
padding:20px;
margin-top:20px;
border-radius:10px;
}

</style>

</head>

<body>

<div class="top">

<h1>Transactions Report</h1>

<a href="/admin-dashboard">
<button>← Back to Dashboard</button>
</a>

</div>

<div class="card">

<canvas id="txChart"></canvas>

</div>

<table>

<tr>
<th>Sender</th>
<th>Receiver</th>
<th>Amount</th>
<th>Date</th>
</tr>

<tr th:each="t : ${transactions}">

<td th:text="${t.senderEmail}"></td>
<td th:text="${t.receiverEmail}"></td>
<td th:text="${t.amount}"></td>
<td th:text="${#temporals.format(t.transactionDate,'dd-MM-yyyy HH:mm')}"></td>

</tr>

</table>

<script>

const ctx = document.getElementById('txChart');

new Chart(ctx,{
type:'bar',

data:{
labels:['Transactions'],
datasets:[{
label:'Total Transactions',
data:[[${transactions.size()}]],
backgroundColor:'blue'
}]
}

});

</script>

</body>
</html>