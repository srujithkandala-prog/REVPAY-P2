<!DOCTYPE html>
<html xmlns:th="http://www.thymeleaf.org" lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>RevPay | Premier Digital Banking & Payments</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <style>
        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
        
        :root {
            --navy-dark: #0f172a;
            --navy-subtle: #1e293b;
            --accent-blue: #2563eb;
            --gold-premium: #eab308;
            --white: #ffffff;
            --glass: rgba(255, 255, 255, 0.03);
            --border: rgba(255, 255, 255, 0.1);
        }

        body {
            font-family: 'Inter', sans-serif;
            background-color: var(--navy-dark);
            color: var(--white);
            line-height: 1.6;
        }

        /* ─── NAVIGATION ─── */
        header {
            background: rgba(15, 23, 42, 0.9);
            backdrop-filter: blur(10px);
            padding: 20px 80px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            position: sticky;
            top: 0;
            z-index: 100;
            border-bottom: 1px solid var(--border);
        }

        .logo { display: flex; align-items: center; gap: 12px; text-decoration: none; }
        .logo-box {
            width: 40px; height: 40px;
            background: var(--white);
            color: var(--navy-dark);
            border-radius: 8px;
            display: flex; align-items: center; justify-content: center;
            font-weight: 800; font-size: 20px;
            border: 2px solid var(--gold-premium);
        }
        .logo span { color: white; font-size: 22px; font-weight: 700; letter-spacing: -0.5px; }

        nav a {
            color: rgba(255,255,255,0.7);
            text-decoration: none;
            font-size: 14px;
            font-weight: 500;
            margin-left: 30px;
            transition: 0.3s;
        }
        nav a:hover { color: var(--gold-premium); }
        nav a.btn-nav {
            background: var(--accent-blue);
            color: white;
            padding: 10px 24px;
            border-radius: 6px;
            font-weight: 600;
        }

        /* ─── HERO SECTION ─── */
        .hero {
            padding: 120px 80px;
            display: flex;
            align-items: center;
            background: linear-gradient(to right, var(--navy-dark) 40%, transparent), 
                        url('https://images.unsplash.com/photo-1554469384-e58fac16e23a?q=80&w=1974&auto=format&fit=crop');
            background-size: cover;
            background-position: center;
            min-height: 85vh;
        }

        .hero-content { max-width: 650px; animation: fadeInUp 1s ease; }
        
        .hero-tag {
            color: var(--gold-premium);
            font-weight: 700;
            letter-spacing: 2px;
            text-transform: uppercase;
            font-size: 13px;
            margin-bottom: 20px;
            display: block;
        }

        .hero h1 {
            font-size: 60px;
            font-weight: 800;
            line-height: 1.1;
            margin-bottom: 25px;
            letter-spacing: -2px;
        }

        .hero p {
            font-size: 18px;
            color: rgba(255,255,255,0.7);
            margin-bottom: 40px;
            max-width: 500px;
        }

        .hero-btns { display: flex; gap: 15px; }
        .btn-main {
            padding: 16px 32px;
            border-radius: 8px;
            font-weight: 700;
            text-decoration: none;
            transition: 0.3s;
        }
        .btn-primary { background: var(--accent-blue); color: white; }
        .btn-primary:hover { transform: translateY(-3px); box-shadow: 0 10px 20px rgba(37, 99, 235, 0.3); }
        .btn-outline { border: 1px solid white; color: white; }
        .btn-outline:hover { background: white; color: var(--navy-dark); }

        /* ─── FEATURES ─── */
        .section { padding: 100px 80px; }
        .section-title { text-align: center; margin-bottom: 60px; }
        .section-title h2 { font-size: 36px; margin-bottom: 15px; }
        .section-title p { color: rgba(255,255,255,0.5); }

        .feature-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 30px;
        }

        .feature-card {
            background: var(--glass);
            border: 1px solid var(--border);
            padding: 40px;
            border-radius: 20px;
            transition: 0.4s;
        }
        .feature-card:hover {
            background: rgba(255,255,255,0.06);
            border-color: var(--gold-premium);
            transform: translateY(-10px);
        }

        .icon-circle {
            width: 60px; height: 60px;
            background: rgba(37, 99, 235, 0.1);
            color: var(--accent-blue);
            border-radius: 50%;
            display: flex; align-items: center; justify-content: center;
            font-size: 24px;
            margin-bottom: 25px;
        }

        /* ─── ACCOUNT SELECTION ─── */
        .account-box {
            display: flex;
            gap: 40px;
            margin-top: 50px;
        }

        .account-card {
            flex: 1;
            background: linear-gradient(145deg, #1e293b, #0f172a);
            padding: 50px;
            border-radius: 24px;
            border: 1px solid var(--border);
            text-align: center;
        }

        .account-card.premium {
            border: 1px solid var(--gold-premium);
            position: relative;
        }

        .premium-tag {
            position: absolute;
            top: -15px;
            left: 50%;
            transform: translateX(-50%);
            background: var(--gold-premium);
            color: var(--navy-dark);
            padding: 5px 15px;
            border-radius: 20px;
            font-weight: 800;
            font-size: 12px;
        }

        /* ─── FOOTER ─── */
        footer {
            padding: 60px 80px;
            border-top: 1px solid var(--border);
            display: flex;
            justify-content: space-between;
            align-items: center;
            background: #080d1a;
        }

        @keyframes fadeInUp {
            from { opacity: 0; transform: translateY(30px); }
            to { opacity: 1; transform: translateY(0); }
        }

        /* Responsive */
        @media (max-width: 992px) {
            header, .hero, .section, footer { padding: 40px 20px; }
            .feature-grid { grid-template-columns: 1fr; }
            .hero h1 { font-size: 40px; }
            .account-box { flex-direction: column; }
        }
    </style>
</head>
<body>

<header>
    <a th:href="@{/}" class="logo">
        <div class="logo-box">R</div>
        <span>RevPay <span style="font-weight: 300; opacity: 0.6;"></span></span>
    </a>
    <nav>
        <a th:href="@{/}">Private Banking</a>
        <a th:href="@{/login}">Client Login</a>
        <a th:href="@{/register}" class="btn-nav">Join RevPay</a>
    </nav>
</header>

<section class="hero">
    <div class="hero-content">
        <span class="hero-tag">Excellence in Digital Finance</span>
        <h1>Modern Banking for the <span style="color: var(--gold-premium);">Global Citizen.</span></h1>
        <p>Experience a seamless fusion of technology and traditional banking security. Manage your wealth with precision and privacy.</p>
        <div class="hero-btns">
            <a th:href="@{/register}" class="btn-main btn-primary">Open an Account</a>
            <a th:href="@{/login}" class="btn-main btn-outline">Access Portfolio</a>
        </div>
    </div>
</section>



<section class="section">
    <div class="section-title">
        <span style="color: var(--gold-premium); font-weight: 700; font-size: 14px;">INSTITUTIONAL GRADE</span>
        <h2>Our Core Capabilities</h2>
        <p>Built on the foundation of security, speed, and absolute reliability.</p>
    </div>
    
    <div class="feature-grid">
        <div class="feature-card">
            <div class="icon-circle">🛡️</div>
            <h3>Vault Security</h3>
            <p>Military-grade encryption and multi-factor authentication protect every micro-transaction in real-time.</p>
        </div>
        <div class="feature-card">
            <div class="icon-circle">🌍</div>
            <h3>Global Remittance</h3>
            <p>Send and receive capital across 150+ countries with institutional exchange rates and zero hidden fees.</p>
        </div>
        <div class="feature-card">
            <div class="icon-circle">📈</div>
            <h3>Wealth Analytics</h3>
            <p>Advanced AI-driven insights to track your spending habits and optimize your business cash flow.</p>
        </div>
    </div>
</section>

<section class="section" style="background: #0d1321;">
    <div class="section-title">
        <h2>Tailored Account Structures</h2>
    </div>
    <div class="account-box">
        <div class="account-card">
            <h3>Personal Tier</h3>
            <p style="margin: 20px 0; font-size: 24px; font-weight: 800;">Free</p>
            <ul style="list-style: none; text-align: left; margin-bottom: 30px; color: rgba(255,255,255,0.6);">
                <li style="margin-bottom: 10px;">✓ Multi-currency Wallet</li>
                <li style="margin-bottom: 10px;">✓ Real-time Fraud Alerts</li>
                <li style="margin-bottom: 10px;">✓ Digital Debit Card</li>
            </ul>
            <a th:href="@{/register}" class="btn-main btn-outline" style="display: block;">Get Started</a>
        </div>
        
        <div class="account-card premium">
            <div class="premium-tag">MOST ELITE</div>
            <h3 style="color: var(--gold-premium);">Business Gold</h3>
            <p style="margin: 20px 0; font-size: 24px; font-weight: 800;">Enterprise</p>
            <ul style="list-style: none; text-align: left; margin-bottom: 30px; color: rgba(255,255,255,0.8);">
                <li style="margin-bottom: 10px;">✓ Unlimited Institutional Invoicing</li>
                <li style="margin-bottom: 10px;">✓ Dedicated Account Manager</li>
                <li style="margin-bottom: 10px;">✓ Priority Loan Processing</li>
            </ul>
            <a th:href="@{/register}" class="btn-main btn-primary" style="display: block;">Contact Sales</a>
        </div>
    </div>
</section>

<footer>
    <div class="logo">
        <div class="logo-box">R</div>
        <span>RevPay</span>
    </div>
    <p style="font-size: 13px; color: rgba(255,255,255,0.4);">© 2026 RevPay International. All Rights Reserved. Member FDIC.</p>
    <div class="nav">
        <a href="#">Privacy Policy</a>
        <a href="#">Security Audit</a>
        <a href="#">Support</a>
    </div>
</footer>

</body>
</html>