<!DOCTYPE html>
<html xmlns:th="http://www.thymeleaf.org">
<head>

<title>Loan Repayments</title>

<style>

body{
font-family:Arial;
background:#0f172a;
color:white;
padding:40px;
}

table{
width:100%;
border-collapse:collapse;
margin-top:20px;
}

th,td{
padding:12px;
border-bottom:1px solid #333;
text-align:left;
}

th{
color:#94a3b8;
}

.amount{
color:#34d399;
font-weight:bold;
}

</style>

</head>

<body>

<h2>Loan Repayments</h2>

<table>

<thead>

<tr>
<th>Payer</th>
<th>Amount</th>
<th>Date</th>
</tr>

</thead>

<tbody>

<tr th:each="t : ${repayments}">

<td th:text="${t.senderEmail}"></td>

<td class="amount">₹ <span th:text="${t.amount}"></span></td>

<td th:text="${#temporals.format(t.transactionDate,'dd MMM yyyy')}"></td>

</tr>

</tbody>

</table>

</body>
</html>