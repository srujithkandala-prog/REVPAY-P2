<!DOCTYPE html>
<html xmlns:th="http://www.thymeleaf.org">

<head>
<meta charset="UTF-8">
<title>Profile Settings</title>

<link rel="stylesheet"
href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">

<style>

body{
margin:0;
font-family:'Segoe UI',sans-serif;
background:#f1f5f9;
color:#334155;
}

.container{
display:flex;
height:100vh;
}

.sidebar{
width:240px;
background:linear-gradient(180deg,#0f172a,#020617);
color:white;
display:flex;
flex-direction:column;
}

.sidebar h2{
text-align:center;
padding:20px;
margin:0;
border-bottom:1px solid #1e293b;
}

.sidebar a{
display:block;
color:#cbd5f5;
padding:12px 20px;
text-decoration:none;
border-left:3px solid transparent;
}

.sidebar a:hover{
background:#1e293b;
border-left:3px solid #38bdf8;
}

.main{
flex:1;
padding:40px;
}

.card{
background:white;
padding:30px;
border-radius:12px;
box-shadow:0 8px 20px rgba(0,0,0,0.05);
max-width:700px;
}

input{
width:100%;
padding:12px;
margin-bottom:15px;
border:1px solid #cbd5e1;
border-radius:6px;
}

button{
width:100%;
padding:12px;
background:#2563eb;
border:none;
color:white;
border-radius:6px;
cursor:pointer;
}

button:hover{
background:#1e40af;
}

/* SUCCESS POPUP */

.popup{
position:fixed;
top:20px;
right:20px;
background:#16a34a;
color:white;
padding:15px 20px;
border-radius:8px;
display:flex;
align-items:center;
gap:10px;
font-weight:600;
box-shadow:0 8px 20px rgba(0,0,0,0.2);
z-index:1000;
}

.error{
background:#ef4444;
color:white;
padding:10px;
border-radius:6px;
margin-bottom:15px;
}

.tabs{
display:flex;
margin-bottom:20px;
}

.tab{
flex:1;
padding:12px;
text-align:center;
cursor:pointer;
border-bottom:2px solid #eee;
}

.tab.active{
border-bottom:3px solid #2563eb;
color:#2563eb;
font-weight:600;
}

.tab-content{
display:none;
}

.tab-content.active{
display:block;
}

</style>

</head>

<body>

<!-- SUCCESS POPUP -->
<div th:if="${successMessage}" class="popup">
<i class="fa-solid fa-circle-check"></i>
<span th:text="${successMessage}"></span>
</div>

<div class="container">

<div class="sidebar">

<h2 th:if="${user.role.name() == 'BUSINESS'}">RevPay Business</h2>
<h2 th:if="${user.role.name() != 'BUSINESS'}">RevPay</h2>

<a th:href="${user.role.name() == 'BUSINESS'} ? '/business-dashboard' : '/dashboard'">
<i class="fa-solid fa-chart-line"></i> Dashboard
</a>

<a href="/profile"><i class="fa-solid fa-user"></i> Profile</a>
<a href="/send-money"><i class="fa-solid fa-paper-plane"></i> Send Money</a>
<a href="/notifications"><i class="fa-solid fa-bell"></i> Notifications</a>
<a href="/logout"><i class="fa-solid fa-right-from-bracket"></i> Logout</a>

</div>

<div class="main">

<h1>Profile Settings</h1>

<div class="card">

<div class="tabs">

<div class="tab active" onclick="openTab(event,'profile')">
Profile
</div>

<div class="tab" onclick="openTab(event,'security')">
Security
</div>

<div class="tab" onclick="openTab(event,'pin')">
Transaction PIN
</div>

</div>

<!-- PROFILE -->

<div id="profile" class="tab-content active">

<form action="/update-profile" method="post">

<input type="text"
name="fullName"
th:value="${user.fullName}"
placeholder="Full Name"
required>

<input type="text"
name="phone"
th:value="${user.phone}"
placeholder="Phone Number"
required>

<button type="submit">
Update Profile
</button>

</form>

</div>

<!-- PASSWORD -->

<div id="security" class="tab-content">

<div th:if="${error}" class="error" th:text="${error}"></div>

<form action="/change-password" method="post">

<input type="password"
name="currentPassword"
placeholder="Current Password"
required>

<input type="password"
name="newPassword"
placeholder="New Password"
required>

<button type="submit">
Change Password
</button>

</form>

</div>

<!-- PIN -->

<div id="pin" class="tab-content">

<form action="/set-transaction-pin" method="post">

<input type="password"
name="transactionPin"
placeholder="Enter 4 digit PIN"
pattern="[0-9]{4}"
maxlength="4"
required>

<button type="submit">
Save PIN
</button>

</form>

</div>

</div>

</div>

</div>

<script>

function openTab(evt,tabName){

var content=document.getElementsByClassName("tab-content");

for(var i=0;i<content.length;i++){
content[i].classList.remove("active");
}

var tabs=document.getElementsByClassName("tab");

for(var i=0;i<tabs.length;i++){
tabs[i].classList.remove("active");
}

document.getElementById(tabName).classList.add("active");

evt.currentTarget.classList.add("active");

}

setTimeout(function(){

var popup=document.querySelector(".popup");

if(popup){
popup.style.display="none";
}

},3000);

</script>

</body>
</html>