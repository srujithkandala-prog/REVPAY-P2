<!DOCTYPE html>
<html xmlns:th="http://www.thymeleaf.org">

<head>
<meta charset="UTF-8">
<title>Add Money</title>

<link rel="stylesheet"
href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">

<style>

body{
margin:0;
font-family:'Segoe UI',sans-serif;
background:#f1f5f9;
color:#334155;
}

/* LAYOUT */

.container{
display:flex;
height:100vh;
}

/* SIDEBAR */

.sidebar{
width:240px;
background:linear-gradient(180deg,#0f172a,#020617);
color:white;
display:flex;
flex-direction:column;
}

.sidebar h2{
text-align:center;
padding:20px;
margin:0;
border-bottom:1px solid #1e293b;
}

.menu{
flex:1;
}

.sidebar a{
display:block;
color:#cbd5f5;
padding:12px 20px;
text-decoration:none;
border-left:3px solid transparent;
transition:0.25s;
}

.sidebar a i{
margin-right:10px;
}

.sidebar a:hover{
background:#1e293b;
border-left:3px solid #38bdf8;
padding-left:25px;
}

/* MAIN AREA */

.main{
flex:1;
display:flex;
flex-direction:column;
align-items:center;
justify-content:center;
padding:40px;
}

/* HEADER */

.header{
position:absolute;
top:30px;
right:40px;
}

.btn{
padding:10px 18px;
border-radius:6px;
text-decoration:none;
font-size:14px;
margin-left:10px;
}

.btn-dashboard{
background:#16a34a;
color:white;
}

.btn-dashboard:hover{
background:#15803d;
}

.btn-logout{
background:#ef4444;
color:white;
}

.btn-logout:hover{
background:#dc2626;
}

/* CARD */

.card{
background:white;
padding:35px;
border-radius:14px;
box-shadow:0 10px 25px rgba(0,0,0,0.08);
width:420px;
text-align:center;
}

/* WALLET */

.wallet{
background:#2563eb;
color:white;
padding:14px;
border-radius:8px;
margin-bottom:20px;
font-weight:bold;
}

/* INPUT */

input{
width:100%;
padding:12px;
margin-top:10px;
margin-bottom:15px;
border:1px solid #cbd5e1;
border-radius:6px;
font-size:14px;
}

/* BUTTON */

button{
width:100%;
padding:12px;
background:#2563eb;
border:none;
color:white;
font-size:15px;
border-radius:6px;
cursor:pointer;
}

button:hover{
background:#1e40af;
}

/* QUICK ACTIONS */

.quick-actions{
margin-top:20px;
display:flex;
gap:10px;
}

.quick-actions a{
flex:1;
text-align:center;
padding:10px;
background:#0f172a;
color:white;
border-radius:6px;
text-decoration:none;
font-size:14px;
}

.quick-actions a:hover{
background:#1e293b;
}

</style>

</head>

<body>

<div class="container">

<!-- SIDEBAR -->

<div class="sidebar">

<h2 th:text="${user != null and user.role.name() == 'BUSINESS'} ? 'RevPay Business' : 'RevPay'"></h2>

<div class="menu">

<a th:href="${user != null and user.role.name() == 'BUSINESS'} ? '/business-dashboard' : '/dashboard'">
<i class="fa-solid fa-chart-line"></i>Dashboard
</a>

<a href="/profile"><i class="fa-solid fa-user"></i>Profile</a>
<a href="/send-money"><i class="fa-solid fa-paper-plane"></i>Send Money</a>
<a href="/add-money"><i class="fa-solid fa-wallet"></i>Add Money</a>
<a href="/request-money"><i class="fa-solid fa-hand-holding-dollar"></i>Request Money</a>
<a href="/transactions"><i class="fa-solid fa-money-bill-transfer"></i>Transactions</a>
<a href="/notifications"><i class="fa-solid fa-bell"></i>Notifications</a>
<a href="/logout"><i class="fa-solid fa-right-from-bracket"></i>Logout</a>

</div>

</div>

<!-- MAIN CONTENT -->

<div class="main">

<div class="header">

<a th:href="${user != null and user.role.name() == 'BUSINESS'} ? '/business-dashboard' : '/dashboard'"
class="btn btn-dashboard">
<i class="fa-solid fa-arrow-left"></i> Dashboard
</a>

<a href="/logout" class="btn btn-logout">
Logout
</a>

</div>

<div class="card">

<h2><i class="fa-solid fa-wallet"></i> Add Money to Wallet</h2>

<div class="wallet">
Wallet Balance:
₹ <span th:text="${wallet != null ? wallet : (user != null ? user.walletBalance : 0)}"></span>
</div>

<form th:action="@{/add-money}" method="post">

<input type="number"
step="0.01"
name="amount"
placeholder="Enter amount"
required>

<button type="submit">
<i class="fa-solid fa-plus"></i> Add Money
</button>

</form>

<div class="quick-actions">

<a href="/send-money">
<i class="fa-solid fa-paper-plane"></i> Send
</a>

<a href="/transactions">
<i class="fa-solid fa-clock-rotate-left"></i> History
</a>

</div>

</div>

</div>

</div>

</body>
</html>