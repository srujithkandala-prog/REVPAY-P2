<!DOCTYPE html>
<html xmlns:th="http://www.thymeleaf.org">

<head>
<meta charset="UTF-8">
<title>Transaction History</title>

<link rel="stylesheet"
href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">

<style>

body{
margin:0;
font-family:'Segoe UI',sans-serif;
background:#f1f5f9;
color:#334155;
}

.container{
display:flex;
height:100vh;
}

/* SIDEBAR */

.sidebar{
width:240px;
background:linear-gradient(180deg,#0f172a,#020617);
color:white;
display:flex;
flex-direction:column;
}

.sidebar h2{
text-align:center;
padding:20px;
border-bottom:1px solid #1e293b;
}

.sidebar a{
display:block;
color:#cbd5f5;
padding:12px 20px;
text-decoration:none;
border-left:3px solid transparent;
}

.sidebar a:hover{
background:#1e293b;
border-left:3px solid #38bdf8;
}

/* MAIN */

.main{
flex:1;
padding:40px;
}

/* HEADER */

.header{
display:flex;
justify-content:space-between;
align-items:center;
margin-bottom:25px;
}

.dashboard-btn{
background:#16a34a;
color:white;
padding:8px 15px;
border-radius:6px;
text-decoration:none;
}

/* CARD */

.card{
background:white;
padding:25px;
border-radius:12px;
box-shadow:0 10px 25px rgba(0,0,0,0.08);
}

/* FILTERS */

.filters{
display:flex;
flex-wrap:wrap;
gap:10px;
margin-bottom:20px;
}

.filters input,
.filters select{
padding:8px;
border:1px solid #ddd;
border-radius:6px;
}

.filters button{
background:#2563eb;
color:white;
border:none;
padding:8px 15px;
border-radius:6px;
cursor:pointer;
}

/* TABLE */

table{
width:100%;
border-collapse:collapse;
}

th{
background:#0f172a;
color:white;
padding:12px;
}

td{
padding:12px;
border-bottom:1px solid #e2e8f0;
}

tr:hover{
background:#f8fafc;
}

/* TYPE BADGES */

.badge{
padding:4px 10px;
border-radius:12px;
font-size:12px;
font-weight:bold;
}

.sent{
background:#fee2e2;
color:#991b1b;
}

.withdraw{
background:#dbeafe;
color:#1e40af;
}

.request{
background:#dcfce7;
color:#166534;
}

.unknown{
background:#e5e7eb;
color:#374151;
}

.export{
margin-top:15px;
background:#16a34a;
color:white;
border:none;
padding:8px 15px;
border-radius:6px;
cursor:pointer;
}

</style>

</head>

<body>

<div class="container">

<!-- SIDEBAR -->

<div class="sidebar">

<!-- Dynamic Title -->

<h2 th:text="${user.role.name() == 'BUSINESS'} ? 'RevPay Business' : 'RevPay'"></h2>

<!-- Dynamic Dashboard -->

<a th:href="${user.role.name() == 'BUSINESS'} ? '/business-dashboard' : '/dashboard'">
<i class="fa-solid fa-chart-line"></i> Dashboard
</a>

<a href="/profile"><i class="fa-solid fa-user"></i> Profile</a>
<a href="/send-money"><i class="fa-solid fa-paper-plane"></i> Send Money</a>
<a href="/add-money"><i class="fa-solid fa-wallet"></i> Add Money</a>
<a href="/withdraw-money"><i class="fa-solid fa-money-bill-wave"></i> Withdraw</a>
<a href="/transactions-history"><i class="fa-solid fa-clock-rotate-left"></i> Transactions</a>
<a href="/logout"><i class="fa-solid fa-right-from-bracket"></i> Logout</a>

</div>

<!-- MAIN -->

<div class="main">

<div class="header">

<h2>Transaction History 📊</h2>

<a th:href="${user.role.name() == 'BUSINESS'} ? '/business-dashboard' : '/dashboard'"
class="dashboard-btn">

<i class="fa-solid fa-arrow-left"></i> Dashboard

</a>

</div>

<div class="card">

<!-- FILTERS -->

<form action="/transactions-history" method="get" class="filters">

<input type="text" name="search" placeholder="Search email">

<select name="type">
<option value="">All Types</option>
<option value="SENT">SENT</option>
<option value="WITHDRAW">WITHDRAW</option>
<option value="REQUEST_PAYMENT">REQUEST_PAYMENT</option>
</select>

<input type="number" step="0.01" name="minAmount" placeholder="Min Amount">

<label>From:</label>
<input type="date" name="startDate">

<label>To:</label>
<input type="date" name="endDate">

<button type="submit">
<i class="fa-solid fa-filter"></i> Apply
</button>

</form>

<!-- TABLE -->

<table>

<tr>
<th>Sender</th>
<th>Receiver</th>
<th>Amount</th>
<th>Type</th>
<th>Date</th>
</tr>

<tr th:each="t : ${transactions}">

<td th:text="${t.senderEmail}"></td>
<td th:text="${t.receiverEmail}"></td>

<td>
₹ <span th:text="${t.amount}"></span>
</td>

<td>

<span th:if="${t.type=='SENT'}" class="badge sent">SENT</span>
<span th:if="${t.type=='WITHDRAW'}" class="badge withdraw">WITHDRAW</span>
<span th:if="${t.type=='REQUEST_PAYMENT'}" class="badge request">REQUEST</span>
<span th:if="${t.type==null}" class="badge unknown">UNKNOWN</span>

</td>

<td th:text="${#temporals.format(t.transactionDate,'dd-MM-yyyy HH:mm')}"></td>

</tr>

</table>

<button class="export">
<i class="fa-solid fa-file-export"></i> Export CSV
</button>

</div>

</div>

</div>

</body>
</html>