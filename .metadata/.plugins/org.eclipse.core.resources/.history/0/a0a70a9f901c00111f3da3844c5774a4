<!DOCTYPE html>
<html xmlns:th="http://www.thymeleaf.org">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>Loans - RevPay Admin</title>
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
<link href="https://cdn.jsdelivr.net/npm/bootstrap-icons/font/bootstrap-icons.css" rel="stylesheet">
<link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">
<style>
body{
font-family:Arial;
background:#f4f6f9;
margin:0;
}
/* SIDEBAR */
.sidebar {
    width: 280px; height: 100vh;
    background: #0f1419;
    color: white;
    position: fixed;
    left: 0; top: 0;
    padding: 28px 20px;
    overflow-y: auto;
    border-right: 1px solid rgba(255,255,255,0.05);
    display: flex;
    flex-direction: column;
    z-index: 1000;
}

.sidebar-header {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 36px;
    padding-bottom: 20px;
    border-bottom: 1px solid rgba(255,255,255,0.08);
}

.logo {
    width: 40px; height: 40px;
    background: linear-gradient(135deg, #6366f1 0%, #a78bfa 100%);
    border-radius: 10px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: white;
    font-size: 20px;
    font-weight: 800;
}

.brand-text h3 { margin: 0; font-size: 16px; font-weight: 700; }
.brand-text p { margin: 0; font-size: 11px; color: rgba(255,255,255,0.5); text-transform: uppercase; }

.nav-section { margin-bottom: 28px; }
.nav-label { 
    font-size: 11px; 
    font-weight: 700; 
    text-transform: uppercase;
    letter-spacing: 1.2px;
    color: rgba(255,255,255,0.35);
    margin-bottom: 14px;
    display: block;
}

.sidebar a {
    display: flex;
    align-items: center;
    gap: 14px;
    color: rgba(255,255,255,0.65);
    text-decoration: none;
    font-size: 14px;
    padding: 11px 14px;
    border-radius: 10px;
    margin-bottom: 6px;
    transition: 0.35s ease;
    font-weight: 500;
}

.icon-box {
    width: 36px; height: 36px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(255,255,255,0.06);
    border-radius: 8px;
    transition: 0.35s ease;
    flex-shrink: 0;
}

.sidebar a:hover { background: rgba(99,102,241,0.15); color: rgba(255,255,255,0.95); }
.sidebar a:hover .icon-box { background: rgba(99,102,241,0.25); transform: translateX(4px); }

.sidebar a.active { 
    background: rgba(99,102,241,0.2);
    color: white;
    border-left: 3px solid #6366f1;
    padding-left: 11px;
}
.sidebar a.active .icon-box { background: #6366f1; color: white; box-shadow: 0 4px 12px rgba(99,102,241,0.4); }

.sidebar-nav { flex: 1; }
.sidebar-footer { margin-top: auto; padding-top: 20px; border-top: 1px solid rgba(255,255,255,0.08); }

.user-card {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 12px 14px;
    background: rgba(255,255,255,0.04);
    border-radius: 10px;
    margin-bottom: 12px;
    transition: 0.3s ease;
}
.user-card:hover { background: rgba(255,255,255,0.08); }

.avatar {
    width: 36px; height: 36px;
    background: linear-gradient(135deg, #6366f1, #a78bfa);
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: white;
    font-weight: 700;
}

.user-name { font-size: 13px; font-weight: 600; color: white; }
.user-role { font-size: 11px; color: rgba(255,255,255,0.5); }

.logout-btn {
    display: flex;
    align-items: center;
    gap: 12px;
    width: 100%;
    padding: 11px 14px;
    border-radius: 10px;
    background: rgba(239,68,68,0.08);
    color: #fca5a5;
    text-decoration: none;
    font-size: 14px;
    transition: 0.3s ease;
    border: 1px solid rgba(239,68,68,0.2);
    font-weight: 500;
}
.logout-btn:hover { background: rgba(239,68,68,0.15); color: white; }

/* CONTENT */
.content{
margin-left:280px;
padding:30px;
}
/* TABLE */
.section{
background:white;
padding:25px;
border-radius:10px;
box-shadow:0 2px 6px rgba(0,0,0,0.1);
}
table{
width:100%;
border-collapse:collapse;
}
th{
background:#f1f5f9;
padding:12px;
text-align:left;
font-size:13px;
}
td{
padding:12px;
border-bottom:1px solid #eee;
}
/* STATUS BADGES */
.status-badge{
padding:6px 12px;
border-radius:20px;
font-size:12px;
font-weight:bold;
}
.status-pending{
background:#fef3c7;
color:#92400e;
}
.status-approved{
background:#dcfce7;
color:#166534;
}
.status-rejected{
background:#fee2e2;
color:#991b1b;
}
/* BUTTONS */
.btn-action{
padding:6px 12px;
border-radius:6px;
text-decoration:none;
font-size:12px;
font-weight:bold;
}
.btn-approve{
background:#16a34a;
color:white;
}
.btn-reject{
background:#dc2626;
color:white;
}
.btn-disabled{
opacity:0.5;
pointer-events:none;
}
/* EMPTY STATE */
.empty-state{
text-align:center;
padding:40px;
color:#6b7280;
}
</style>
</head>
<body>
<!-- SIDEBAR -->
<div class="sidebar">
    <div class="sidebar-header">
        <div class="logo"><i class="bi bi-lightning-charge-fill"></i></div>
        <div class="brand-text">
            <h3>RevPay</h3>
            <p>Admin Panel</p>
        </div>
    </div>

    <nav class="sidebar-nav">
        <div class="nav-section">
            <span class="nav-label">Overview</span>
            <a href="/admin-dashboard">
                <div class="icon-box"><i class="bi bi-speedometer2"></i></div>
                Dashboard
            </a>
            <a href="/admin/users">
                <div class="icon-box"><i class="bi bi-people-fill"></i></div>
                Users
            </a>
        </div>

        <div class="nav-section">
            <span class="nav-label">Finance</span>
            <a href="/admin/transactions">
                <div class="icon-box"><i class="bi bi-arrow-left-right"></i></div>
                Transactions
            </a>
            <a href="/admin/loans" class="active">
                <div class="icon-box"><i class="bi bi-bank2"></i></div>
                Loans
            </a>
            <a href="/admin/revenue">
                <div class="icon-box"><i class="bi bi-graph-up"></i></div>
                Revenue
            </a>
        </div>

        <div class="nav-section">
            <span class="nav-label">Monitoring</span>
            <a href="/admin/system-health">
                <div class="icon-box"><i class="bi bi-cpu"></i></div>
                System Health
            </a>
            <a href="/admin/live-transactions">
                <div class="icon-box"><i class="bi bi-broadcast"></i></div>
                Live Monitor
            </a>
            <a href="/admin/fraud-alerts">
                <div class="icon-box"><i class="bi bi-shield-exclamation"></i></div>
                Fraud Alerts
            </a>
            <a href="/admin/reports">
                <div class="icon-box"><i class="bi bi-file-earmark-text"></i></div>
                Reports
            </a>
        </div>
    </nav>

    <div class="sidebar-footer">
        <div class="user-card">
            <div class="avatar">A</div>
            <div>
                <div class="user-name">Admin User</div>
                <div class="user-role">Manager</div>
            </div>
        </div>
        <a href="/logout" class="logout-btn">
            <i class="bi bi-box-arrow-right"></i>
            Logout
        </a>
    </div>
</div>

<!-- CONTENT -->
<div class="content">
<h2>Loan Applications</h2>
<div class="section">
<table th:if="${not #lists.isEmpty(loans)}">
<thead>
<tr>
<th>ID</th>
<th>Business Email</th>
<th>Amount</th>
<th>Interest</th>
<th>Tenure</th>
<th>Status</th>
<th>Action</th>
</tr>
</thead>
<tbody>
<tr th:each="loan : ${loans}">
<td th:text="${loan.id}"></td>
<td th:text="${loan.businessEmail}"></td>
<td th:text="${loan.amount}"></td>
<td th:text="${loan.interestRate}"></td>
<td th:text="${loan.tenureMonths}"></td>
<td>
<span class="status-badge"
th:classappend="${loan.status == 'PENDING'} ? ' status-pending' : (${loan.status == 'APPROVED'} ? ' status-approved' : ' status-rejected')"
th:text="${loan.status}">
</span>
</td>
<td>
<a class="btn-action btn-approve"
th:href="@{/admin/approve-loan/{id}(id=${loan.id})}"
th:classappend="${loan.status != 'PENDING'} ? ' btn-disabled' : ''">
Approve
</a>
<a class="btn-action btn-reject"
th:href="@{/admin/reject-loan/{id}(id=${loan.id})}"
th:classappend="${loan.status != 'PENDING'} ? ' btn-disabled' : ''">
Reject
</a>
</td>
</tr>
</tbody>
</table>
<div class="empty-state" th:if="${#lists.isEmpty(loans)}">
<i class="bi bi-inbox"></i>
<p>No loan applications found</p>
</div>
</div>
</div>
</body>
</html>