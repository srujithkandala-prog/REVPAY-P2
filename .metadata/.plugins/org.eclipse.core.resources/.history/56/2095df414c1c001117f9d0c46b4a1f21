<!DOCTYPE html>
<html xmlns:th="http://www.thymeleaf.org">

<head>
    <title>RevPay - Payment Admin</title>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons/font/bootstrap-icons.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        :root {
            --primary: #6366f1;
            --primary-dark: #4f46e5;
            --primary-light: #e0e7ff;
            --success: #10b981;
            --warning: #f59e0b;
            --danger: #ef4444;
            --info: #0ea5e9;
            --white: #ffffff;
            --gray-50: #f9fafb;
            --gray-100: #f3f4f6;
            --gray-200: #e5e7eb;
            --gray-300: #d1d5db;
            --gray-400: #9ca3af;
            --gray-500: #6b7280;
            --gray-600: #4b5563;
            --gray-700: #374151;
            --gray-800: #1f2937;
            --gray-900: #111827;
            --sidebar-bg: #0f1419;
            --sidebar-hover: #1a1f2e;
        }

        body {
            font-family: 'Plus Jakarta Sans', sans-serif;
            background: linear-gradient(135deg, #f8f9fa 0%, #f0f1f5 100%);
            color: var(--gray-800);
            line-height: 1.6;
        }

        /* ===== SIDEBAR ===== */
        .sidebar {
            width: 280px;
            height: 100vh;
            background: var(--sidebar-bg);
            color: white;
            position: fixed;
            left: 0;
            top: 0;
            padding: 28px 20px;
            overflow-y: auto;
            z-index: 1000;
            border-right: 1px solid rgba(255, 255, 255, 0.05);
            display: flex;
            flex-direction: column;
        }

        .sidebar::-webkit-scrollbar {
            width: 6px;
        }

        .sidebar::-webkit-scrollbar-track {
            background: transparent;
        }

        .sidebar::-webkit-scrollbar-thumb {
            background: rgba(255, 255, 255, 0.1);
            border-radius: 3px;
        }

        .sidebar::-webkit-scrollbar-thumb:hover {
            background: rgba(255, 255, 255, 0.2);
        }

        .sidebar-header {
            display: flex;
            align-items: center;
            gap: 12px;
            margin-bottom: 36px;
            padding-bottom: 20px;
            border-bottom: 1px solid rgba(255, 255, 255, 0.08);
        }

        .sidebar-logo {
            width: 40px;
            height: 40px;
            background: linear-gradient(135deg, var(--primary) 0%, #a78bfa 100%);
            border-radius: 10px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 20px;
            color: white;
            font-weight: 800;
        }

        .sidebar-brand-text {
            display: flex;
            flex-direction: column;
            gap: 2px;
        }

        .sidebar-brand-text h3 {
            margin: 0;
            font-size: 16px;
            font-weight: 700;
            letter-spacing: -0.5px;
        }

        .sidebar-brand-text p {
            margin: 0;
            font-size: 11px;
            color: rgba(255, 255, 255, 0.5);
            font-weight: 500;
            letter-spacing: 0.5px;
            text-transform: uppercase;
        }

        .sidebar-nav {
            flex: 1;
        }

        .nav-section {
            margin-bottom: 28px;
        }

        .nav-section-label {
            font-size: 11px;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 1.2px;
            color: rgba(255, 255, 255, 0.35);
            margin-bottom: 14px;
            display: block;
            padding: 0 8px;
        }

        .sidebar a {
            display: flex;
            align-items: center;
            gap: 14px;
            color: rgba(255, 255, 255, 0.65);
            text-decoration: none;
            font-size: 14px;
            padding: 11px 14px;
            border-radius: 10px;
            margin-bottom: 6px;
            transition: all 0.35s cubic-bezier(0.4, 0.0, 0.2, 1);
            position: relative;
            font-weight: 500;
        }

        .nav-icon {
            width: 36px;
            height: 36px;
            display: flex;
            align-items: center;
            justify-content: center;
            background: rgba(255, 255, 255, 0.06);
            border-radius: 8px;
            transition: all 0.35s cubic-bezier(0.4, 0.0, 0.2, 1);
            font-size: 16px;
            flex-shrink: 0;
        }

        .sidebar a:hover {
            background: rgba(99, 102, 241, 0.15);
            color: rgba(255, 255, 255, 0.95);
        }

        .sidebar a:hover .nav-icon {
            background: rgba(99, 102, 241, 0.25);
            transform: translateX(4px);
        }

        .sidebar a.active {
            background: rgba(99, 102, 241, 0.2);
            color: white;
            border-left: 3px solid var(--primary);
            padding-left: 11px;
        }

        .sidebar a.active .nav-icon {
            background: var(--primary);
            color: white;
            box-shadow: 0 4px 12px rgba(99, 102, 241, 0.4);
        }

        .sidebar-footer {
            margin-top: auto;
            padding-top: 20px;
            border-top: 1px solid rgba(255, 255, 255, 0.08);
        }

        .user-profile {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 12px 14px;
            background: rgba(255, 255, 255, 0.04);
            border-radius: 10px;
            margin-bottom: 12px;
            cursor: pointer;
            transition: all 0.3s ease;
        }

        .user-profile:hover {
            background: rgba(255, 255, 255, 0.08);
        }

        .user-avatar {
            width: 36px;
            height: 36px;
            background: linear-gradient(135deg, var(--primary), #a78bfa);
            border-radius: 8px;
            display: flex;
            align-items: center;
            justify-content: center;
            color: white;
            font-weight: 700;
            font-size: 14px;
        }

        .user-info {
            flex: 1;
            min-width: 0;
        }

        .user-name {
            font-size: 13px;
            font-weight: 600;
            color: white;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }

        .user-role {
            font-size: 11px;
            color: rgba(255, 255, 255, 0.5);
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }

        .logout-btn {
            display: flex;
            align-items: center;
            gap: 12px;
            width: 100%;
            padding: 11px 14px;
            border-radius: 10px;
            background: rgba(239, 68, 68, 0.08);
            color: #fca5a5;
            text-decoration: none;
            font-size: 14px;
            transition: all 0.3s ease;
            border: 1px solid rgba(239, 68, 68, 0.2);
            font-weight: 500;
            cursor: pointer;
        }

        .logout-btn:hover {
            background: rgba(239, 68, 68, 0.15);
            color: white;
            border-color: rgba(239, 68, 68, 0.4);
            transform: translateX(-4px);
        }

        .logout-icon {
            width: 36px;
            height: 36px;
            display: flex;
            align-items: center;
            justify-content: center;
            background: rgba(239, 68, 68, 0.15);
            border-radius: 8px;
            font-size: 16px;
            flex-shrink: 0;
        }

        /* ===== MAIN CONTENT ===== */
        .content {
            margin-left: 280px;
            padding: 36px 40px;
            min-height: 100vh;
        }

        .header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 40px;
            flex-wrap: wrap;
            gap: 20px;
        }

        .header-left h1 {
            font-size: 32px;
            font-weight: 800;
            color: var(--gray-900);
            letter-spacing: -1px;
            margin: 0;
        }

        .header-right {
            display: flex;
            align-items: center;
            gap: 16px;
        }

        .status-badge {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            padding: 8px 16px;
            background: rgba(16, 185, 129, 0.1);
            color: var(--success);
            border-radius: 20px;
            font-size: 13px;
            font-weight: 600;
            border: 1px solid rgba(16, 185, 129, 0.2);
        }

        .status-dot {
            width: 8px;
            height: 8px;
            background: var(--success);
            border-radius: 50%;
            animation: pulse-dot 2s infinite;
        }

        @keyframes pulse-dot {
            0%, 100% { opacity: 1; }
            50% { opacity: 0.5; }
        }

        /* ===== METRIC CARDS ===== */
        .metrics-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
            gap: 20px;
            margin-bottom: 36px;
        }

        .metric-card {
            background: white;
            border-radius: 14px;
            padding: 24px;
            box-shadow: 0 2px 8px rgba(0, 0, 0, 0.06);
            transition: all 0.4s cubic-bezier(0.4, 0.0, 0.2, 1);
            border: 1px solid rgba(0, 0, 0, 0.04);
            position: relative;
            overflow: hidden;
        }

        .metric-card::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 3px;
            background: linear-gradient(90deg, var(--primary), #a78bfa);
            opacity: 0;
            transition: opacity 0.4s ease;
        }

        .metric-card:hover {
            box-shadow: 0 12px 24px rgba(0, 0, 0, 0.1);
            transform: translateY(-6px);
        }

        .metric-card:hover::before {
            opacity: 1;
        }

        .metric-header {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            margin-bottom: 16px;
        }

        .metric-label {
            font-size: 12px;
            font-weight: 600;
            color: var(--gray-500);
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        .metric-icon-small {
            width: 32px;
            height: 32px;
            display: flex;
            align-items: center;
            justify-content: center;
            background: rgba(99, 102, 241, 0.1);
            border-radius: 8px;
            font-size: 16px;
            color: var(--primary);
        }

        .metric-value {
            font-size: 28px;
            font-weight: 800;
            color: var(--gray-900);
            margin-bottom: 8px;
            font-family: 'Plus Jakarta Sans', sans-serif;
            letter-spacing: -0.5px;
        }

        .metric-subtitle {
            font-size: 12px;
            color: var(--gray-400);
            font-weight: 500;
        }

        .metric-card-1 .metric-icon-small { background: rgba(99, 102, 241, 0.1); color: var(--primary); }
        .metric-card-2 .metric-icon-small { background: rgba(16, 185, 129, 0.1); color: var(--success); }
        .metric-card-3 .metric-icon-small { background: rgba(245, 158, 11, 0.1); color: var(--warning); }
        .metric-card-4 .metric-icon-small { background: rgba(239, 68, 68, 0.1); color: var(--danger); }

        /* ===== CHART SECTION ===== */
        .chart-section {
            background: white;
            border-radius: 14px;
            padding: 28px;
            box-shadow: 0 2px 8px rgba(0, 0, 0, 0.06);
            margin-bottom: 36px;
            border: 1px solid rgba(0, 0, 0, 0.04);
        }

        .section-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 28px;
            padding-bottom: 16px;
            border-bottom: 1px solid var(--gray-100);
        }

        .section-title {
            font-size: 18px;
            font-weight: 700;
            color: var(--gray-900);
            margin: 0;
        }

        .section-subtitle {
            font-size: 12px;
            color: var(--gray-500);
            margin-top: 4px;
        }

        .chart-legend {
            display: flex;
            align-items: center;
            gap: 10px;
            font-size: 12px;
            color: var(--gray-600);
            font-weight: 600;
        }

        .chart-legend-dot {
            width: 10px;
            height: 10px;
            background: var(--primary);
            border-radius: 2px;
        }

        #revenueChart {
            max-height: 320px;
        }

        /* ===== TRANSACTIONS TABLE ===== */
        .table-section {
            background: white;
            border-radius: 14px;
            padding: 28px;
            box-shadow: 0 2px 8px rgba(0, 0, 0, 0.06);
            border: 1px solid rgba(0, 0, 0, 0.04);
        }

        .view-all-link {
            font-size: 12px;
            color: var(--primary);
            text-decoration: none;
            font-weight: 700;
            transition: all 0.3s ease;
            display: flex;
            align-items: center;
            gap: 6px;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        .view-all-link:hover {
            color: var(--primary-dark);
            gap: 10px;
        }

        .table-container {
            overflow-x: auto;
        }

        .table {
            width: 100%;
            border-collapse: collapse;
        }

        .table thead {
            background: var(--gray-50);
        }

        .table th {
            padding: 14px 16px;
            text-align: left;
            font-size: 11px;
            font-weight: 700;
            color: var(--gray-600);
            text-transform: uppercase;
            letter-spacing: 0.5px;
            border: none;
        }

        .table td {
            padding: 14px 16px;
            font-size: 14px;
            color: var(--gray-700);
            border-bottom: 1px solid var(--gray-100);
            font-weight: 500;
        }

        .table tbody tr:hover {
            background: rgba(99, 102, 241, 0.03);
        }

        .table tbody tr:last-child td {
            border-bottom: none;
        }

        .email-text {
            display: flex;
            align-items: center;
            gap: 8px;
            color: var(--gray-700);
            font-weight: 500;
        }

        .email-indicator {
            width: 6px;
            height: 6px;
            background: var(--primary);
            border-radius: 50%;
            flex-shrink: 0;
        }

        .amount-value {
            font-family: 'Plus Jakarta Sans', sans-serif;
            font-weight: 700;
            color: var(--gray-900);
            font-size: 15px;
        }

        /* ===== SCROLLBAR ===== */
        ::-webkit-scrollbar {
            width: 8px;
            height: 8px;
        }

        ::-webkit-scrollbar-track {
            background: transparent;
        }

        ::-webkit-scrollbar-thumb {
            background: rgba(0, 0, 0, 0.1);
            border-radius: 4px;
        }

        ::-webkit-scrollbar-thumb:hover {
            background: rgba(0, 0, 0, 0.2);
        }

        /* ===== RESPONSIVE ===== */
        @media (max-width: 1024px) {
            .metrics-grid {
                grid-template-columns: repeat(2, 1fr);
            }
        }

        @media (max-width: 768px) {
            .sidebar {
                width: 260px;
                padding: 20px;
            }

            .content {
                margin-left: 260px;
                padding: 24px;
            }

            .header {
                flex-direction: column;
                align-items: flex-start;
            }

            .header-left h1 {
                font-size: 28px;
            }

            .metrics-grid {
                grid-template-columns: 1fr;
            }

            .section-header {
                flex-direction: column;
                align-items: flex-start;
                gap: 12px;
            }
        }

        @media (max-width: 640px) {
            .sidebar {
                width: 100%;
                height: auto;
                position: static;
                border-right: none;
                border-bottom: 1px solid rgba(255, 255, 255, 0.08);
                padding: 16px;
                flex-direction: row;
                flex-wrap: wrap;
                align-content: flex-start;
            }

            .sidebar-nav {
                width: 100%;
            }

            .sidebar-footer {
                width: 100%;
                margin-top: 16px;
                padding-top: 16px;
            }

            .content {
                margin-left: 0;
                padding: 16px;
            }

            .header-left h1 {
                font-size: 24px;
            }

            .table th,
            .table td {
                padding: 12px 8px;
                font-size: 12px;
            }
        }

    </style>
</head>

<body>

    <!-- SIDEBAR -->
    <div class="sidebar">
        <div class="sidebar-header">
            <div class="sidebar-logo">
                <i class="bi bi-lightning-charge-fill"></i>
            </div>
            <div class="sidebar-brand-text">
                <h3>RevPay</h3>
                <p>Admin Panel</p>
            </div>
        </div>

        <nav class="sidebar-nav">
            <div class="nav-section">
                <span class="nav-section-label">Overview</span>
                <a href="/admin-dashboard" class="active">
                    <div class="nav-icon"><i class="bi bi-speedometer2"></i></div>
                    Dashboard
                </a>
                <a href="/admin/users">
                    <div class="nav-icon"><i class="bi bi-people-fill"></i></div>
                    Users
                </a>
                <a href="/admin/logs">Admin Logs</a>
            </div>

            <div class="nav-section">
                <span class="nav-section-label">Finance</span>
                <a href="/admin/transactions">
                    <div class="nav-icon"><i class="bi bi-arrow-left-right"></i></div>
                    Transactions
                </a>
                <a href="/admin/loans">
                    <div class="nav-icon"><i class="bi bi-bank2"></i></div>
                    Loans
                </a>
                <a href="/admin/revenue">
                    <div class="nav-icon"><i class="bi bi-graph-up"></i></div>
                    Revenue
                </a>
            </div>

            <div class="nav-section">
                <span class="nav-section-label">Monitoring</span>
                <a href="/admin/system-health">
                    <div class="nav-icon"><i class="bi bi-cpu"></i></div>
                    System Health
                </a>
                <a href="/admin/live-transactions">
                    <div class="nav-icon"><i class="bi bi-broadcast"></i></div>
                    Live Monitor
                </a>
                <a href="/admin/emi-history">
						<div class="nav-icon"><i class="bi bi-cash-coin"></i></div>
						EMI History
						</a>
                <a href="/admin/fraud-alerts">
                    <div class="nav-icon"><i class="bi bi-shield-exclamation"></i></div>
                    Fraud Alerts
                </a>
                <a href="/admin/reports">
                    <div class="nav-icon"><i class="bi bi-file-earmark-text"></i></div>
                    Reports
                </a>
            </div>
        </nav>

        <div class="sidebar-footer">
            <div class="user-profile">
                <div class="user-avatar">A</div>
                <div class="user-info">
                    <div class="user-name">Admin User</div>
                    <div class="user-role">Manager</div>
                </div>
            </div>
            <a href="/logout" class="logout-btn">
                <div class="logout-icon"><i class="bi bi-box-arrow-right"></i></div>
                <span>Logout</span>
            </a>
        </div>
    </div>

    <!-- MAIN CONTENT -->
    <div class="content">

        <div class="header">
            <div class="header-left">
                <h1>Dashboard</h1>
            </div>
            <div class="header-right">
                <span class="status-badge">
                    <span class="status-dot"></span>
                    Live
                </span>
            </div>
        </div>

        <!-- METRIC CARDS -->
        <div class="metrics-grid">
            <div class="metric-card metric-card-1">
                <div class="metric-header">
                    <div class="metric-label">Total Users</div>
                    <div class="metric-icon-small"><i class="bi bi-people-fill"></i></div>
                </div>
                <div class="metric-value" th:text="${totalUsers}">0</div>
                <div class="metric-subtitle">Active accounts</div>
            </div>

            <div class="metric-card metric-card-2">
                <div class="metric-header">
                    <div class="metric-label">Transactions</div>
                    <div class="metric-icon-small"><i class="bi bi-arrow-left-right"></i></div>
                </div>
                <div class="metric-value" th:text="${totalTransactions}">0</div>
                <div class="metric-subtitle">All time</div>
            </div>

            <div class="metric-card metric-card-3">
                <div class="metric-header">
                    <div class="metric-label">Loans</div>
                    <div class="metric-icon-small"><i class="bi bi-bank2"></i></div>
                </div>
                <div class="metric-value" th:text="${totalLoans}">0</div>
                <div class="metric-subtitle">Total issued</div>
            </div>

            <div class="metric-card metric-card-4">
                <div class="metric-header">
                    <div class="metric-label">Pending Loans</div>
                    <div class="metric-icon-small"><i class="bi bi-hourglass-split"></i></div>
                </div>
                <div class="metric-value" th:text="${pendingLoans}">0</div>
                <div class="metric-subtitle">Awaiting review</div>
            </div>
        </div>

        <!-- REVENUE CHART -->
        <div class="chart-section">
            <div class="section-header">
                <div>
                    <h3 class="section-title">Revenue Analytics</h3>
                    <p class="section-subtitle">Monthly revenue overview — current year</p>
                </div>
                <div class="chart-legend">
                    <div class="chart-legend-dot"></div>
                    <span>Revenue</span>
                </div>
            </div>
            <canvas id="revenueChart"></canvas>
        </div>

        <!-- TRANSACTIONS TABLE -->
        <div class="table-section">
            <div class="section-header">
                <div>
                    <h3 class="section-title">Recent Transactions</h3>
                    <p class="section-subtitle">Latest payment activity across the platform</p>
                </div>
                <a href="#" class="view-all-link">
                    View all
                    <i class="bi bi-arrow-right"></i>
                </a>
            </div>

            <div class="table-container">
                <table class="table">
                    <thead>
                        <tr>
                            <th>Sender</th>
                            <th>Receiver</th>
                            <th>Amount</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr th:each="t : ${transactions}">
                            <td>
                                <span class="email-text">
                                    <span class="email-indicator"></span>
                                    <span th:text="${t.senderEmail}"></span>
                                </span>
                            </td>
                            <td>
                                <span class="email-text">
                                    <span class="email-indicator"></span>
                                    <span th:text="${t.receiverEmail}"></span>
                                </span>
                            </td>
                            <td>
                                <span class="amount-value" th:text="${t.amount}"></span>
                            </td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>

    </div>

    <!-- CHART SCRIPT -->
    <script>
        const ctx = document.getElementById('revenueChart');
        
        if (ctx) {
            new Chart(ctx, {
                type: 'line',
                data: {
                    labels: ['Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun'],
                    datasets: [{
                        label: 'Revenue',
                        data: [1000, 2000, 1500, 3000, 4500, 6000],
                        borderColor: '#6366f1',
                        backgroundColor: 'rgba(99, 102, 241, 0.08)',
                        fill: true,
                        tension: 0.4,
                        pointRadius: 5,
                        pointBackgroundColor: '#6366f1',
                        pointBorderColor: 'white',
                        pointBorderWidth: 2,
                        pointHoverRadius: 7
                    }]
                },
                options: {
                    responsive: true,
