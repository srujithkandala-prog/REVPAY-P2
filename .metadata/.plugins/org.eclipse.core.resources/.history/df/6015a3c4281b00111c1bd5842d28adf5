<!DOCTYPE html>
<html xmlns:th="http://www.thymeleaf.org">

<head>
<meta charset="UTF-8">
<title>Request Money</title>

<link rel="stylesheet"
href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">

<style>

body{
margin:0;
font-family:'Segoe UI',sans-serif;
background:#f1f5f9;
color:#334155;
}

/* ===== LAYOUT ===== */

.container{
display:flex;
height:100vh;
}

/* ===== SIDEBAR ===== */

.sidebar{
width:240px;
background:linear-gradient(180deg,#0f172a,#020617);
color:white;
display:flex;
flex-direction:column;
}

.sidebar h2{
text-align:center;
padding:20px;
margin:0;
border-bottom:1px solid #1e293b;
}

.menu{
flex:1;
}

.sidebar a{
display:block;
color:#cbd5f5;
padding:12px 20px;
text-decoration:none;
border-left:3px solid transparent;
transition:0.25s;
}

.sidebar a i{
margin-right:10px;
}

.sidebar a:hover{
background:#1e293b;
border-left:3px solid #38bdf8;
padding-left:25px;
color:white;
}

/* ===== MAIN ===== */

.main{
flex:1;
padding:40px;
overflow:auto;
}

/* HEADER */

.header{
display:flex;
justify-content:space-between;
align-items:center;
margin-bottom:25px;
}

.header h2{
margin:0;
}

/* BUTTONS */

.btn{
padding:10px 18px;
border-radius:6px;
text-decoration:none;
font-size:14px;
}

.btn-dashboard{
background:#16a34a;
color:white;
}

.btn-dashboard:hover{
background:#15803d;
}

.btn-logout{
background:#ef4444;
color:white;
}

.btn-logout:hover{
background:#dc2626;
}

/* CARD */

.card{
background:white;
padding:30px;
border-radius:12px;
box-shadow:0 8px 20px rgba(0,0,0,0.05);
max-width:500px;
}

/* WALLET */

.wallet{
background:#2563eb;
color:white;
padding:15px;
border-radius:8px;
margin-bottom:20px;
font-weight:bold;
}

/* INPUTS */

input{
width:100%;
padding:12px;
margin-top:10px;
margin-bottom:15px;
border:1px solid #cbd5e1;
border-radius:6px;
font-size:14px;
}

/* BUTTON */

button{
width:100%;
padding:12px;
background:#2563eb;
border:none;
color:white;
font-size:15px;
border-radius:6px;
cursor:pointer;
}

button:hover{
background:#1e40af;
}

/* QUICK ACTIONS */

.quick-actions{
margin-top:20px;
display:flex;
gap:10px;
}

.quick-actions a{
flex:1;
text-align:center;
padding:10px;
background:#0f172a;
color:white;
border-radius:6px;
text-decoration:none;
}

.quick-actions a:hover{
background:#1e293b;
}

</style>

</head>

<body>

<div class="container">

<!-- ===== SIDEBAR ===== -->

<div class="sidebar">

<h2>RevPay Business</h2>

<div class="menu">

<a href="/business-dashboard"><i class="fa-solid fa-chart-line"></i>Dashboard</a>
<a href="/profile"><i class="fa-solid fa-user"></i>Profile</a>
<a href="/send-money"><i class="fa-solid fa-paper-plane"></i>Send Money</a>
<a href="/request-money"><i class="fa-solid fa-hand-holding-dollar"></i>Request Money</a>
<a href="/transactions"><i class="fa-solid fa-money-bill-transfer"></i>Transactions</a>
<a href="/notifications"><i class="fa-solid fa-bell"></i>Notifications</a>
<a href="/logout"><i class="fa-solid fa-right-from-bracket"></i>Logout</a>

</div>

</div>

<!-- ===== MAIN ===== -->

<div class="main">

<div class="header">

<h2>Request Money 💰</h2>

<div>

<a href="/business-dashboard" class="btn btn-dashboard">
<i class="fa-solid fa-arrow-left"></i> Dashboard
</a>

<a href="/logout" class="btn btn-logout">
Logout
</a>

</div>

</div>

<div class="card">

<!-- WALLET -->

<div class="wallet">
Wallet Balance: ₹ <span th:text="${wallet}"></span>
</div>

<form th:action="@{/request-money}" method="post"
th:object="${request}">

<label>Receiver Email</label>
<input type="email"
th:field="*{receiverEmail}"
placeholder="Enter receiver email"
required>

<label>Amount</label>
<input type="number"
step="0.01"
th:field="*{amount}"
placeholder="Enter amount"
required>

<label>Purpose</label>
<input type="text"
th:field="*{purpose}"
placeholder="Purpose of request"
required>

<button type="submit">
<i class="fa-solid fa-hand-holding-dollar"></i>
Send Request
</button>

</form>

<!-- QUICK ACTIONS -->

<div class="quick-actions">

<a href="/send-money">
<i class="fa-solid fa-paper-plane"></i>
Send Money
</a>

<a href="/transactions">
<i class="fa-solid fa-clock-rotate-left"></i>
Transactions
</a>

</div>

</div>

</div>

</div>

</body>
</html>