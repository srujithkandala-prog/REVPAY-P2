<!DOCTYPE html>
<html xmlns:th="http://www.thymeleaf.org">

<head>
<title>Transaction Report</title>

<style>
body{font-family:Arial;background:#f4f6f9;padding:30px;}

table{
width:100%;
border-collapse:collapse;
background:white;
}

th,td{
padding:10px;
border:1px solid #ddd;
}

th{
background:#0f172a;
color:white;
}
</style>

</head>

<body>

<h1>Transactions Report</h1>

<table>

<tr>
<th>Sender</th>
<th>Receiver</th>
<th>Amount</th>
<th>Date</th>
</tr>

<tr th:each="t : ${transactions}">

<td th:text="${t.senderEmail}"></td>
<td th:text="${t.receiverEmail}"></td>
<td th:text="${t.amount}"></td>
<td th:text="${#temporals.format(t.transactionDate,'dd-MM-yyyy HH:mm')}"></td>

</tr>

</table>

</body>

</html>