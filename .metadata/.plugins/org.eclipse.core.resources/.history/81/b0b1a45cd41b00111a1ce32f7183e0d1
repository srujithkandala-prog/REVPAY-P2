<!DOCTYPE html>
<html xmlns:th="http://www.thymeleaf.org">

<head>

<title>Revenue Report</title>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<style>

body{
font-family:Arial;
background:#f4f6f9;
padding:30px;
}

.top{
display:flex;
justify-content:space-between;
}

button{
background:#2563eb;
color:white;
border:none;
padding:8px 14px;
border-radius:6px;
cursor:pointer;
}

.card{
background:white;
padding:20px;
border-radius:10px;
margin-bottom:20px;
}

</style>

</head>

<body>

<div class="top">

<h1>Revenue Report</h1>

<a href="/admin-dashboard">
<button>← Back to Dashboard</button>
</a>

</div>

<div class="card">

<h2>Total Revenue</h2>

<h1>₹ <span th:text="${revenue}"></span></h1>

</div>

<div class="card">

<canvas id="revChart"></canvas>

</div>

<script>

const ctx = document.getElementById('revChart');

new Chart(ctx,{
type:'pie',

data:{
labels:['Revenue'],
datasets:[{
data:[[${revenue}]],
backgroundColor:['orange']
}]
}

});

</script>

</body>

</html>