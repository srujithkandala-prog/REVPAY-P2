<!DOCTYPE html>
<html xmlns:th="http://www.thymeleaf.org">

<head>
<meta charset="UTF-8">
<title>Create Invoice</title>

<link rel="stylesheet"
href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">

<style>

*{
box-sizing:border-box;
}

body{
margin:0;
font-family:'Segoe UI',sans-serif;
background:#f1f5f9;
color:#334155;
overflow-x:hidden;
}

/* LAYOUT */

.wrapper{
display:flex;
min-height:100vh;
width:100%;
}

/* SIDEBAR */

.sidebar{
width:240px;
background:linear-gradient(180deg,#0f172a,#020617);
color:white;
display:flex;
flex-direction:column;
position:fixed;
top:0;
left:0;
bottom:0;
}

.sidebar h2{
text-align:center;
padding:20px;
margin:0;
border-bottom:1px solid #1e293b;
}

.sidebar a{
display:block;
padding:12px 20px;
color:#cbd5f5;
text-decoration:none;
border-left:3px solid transparent;
transition:0.2s;
}

.sidebar a:hover{
background:#1e293b;
border-left:3px solid #38bdf8;
color:white;
}

/* MAIN */

.main{
margin-left:240px;
flex:1;
padding:40px;
display:flex;
flex-direction:column;
align-items:center;
width:100%;
}

/* HEADER */

.header{
width:100%;
max-width:600px;
display:flex;
justify-content:space-between;
align-items:center;
margin-bottom:20px;
}

/* DASHBOARD BUTTON */

.dashboard-btn{
background:#16a34a;
color:white;
padding:8px 15px;
border-radius:6px;
text-decoration:none;
}

.dashboard-btn:hover{
background:#15803d;
}

/* CARD */

.card{
background:white;
padding:30px;
border-radius:12px;
box-shadow:0 10px 25px rgba(0,0,0,0.08);
width:100%;
max-width:600px;
}

/* FORM GRID */

.form-grid{
display:grid;
grid-template-columns:1fr 1fr;
gap:15px;
}

/* INPUT */

input, textarea{
width:100%;
padding:10px;
border:1px solid #ddd;
border-radius:6px;
margin-top:5px;
}

/* FULL WIDTH */

.full{
grid-column:span 2;
}

/* BUTTON */

button{
width:100%;
padding:12px;
margin-top:15px;
background:#2563eb;
color:white;
border:none;
border-radius:6px;
font-size:15px;
cursor:pointer;
}

button:hover{
background:#1e40af;
}

/* TOTAL BOX */

.total-box{
margin-top:15px;
background:#f8fafc;
padding:10px;
border-radius:6px;
font-weight:bold;
}

/* MOBILE RESPONSIVE */

@media (max-width:900px){

.sidebar{
position:relative;
width:200px;
}

.main{
margin-left:200px;
padding:20px;
}

}

@media (max-width:700px){

.wrapper{
flex-direction:column;
}

.sidebar{
width:100%;
position:relative;
flex-direction:row;
overflow-x:auto;
}

.sidebar a{
flex:1;
text-align:center;
border-left:none;
}

.main{
margin-left:0;
padding:20px;
}

.form-grid{
grid-template-columns:1fr;
}

.full{
grid-column:span 1;
}

}

</style>

</head>

<body>

<div class="wrapper">

<!-- SIDEBAR -->

<div class="sidebar">

<h2>RevPay Business</h2>

<a href="/business-dashboard"><i class="fa-solid fa-chart-line"></i> Dashboard</a>
<a href="/send-money"><i class="fa-solid fa-paper-plane"></i> Send Money</a>
<a href="/request-money"><i class="fa-solid fa-hand-holding-dollar"></i> Request Money</a>
<a href="/transactions-history"><i class="fa-solid fa-clock"></i> Transactions</a>
<a href="/create-invoice"><i class="fa-solid fa-file-invoice"></i> Create Invoice</a>
<a href="/invoices"><i class="fa-solid fa-receipt"></i> Invoices</a>
<a href="/logout"><i class="fa-solid fa-right-from-bracket"></i> Logout</a>

</div>

<!-- MAIN -->

<div class="main">

<div class="header">

<h2>Create Invoice 🧾</h2>

<a href="/business-dashboard" class="dashboard-btn">
← Dashboard
</a>

</div>

<div class="card">

<form action="/create-invoice" method="post">

<div class="form-grid">

<div class="full">
<label>Customer Name</label>
<input type="text" name="customerName" required>
</div>

<div class="full">
<label>Customer Email</label>
<input type="email" name="customerEmail" required>
</div>

<div class="full">
<label>Description</label>
<textarea name="description"></textarea>
</div>

<div class="full">
<label>Item Description</label>
<input type="text" name="itemDescription" required>
</div>

<div>
<label>Quantity</label>
<input type="number" name="quantity" id="qty" min="1" required>
</div>

<div>
<label>Unit Price</label>
<input type="number" step="0.01" name="unitPrice" id="price" min="0" required>
</div>

<div>
<label>Tax (%)</label>
<input type="number" step="0.01" name="tax" id="tax" value="0" min="0">
</div>

<div>
<label>Payment Terms</label>
<input type="text" name="paymentTerms" placeholder="Net 30" required>
</div>

<div class="full">
<label>Due Date</label>
<input type="date" name="dueDate" required>
</div>

</div>

<div class="total-box">
Estimated Total: ₹ <span id="total">0</span>
</div>

<button type="submit">
<i class="fa-solid fa-file-invoice"></i> Create Invoice
</button>

</form>

</div>

</div>

</div>

<script>

function calculateTotal(){

let q=parseFloat(document.getElementById("qty").value) || 0;
let p=parseFloat(document.getElementById("price").value) || 0;
let t=parseFloat(document.getElementById("tax").value) || 0;

let subtotal=q*p;
let total=subtotal+(subtotal*(t/100));

document.getElementById("total").innerText=total.toFixed(2);

}

document.getElementById("qty").oninput=calculateTotal;
document.getElementById("price").oninput=calculateTotal;
document.getElementById("tax").oninput=calculateTotal;

</script>

</body>
</html>