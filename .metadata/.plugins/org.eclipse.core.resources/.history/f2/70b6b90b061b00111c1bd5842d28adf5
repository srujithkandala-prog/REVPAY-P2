<!DOCTYPE html>
<html xmlns:th="http://www.thymeleaf.org" lang="en">

<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<title>RevPay — Dashboard</title>

<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">

<style>

*{margin:0;padding:0;box-sizing:border-box;}

:root{
--navy-dark:#0f172a;
--navy-subtle:#1e293b;
--accent-blue:#2563eb;
--white:#ffffff;
--border:rgba(255,255,255,0.08);
--muted:rgba(255,255,255,0.5);
--sidebar-w:230px;
}

body{
font-family:'Inter',sans-serif;
background:var(--navy-dark);
color:white;
display:flex;
min-height:100vh;
}

.sidebar{
width:var(--sidebar-w);
background:var(--navy-subtle);
position:fixed;
top:0;
left:0;
bottom:0;
border-right:1px solid var(--border);
padding-top:20px;
}

.sidebar-logo{
display:flex;
align-items:center;
gap:10px;
padding:20px;
text-decoration:none;
color:white;
}

.logo-box{
width:36px;
height:36px;
background:white;
color:black;
border-radius:8px;
display:flex;
align-items:center;
justify-content:center;
font-weight:700;
}

.logo-text .s-tag{
font-size:10px;
color:#eab308;
}

.nav-section{
padding:12px 20px;
font-size:10px;
letter-spacing:2px;
color:#64748b;
}

.nav-item{
display:flex;
align-items:center;
gap:10px;
padding:10px 18px;
text-decoration:none;
color:#94a3b8;
}

.nav-item:hover{
background:#1e293b;
color:white;
}

.nav-item.active{
background:#2563eb33;
color:white;
}

.main{
margin-left:var(--sidebar-w);
flex:1;
display:flex;
flex-direction:column;
}

.topbar{
display:flex;
justify-content:space-between;
align-items:center;
padding:18px 32px;
border-bottom:1px solid var(--border);
background:#0f172a;
}

.topbar-left{
display:flex;
flex-direction:column;
}

.topbar-title{
font-size:18px;
font-weight:700;
}

.topbar-sub{
font-size:12px;
color:var(--muted);
}

.topbar-right{
display:flex;
align-items:center;
gap:15px;
}

.tb-badge{
padding:4px 10px;
border-radius:6px;
font-size:11px;
background:#2563eb33;
color:#93c5fd;
}

.tb-btn{
width:34px;
height:34px;
border-radius:7px;
background:#1e293b;
display:flex;
align-items:center;
justify-content:center;
text-decoration:none;
color:white;
position:relative;
}

.notif-dot{
width:6px;
height:6px;
background:red;
border-radius:50%;
position:absolute;
top:6px;
right:6px;
}

.tb-avatar{
width:34px;
height:34px;
border-radius:7px;
background:#2563eb;
display:flex;
align-items:center;
justify-content:center;
font-weight:700;
}

.content{
padding:30px;
}

.welcome-banner{
background:#1e293b;
padding:25px;
border-radius:12px;
display:flex;
justify-content:space-between;
align-items:center;
margin-bottom:25px;
}

.btn-blue{
background:#2563eb;
padding:10px 16px;
border-radius:6px;
text-decoration:none;
color:white;
font-size:13px;
}

.btn-outline{
border:1px solid var(--border);
padding:10px 16px;
border-radius:6px;
text-decoration:none;
color:white;
font-size:13px;
}

.wallet{
background:linear-gradient(135deg,#2563eb,#7c3aed);
padding:30px;
border-radius:14px;
margin-bottom:25px;
}

.wallet h2{
font-size:32px;
margin:10px 0;
}

.cards{
display:grid;
grid-template-columns:repeat(3,1fr);
gap:20px;
margin-bottom:25px;
}

.card{
background:#1e293b;
padding:20px;
border-radius:12px;
}

.card h3{
margin-bottom:10px;
}

.quick{
background:#1e293b;
padding:20px;
border-radius:12px;
margin-bottom:25px;
}

.quick-grid{
display:grid;
grid-template-columns:repeat(5,1fr);
gap:15px;
margin-top:10px;
}

.quick-item{
background:#111827;
padding:18px;
border-radius:10px;
text-align:center;
text-decoration:none;
color:white;
}

.transactions{
background:#1e293b;
padding:20px;
border-radius:12px;
}

.txn{
display:flex;
justify-content:space-between;
padding:12px 0;
border-bottom:1px solid rgba(255,255,255,0.05);
}

</style>
</head>

<body>

<aside class="sidebar">

<a th:href="@{/dashboard}" class="sidebar-logo">
<div class="logo-box">R</div>
<div class="logo-text">
<div>RevPay</div>
<div class="s-tag">PERSONAL</div>
</div>
</a>

<div class="nav-section">MAIN</div>

<a th:href="@{/dashboard}" class="nav-item active">🏠 Dashboard</a>
<a th:href="@{/profile}" class="nav-item">👤 Profile</a>

<div class="nav-section">PAYMENTS</div>

<a th:href="@{/send-money}" class="nav-item">💸 Send Money</a>
<a th:href="@{/add-money}" class="nav-item">➕ Add Money</a>
<a th:href="@{/request-money}" class="nav-item">📩 Request Money</a>
<a th:href="@{/withdraw}" class="nav-item">🏦 Withdraw</a>

<div class="nav-section">HISTORY</div>

<a th:href="@{/transactions}" class="nav-item">🔁 Transactions</a>
<a th:href="@{/transaction-history}" class="nav-item">📄 Transaction History</a>

<div class="nav-section">ACCOUNT</div>

<a th:href="@{/notifications}" class="nav-item">🔔 Notifications</a>
<a th:href="@{/logout}" class="nav-item">🚪 Logout</a>

</aside>

<div class="main">

<div class="topbar">

<div class="topbar-left">
<div class="topbar-title">Dashboard</div>
<div class="topbar-sub"
th:text="${#dates.format(#dates.createNow(),'EEEE, dd MMMM yyyy')}">
Sunday, 08 March 2026
</div>
</div>

<div class="topbar-right">

<span class="tb-badge">PERSONAL</span>

<a th:href="@{/notifications}" class="tb-btn">
🔔
<div class="notif-dot"></div>
</a>

<div class="tb-avatar"
th:text="${username != null ? #strings.substring(username,0,1).toUpperCase() : 'U'}">
U
</div>

</div>

</div>

<div class="content">

<div class="welcome-banner">

<div>
<h2>Welcome back, <span th:text="${username}">User</span> 👋</h2>
<p>Here's your financial overview for today.</p>
</div>

<div>
<a th:href="@{/send-money}" class="btn-blue">Send Money</a>
<a th:href="@{/add-money}" class="btn-outline">Add Money</a>
</div>

</div>

<div class="wallet">

<div>Wallet Balance</div>
<h2>₹ <span th:text="${walletBalance}">0</span></h2>

</div>

<div class="cards">

<div class="card">
<h3>Total Sent</h3>
₹ <span th:text="${totalSent}">0</span>
</div>

<div class="card">
<h3>Total Received</h3>
₹ <span th:text="${totalReceived}">0</span>
</div>

<div class="card">
<h3>Total Transactions</h3>
<span th:text="${totalTransactions}">0</span>
</div>

</div>

<div class="quick">

<h3>Quick Actions</h3>

<div class="quick-grid">

<a th:href="@{/send-money}" class="quick-item">Send Money</a>
<a th:href="@{/request-money}" class="quick-item">Request</a>
<a th:href="@{/add-money}" class="quick-item">Add Money</a>
<a th:href="@{/payment-methods}" class="quick-item">Cards</a>
<a th:href="@{/transactions-history}" class="quick-item">History</a>

</div>

</div>

<div class="transactions">

<h3>Recent Transactions</h3>

<div th:if="${#lists.isEmpty(recentTransactions)}">
No transactions yet
</div>

<div th:each="txn : ${recentTransactions}" class="txn">

<div>
<div th:text="${txn.name}">User</div>
<small th:text="${txn.date}">Date</small>
</div>

<div>
₹ <span th:text="${txn.amount}">0</span>
</div>

</div>

</div>

</div>

</div>

</body>
</html>