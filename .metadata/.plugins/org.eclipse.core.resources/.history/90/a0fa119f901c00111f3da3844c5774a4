<!DOCTYPE html>
<html xmlns:th="http://www.thymeleaf.org">

<head>
<meta charset="UTF-8">
<title>Transaction History</title>

<!-- Bootstrap -->
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">

<!-- Icons -->
<link rel="stylesheet"
href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">

<style>

body{
background:#f1f5f9;
font-family:'Segoe UI',sans-serif;
}

/* SIDEBAR */

.sidebar{
height:100vh;
width:240px;
position:fixed;
background:linear-gradient(180deg,#0f172a,#020617);
color:white;
padding-top:20px;
}

.sidebar h3{
text-align:center;
margin-bottom:20px;
}

.sidebar a{
display:block;
padding:12px 20px;
color:#cbd5f5;
text-decoration:none;
border-left:3px solid transparent;
transition:0.2s;
}

.sidebar a:hover{
background:#1e293b;
border-left:3px solid #38bdf8;
color:white;
}

/* MAIN */

.main{
margin-left:240px;
padding:40px;
}

/* CARD */

.transaction-card{
border-radius:12px;
box-shadow:0 10px 25px rgba(0,0,0,0.08);
}

/* TABLE */

table tbody tr:hover{
background:#f8fafc;
}

</style>

</head>

<body>

<!-- SIDEBAR -->

<div class="sidebar">

<h3>RevPay</h3>

<a href="/business-dashboard"><i class="fa-solid fa-chart-line"></i> Dashboard</a>
<a href="/profile"><i class="fa-solid fa-user"></i> Profile</a>
<a href="/send-money"><i class="fa-solid fa-paper-plane"></i> Send Money</a>
<a href="/add-money"><i class="fa-solid fa-wallet"></i> Add Money</a>
<a href="/withdraw-money"><i class="fa-solid fa-money-bill-wave"></i> Withdraw</a>
<a href="/transactions"><i class="fa-solid fa-clock-rotate-left"></i> Transactions</a>
<a href="/logout"><i class="fa-solid fa-right-from-bracket"></i> Logout</a>

</div>

<!-- MAIN CONTENT -->

<div class="main">

<div class="d-flex justify-content-between align-items-center mb-4">

<h2>Transactions</h2>

<a href="/business-dashboard" class="btn btn-success">
<i class="fa-solid fa-arrow-left"></i> Dashboard
</a>

</div>

<!-- SEARCH BAR -->

<div class="card transaction-card p-4">

<div class="row mb-3">




</div>

<!-- TABLE -->

<div class="table-responsive">

<table class="table table-striped table-hover">

<thead class="table-dark">

<tr>
<th>Sender</th>
<th>Receiver</th>
<th>Amount</th>
<th>Date</th>
</tr>

</thead>

<tbody>

<tr th:each="t : ${transactions}">

<td th:text="${t.senderEmail}"></td>

<!-- FIXED LINE -->
<td th:text="${t.receiverEmail == 'BANK' ? 'Withdraw' : t.receiverEmail}"></td>

<td>
₹ <span th:text="${t.amount}"></span>
</td>

<td th:text="${#temporals.format(t.transactionDate,'dd-MM-yyyy HH:mm')}"></td>

</tr>

</tbody>

</table>

</div>

</div>

</div>

</body>
</html>