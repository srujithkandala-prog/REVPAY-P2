<!DOCTYPE html>
<html xmlns:th="http://www.thymeleaf.org" lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>RevPay - Login</title>
<link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --blue:   #2563eb;
    --blue-lt:#3b82f6;
    --purple: #7c3aed;
    --bg:     #f0f2ff;
  }

  html, body { height: 100%; }

  body {
    font-family: 'Plus Jakarta Sans', sans-serif;
    min-height: 100vh;
    display: flex;
    background: var(--bg);
    overflow: hidden;
  }

  /* ═══════════════════════════
     LEFT  —  ILLUSTRATION
  ═══════════════════════════ */
  .left {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 48px 40px;
    position: relative;
    overflow: hidden;
  }

  /* soft gradient blobs in bg */
  .left::before {
    content: '';
    position: absolute;
    width: 500px; height: 500px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(124,58,237,0.12) 0%, transparent 65%);
    top: -100px; left: -100px;
    pointer-events: none;
  }

  .left::after {
    content: '';
    position: absolute;
    width: 400px; height: 400px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(37,99,235,0.1) 0%, transparent 65%);
    bottom: -100px; right: -80px;
    pointer-events: none;
  }

  /* headline text */
  .ill-text {
    text-align: center;
    margin-bottom: 44px;
    position: relative;
    z-index: 1;
  }

  .ill-text h2 {
    font-size: clamp(22px, 2.4vw, 30px);
    font-weight: 800;
    color: #1e1b4b;
    line-height: 1.25;
    letter-spacing: -0.5px;
    margin-bottom: 12px;
    max-width: 320px;
    margin-left: auto;
    margin-right: auto;
  }

  .ill-text p {
    font-size: 13px;
    color: #64748b;
    line-height: 1.65;
    max-width: 280px;
    margin: 0 auto;
  }

  /* ── 3-D PHONE ILLUSTRATION ── */
  .ill-scene {
    position: relative;
    width: 260px;
    height: 310px;
    z-index: 1;
    animation: sceneFloat 5s ease-in-out infinite;
  }

  @keyframes sceneFloat {
    0%, 100% { transform: translateY(0px); }
    50%       { transform: translateY(-14px); }
  }

  /* PHONE body */
  .phone {
    position: absolute;
    left: 50%; top: 50%;
    transform: translate(-50%, -50%);
    width: 130px; height: 220px;
    background: linear-gradient(145deg, #ede9fe, #ddd6fe);
    border-radius: 28px;
    box-shadow:
      8px 16px 40px rgba(124,58,237,0.35),
      -4px -4px 16px rgba(255,255,255,0.7),
      inset 0 0 0 2px rgba(255,255,255,0.5);
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 2;
  }

  /* phone notch */
  .phone::before {
    content: '';
    position: absolute;
    top: 10px;
    width: 40px; height: 8px;
    background: rgba(124,58,237,0.2);
    border-radius: 4px;
  }

  /* phone screen icon */
  .phone-icon {
    width: 64px; height: 64px;
    background: linear-gradient(135deg, #7c3aed, #6d28d9);
    border-radius: 18px;
    display: flex; align-items: center; justify-content: center;
    font-size: 28px;
    box-shadow: 0 8px 24px rgba(124,58,237,0.45);
    margin-top: 12px;
  }

  /* revpay screen inside phone */
  .phone-screen-inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 6px;
    margin-top: 12px;
  }

  .phone-screen-logo {
    width: 44px; height: 44px;
    background: linear-gradient(135deg, #2563eb, #7c3aed);
    border-radius: 13px;
    display: flex; align-items: center; justify-content: center;
    font-size: 20px; font-weight: 900; color: white;
    box-shadow: 0 6px 18px rgba(124,58,237,0.45);
    font-family: 'Plus Jakarta Sans', sans-serif;
    letter-spacing: -1px;
  }

  .phone-screen-name {
    font-size: 9px; font-weight: 800;
    color: #4c1d95;
    letter-spacing: 1.5px;
    text-transform: uppercase;
  }

  .phone-screen-balance {
    font-size: 15px; font-weight: 800;
    color: #3b0764;
    letter-spacing: -0.5px;
    margin-top: 4px;
  }

  .phone-screen-label {
    font-size: 7.5px; color: #7c3aed;
    font-weight: 600; letter-spacing: 0.5px;
  }

  .phone-screen-bar {
    width: 80px; height: 4px;
    background: rgba(124,58,237,0.15);
    border-radius: 2px;
    margin-top: 6px;
    overflow: hidden;
  }

  .phone-screen-bar-fill {
    width: 60%; height: 100%;
    background: linear-gradient(90deg, #2563eb, #7c3aed);
    border-radius: 2px;
  }

  /* sparkles around phone */
  .spark {
    position: absolute;
    font-size: 18px;
    color: #a78bfa;
    animation: sparkle 3s ease-in-out infinite;
  }

  .spark1 { top: 30px;  left: 20px;  animation-delay: 0s;   font-size: 20px; }
  .spark2 { top: 10px;  right: 30px; animation-delay: 1s;   font-size: 14px; }
  .spark3 { bottom: 50px; left: 10px; animation-delay: 0.5s; font-size: 16px; }

  @keyframes sparkle {
    0%, 100% { opacity: 0.4; transform: scale(1); }
    50%       { opacity: 1;   transform: scale(1.3); }
  }

  /* FLOATING BADGE ICONS */
  .badge {
    position: absolute;
    width: 52px; height: 52px;
    border-radius: 16px;
    display: flex; align-items: center; justify-content: center;
    font-size: 24px;
    box-shadow: 0 8px 24px rgba(0,0,0,0.15);
    z-index: 3;
  }

  .badge-green {
    background: linear-gradient(135deg, #10b981, #059669);
    top: 20px; right: 20px;
    animation: badgeFloat 4s ease-in-out infinite;
    transform: rotate(8deg);
  }

  .badge-orange {
    background: linear-gradient(135deg, #f97316, #ea580c);
    top: 80px; left: 10px;
    animation: badgeFloat 5s ease-in-out infinite reverse;
    transform: rotate(-10deg);
  }

  .badge-pink {
    background: linear-gradient(135deg, #ec4899, #db2777);
    bottom: 60px; right: 14px;
    animation: badgeFloat 4.5s ease-in-out infinite;
    transform: rotate(5deg);
  }

  @keyframes badgeFloat {
    0%, 100% { transform: translateY(0px) rotate(var(--rot, 0deg)); }
    50%       { transform: translateY(-10px) rotate(var(--rot, 0deg)); }
  }

  /* shadow under phone */
  .phone-shadow {
    position: absolute;
    bottom: 10px; left: 50%;
    transform: translateX(-50%);
    width: 100px; height: 16px;
    background: radial-gradient(ellipse, rgba(124,58,237,0.25) 0%, transparent 70%);
    border-radius: 50%;
    z-index: 1;
  }

  /* dots pagination */
  .dots {
    display: flex; gap: 7px; margin-top: 36px;
    position: relative; z-index: 1;
  }

  .dot {
    width: 8px; height: 8px;
    border-radius: 50%;
    background: #c4b5fd;
  }

  .dot.active {
    width: 22px;
    border-radius: 4px;
    background: var(--purple);
  }

  /* ═══════════════════════════
     RIGHT — LOGIN FORM
  ═══════════════════════════ */
  .right {
    width: 420px;
    flex-shrink: 0;
    background: white;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 48px 44px;
    box-shadow: -8px 0 40px rgba(0,0,0,0.06);
    position: relative;
    z-index: 2;
  }

  .form-box { width: 100%; max-width: 320px; }

  /* logo */
  .form-logo {
    display: flex; align-items: center; gap: 9px;
    text-decoration: none; margin-bottom: 36px;
  }

  .logo-box {
    width: 36px; height: 36px; background: var(--blue);
    border-radius: 9px; display: flex; align-items: center;
    justify-content: center; font-weight: 800; font-size: 16px; color: white;
    box-shadow: 0 4px 12px rgba(37,99,235,0.35);
  }

  .form-logo span { font-size: 19px; font-weight: 800; color: #1e1b4b; letter-spacing: -0.3px; }

  /* heading */
  .form-head { margin-bottom: 28px; }

  .form-head h2 {
    font-size: 22px; font-weight: 800;
    color: #1e1b4b; letter-spacing: -0.4px; margin-bottom: 5px;
  }

  .form-head p { font-size: 13px; color: #94a3b8; }

  /* fields */
  .field { margin-bottom: 14px; }

  .field label {
    display: block; font-size: 11.5px; font-weight: 700;
    color: #475569; letter-spacing: 0.4px;
    text-transform: uppercase; margin-bottom: 6px;
  }

  .pw-wrap { position: relative; }
  .pw-wrap input { padding-right: 40px; }

  .pw-eye {
    position: absolute; right: 12px; top: 50%;
    transform: translateY(-50%);
    background: none; border: none; cursor: pointer;
    font-size: 14px; opacity: 0.35; padding: 0;
    transition: opacity 0.18s; line-height: 1;
  }

  .pw-eye:hover { opacity: 0.8; }

  .field input {
    width: 100%; padding: 11px 13px;
    border: 1.5px solid #e2e8f0; border-radius: 10px;
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-size: 14px; font-weight: 500; color: #1e293b;
    background: #f8fafc; outline: none;
    transition: border-color 0.18s, box-shadow 0.18s, background 0.18s;
  }

  .field input:focus {
    border-color: var(--blue);
    background: white;
    box-shadow: 0 0 0 3px rgba(37,99,235,0.1);
  }

  .field input::placeholder { color: #cbd5e1; font-weight: 400; }

  /* forgot */
  .forgot-row { display: flex; justify-content: flex-end; margin: -4px 0 20px; }

  .forgot-row a {
    font-size: 12px; font-weight: 600;
    color: var(--blue); text-decoration: none;
  }

  .forgot-row a:hover { text-decoration: underline; }

  /* submit */
  .btn-submit {
    width: 100%; padding: 13px;
    background: var(--blue); color: white;
    border: none; border-radius: 10px;
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-size: 15px; font-weight: 700; cursor: pointer;
    box-shadow: 0 4px 16px rgba(37,99,235,0.3);
    transition: background 0.18s, transform 0.15s, box-shadow 0.18s;
  }

  .btn-submit:hover {
    background: var(--blue-lt);
    transform: translateY(-1px);
    box-shadow: 0 8px 24px rgba(37,99,235,0.38);
  }

  .btn-submit:active { transform: translateY(0); }

  /* divider */
  .or-divider {
    display: flex; align-items: center; gap: 10px;
    font-size: 11px; font-weight: 700;
    color: #cbd5e1; letter-spacing: 1.5px;
    text-transform: uppercase; margin: 20px 0;
  }

  .or-divider::before,
  .or-divider::after { content: ''; flex: 1; height: 1px; background: #f1f5f9; }

  /* bottom links */
  .bottom-links { display: flex; flex-direction: column; align-items: center; gap: 10px; }

  .register-link {
    display: block; width: 100%; text-align: center;
    padding: 12px; border-radius: 10px;
    border: 1.5px solid #e2e8f0;
    background: white; color: #1e293b;
    font-size: 14px; font-weight: 700; text-decoration: none;
    transition: all 0.18s;
  }

  .register-link:hover {
    border-color: var(--blue);
    box-shadow: 0 0 0 3px rgba(37,99,235,0.08);
  }

  .home-link {
    font-size: 12px; color: #94a3b8;
    font-weight: 500; text-decoration: none;
    transition: color 0.18s;
  }

  .home-link:hover { color: #475569; }

  /* RESPONSIVE */
  @media (max-width: 820px) {
    .left  { display: none; }
    .right { width: 100%; box-shadow: none; }
  }
</style>
</head>
<body>

<!-- LEFT: ILLUSTRATION -->
<div class="left">

  <div class="ill-text">
    <h2>Easy, safe, and efficient transactions</h2>
    <p>Experience seamless payments that prioritize your safety and efficiency.</p>
  </div>

  <div class="ill-scene">

    <!-- sparkles -->
    <div class="spark spark1">✦</div>
    <div class="spark spark2">✦</div>
    <div class="spark spark3">✦</div>

    <!-- floating badges -->
    <div class="badge badge-green">✓</div>
    <div class="badge badge-orange">↗</div>
    <div class="badge badge-pink">😊</div>

    <!-- phone -->
    <div class="phone">
      <div class="phone-screen-inner">
        <div class="phone-screen-logo">R</div>
        <div class="phone-screen-name">RevPay</div>
        <div class="phone-screen-balance">₹ 24,500</div>
        <div class="phone-screen-label">Wallet Balance</div>
        <div class="phone-screen-bar"><div class="phone-screen-bar-fill"></div></div>
      </div>
    </div>

    <!-- shadow -->
    <div class="phone-shadow"></div>
  </div>



</div>

<!-- RIGHT: LOGIN FORM -->
<div class="right">
  <div class="form-box">

    <a th:href="@{/}" class="form-logo">
      <div class="logo-box">R</div>
      <span>RevPay</span>
    </a>

    <div class="form-head">
      <h2>Login to your account</h2>
      <p>Enter your credentials to continue.</p>
    </div>

    <form th:action="@{/login}" method="post">

      <div class="field">
        <label>Email or Phone</label>
        <input type="text" name="username" placeholder="you@example.com" required autofocus>
      </div>

      <div class="field">
        <label>Password</label>
        <div class="pw-wrap">
          <input type="password" id="pw" name="password" placeholder="Enter your password" required>
          <button type="button" class="pw-eye" onclick="togglePw()">👁</button>
        </div>
      </div>

      <div class="forgot-row">
        <a th:href="@{/forgot-password}">Forgot password?</a>
      </div>

      <button type="submit" class="btn-submit">Login →</button>
    </form>

    <div class="or-divider">or</div>

    <div class="bottom-links">
      <a th:href="@{/register}" class="register-link">Create a new account</a>
      <a th:href="@{/}" class="home-link">← Back to Home</a>
    </div>

  </div>
</div>

<script>
  function togglePw() {
    const el = document.getElementById('pw');
    const btn = el.nextElementSibling;
    el.type = el.type === 'password' ? 'text' : 'password';
    btn.textContent = el.type === 'password' ? '👁' : '🙈';
  }
</script>
</body>
</html>