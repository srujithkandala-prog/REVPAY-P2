<!DOCTYPE html>
<html xmlns:th="http://www.thymeleaf.org">
<body style="font-family:Arial;background:#f4f6f9;padding:20px;">

<h2>Request Money 💰</h2>

<form th:action="@{/request-money}" method="post"
      th:object="${request}">

<input type="email" th:field="*{receiverEmail}"
placeholder="Receiver Email" required><br><br>

<input type="number" step="0.01"
th:field="*{amount}" placeholder="Amount" required><br><br>

<input type="text" th:field="*{purpose}"
placeholder="Purpose" required><br><br>

<button type="submit">Send Request</button>

</form>

</body>
</html>