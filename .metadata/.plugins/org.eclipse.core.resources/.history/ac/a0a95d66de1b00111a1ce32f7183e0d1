<!DOCTYPE html>
<html xmlns:th="http://www.thymeleaf.org">
<head>

<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1">

<title>Reports - RevPay Admin</title>

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
<link href="https://cdn.jsdelivr.net/npm/bootstrap-icons/font/bootstrap-icons.css" rel="stylesheet">
<link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">

<style>

body{
font-family:'Plus Jakarta Sans',sans-serif;
background:#f5f6fa;
margin:0;
}

/* SIDEBAR */

.sidebar{
width:260px;
height:100vh;
background:#0f172a;
color:white;
position:fixed;
padding:20px;
}

.sidebar h2{
margin-bottom:30px;
}

.sidebar a{
display:block;
color:white;
text-decoration:none;
margin:15px 0;
}

.sidebar a:hover{
color:#38bdf8;
}

/* MAIN */

.content{
margin-left:280px;
padding:40px;
}

/* REPORT CARDS */

.reports-grid{
display:grid;
grid-template-columns:repeat(auto-fit,minmax(280px,1fr));
gap:20px;
}

.report-card{
background:white;
border-radius:12px;
padding:25px;
box-shadow:0 4px 10px rgba(0,0,0,0.08);
transition:0.3s;
}

.report-card:hover{
transform:translateY(-5px);
box-shadow:0 10px 20px rgba(0,0,0,0.15);
}

.report-icon{
font-size:30px;
color:#6366f1;
margin-bottom:15px;
}

.report-title{
font-size:18px;
font-weight:700;
margin-bottom:8px;
}

.report-desc{
font-size:13px;
color:#6b7280;
margin-bottom:15px;
}

.report-link{
display:inline-flex;
align-items:center;
gap:6px;
background:#6366f1;
color:white;
padding:8px 14px;
border-radius:6px;
text-decoration:none;
font-size:13px;
}

.report-link:hover{
background:#4f46e5;
color:white;
}

</style>

</head>

<body>

<!-- SIDEBAR -->

<div class="sidebar">

<h2>RevPay Admin</h2>

<a href="/admin-dashboard">Dashboard</a>
<a href="/admin/users">Users</a>
<a href="/admin/transactions">Transactions</a>
<a href="/admin/loans">Loans</a>
<a href="/admin/revenue">Revenue</a>
<a href="/admin/system-health">System Health</a>
<a href="/admin/live-transactions">Live Monitor</a>
<a href="/admin/fraud-alerts">Fraud Alerts</a>
<a href="/admin/reports">Reports</a>

<hr>

<a href="/logout">Logout</a>

</div>


<!-- MAIN CONTENT -->

<div class="content">

<h1>Admin Reports</h1>

<div class="reports-grid">

<!-- DAILY TRANSACTIONS -->

<div class="report-card">

<div class="report-icon">
<i class="bi bi-calendar-check"></i>
</div>

<div class="report-title">
Daily Transactions Report
</div>

<div class="report-desc">
View all transaction activity across the platform.
</div>

<a th:href="@{/admin/transactions}" class="report-link">

View Report
<i class="bi bi-arrow-right"></i>

</a>

</div>


<!-- LOAN REPORT -->

<div class="report-card">

<div class="report-icon">
<i class="bi bi-bank2"></i>
</div>

<div class="report-title">
Loan Reports
</div>

<div class="report-desc">
Review loan approvals, rejections and repayment data.
</div>

<a th:href="@{/admin/loans}" class="report-link">

View Report
<i class="bi bi-arrow-right"></i>

</a>

</div>


<!-- USER REPORT -->

<div class="report-card">

<div class="report-icon">
<i class="bi bi-people-fill"></i>
</div>

<div class="report-title">
User Activity Report
</div>

<div class="report-desc">
Monitor user registrations and activity across the platform.
</div>

<a th:href="@{/admin/users}" class="report-link">

View Report
<i class="bi bi-arrow-right"></i>

</a>

</div>


<!-- REVENUE REPORT -->

<div class="report-card">

<div class="report-icon">
<i class="bi bi-cash-coin"></i>
</div>

<div class="report-title">
Revenue Report
</div>

<div class="report-desc">
Analyze platform earnings and transaction revenue.
</div>

<a th:href="@{/admin/revenue}" class="report-link">

View Report
<i class="bi bi-arrow-right"></i>

</a>

</div>

</div>

</div>

</body>
</html>