<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
	xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 https://maven.apache.org/xsd/maven-4.0.0.xsd">
	<modelVersion>4.0.0</modelVersion>
	<parent>
		<groupId>org.springframework.boot</groupId>
		<artifactId>spring-boot-starter-parent</artifactId>
		<version>3.5.11</version>
		<relativePath/> <!-- lookup parent from repository -->
	</parent>
	<groupId>com.REVpay</groupId>
	<artifactId>revpay</artifactId>
	<version>0.0.1-SNAPSHOT</version>
	<name>revpay</name>
	<description>revpay</description>
	<url/>
	<licenses>
		<license/>
	</licenses>
	<developers>
		<developer/>
	</developers>
	<scm>
		<connection/>
		<developerConnection/>
		<tag/>
		<url/>
	</scm>

	<properties>
		<java.version>17</java.version>
	</properties>

	<dependencies>

		<!-- ===================================================== -->
		<!-- CORE SPRING BOOT DEPENDENCIES (already existed)       -->
		<!-- ===================================================== -->

		<dependency>
			<groupId>org.springframework.boot</groupId>
			<artifactId>spring-boot-starter-data-jpa</artifactId>
		</dependency>

		<dependency>
			<groupId>org.springframework.boot</groupId>
			<artifactId>spring-boot-starter-security</artifactId>
		</dependency>

		<dependency>
			<groupId>org.springframework.boot</groupId>
			<artifactId>spring-boot-starter-thymeleaf</artifactId>
		</dependency>

		<dependency>
			<groupId>org.springframework.boot</groupId>
			<artifactId>spring-boot-starter-validation</artifactId>
		</dependency>

		<dependency>
			<groupId>org.springframework.boot</groupId>
			<artifactId>spring-boot-starter-web</artifactId>
		</dependency>

		<dependency>
			<groupId>org.thymeleaf.extras</groupId>
			<artifactId>thymeleaf-extras-springsecurity6</artifactId>
		</dependency>

		<dependency>
			<groupId>org.springframework.boot</groupId>
			<artifactId>spring-boot-starter-mail</artifactId>
		</dependency>

		<dependency>
			<groupId>org.springframework.boot</groupId>
			<artifactId>spring-boot-devtools</artifactId>
			<scope>runtime</scope>
			<optional>true</optional>
		</dependency>

		<dependency>
			<groupId>com.mysql</groupId>
			<artifactId>mysql-connector-j</artifactId>
			<scope>runtime</scope>
		</dependency>

		<!-- ===================================================== -->
		<!-- FIX 1: spring-boot-starter-test                       -->
		<!-- The original had no exclusions, which means JUnit 5   -->
		<!-- (junit-jupiter) was pulled in automatically.          -->
		<!-- JUnit 4 and JUnit 5 conflict with each other, so we   -->
		<!-- MUST exclude junit-jupiter here.                      -->
		<!-- ===================================================== -->
		<dependency>
			<groupId>org.springframework.boot</groupId>
			<artifactId>spring-boot-starter-test</artifactId>
			<scope>test</scope>
			<exclusions>
				<exclusion>
					<groupId>org.junit.jupiter</groupId>
					<artifactId>junit-jupiter</artifactId>
				</exclusion>
			</exclusions>
		</dependency>

		<dependency>
			<groupId>org.springframework.security</groupId>
			<artifactId>spring-security-test</artifactId>
			<scope>test</scope>
		</dependency>

		<!-- ===================================================== -->
		<!-- FIX 2: JUnit 4                                        -->
		<!-- The __version__ underscores in your pom.xml are NOT   -->
		<!-- valid XML — Maven cannot parse them.                  -->
		<!-- Correct tag is just <version>4.13.2</version>         -->
		<!-- ===================================================== -->
		<dependency>
			<groupId>junit</groupId>
			<artifactId>junit</artifactId>
			<version>4.13.2</version>
			<scope>test</scope>
		</dependency>

		<!-- ===================================================== -->
		<!-- FIX 3: Mockito                                        -->
		<!-- Same issue — __version__ is invalid XML.              -->
		<!-- Correct tag is just <version>5.12.0</version>         -->
		<!-- ===================================================== -->
		<dependency>
			<groupId>org.mockito</groupId>
			<artifactId>mockito-core</artifactId>
			<version>5.12.0</version>
			<scope>test</scope>
		</dependency>

		<!-- ===================================================== -->
		<!-- H2 in-memory database (used only during tests)        -->
		<!-- No version needed — Spring Boot manages it            -->
		<!-- ===================================================== -->
		<dependency>
			<groupId>com.h2database</groupId>
			<artifactId>h2</artifactId>
			<scope>test</scope>
		</dependency>

		<!-- ===================================================== -->
		<!-- FIX 4: Log4J2 — must ALSO exclude spring-boot-        -->
		<!-- starter-logging from the main starters that pull in   -->
		<!-- Logback. If both Logback and Log4J2 are present,      -->
		<!-- you get "Multiple SLF4J bindings" errors at startup.  -->
		<!-- The fix: exclude spring-boot-starter-logging from     -->
		<!-- spring-boot-starter-web (it is the main one that      -->
		<!-- pulls in Logback transitively).                       -->
		<!-- ===================================================== -->
		<dependency>
			<groupId>org.springframework.boot</groupId>
			<artifactId>spring-boot-starter-log4j2</artifactId>
		</dependency>

	</dependencies>

	<build>
		<plugins>

			<!-- ================================================= -->
			<!-- Spring Boot Maven Plugin (already existed)        -->
			<!-- ================================================= -->
			<plugin>
				<groupId>org.springframework.boot</groupId>
				<artifactId>spring-boot-maven-plugin</artifactId>
				<!-- FIX 5: exclude Logback from the fat JAR       -->
				<!-- This prevents the "Multiple SLF4J bindings"   -->
				<!-- error when you run mvn spring-boot:run        -->
				<configuration>
					<excludes>
						<exclude>
							<groupId>org.springframework.boot</groupId>
							<artifactId>spring-boot-starter-logging</artifactId>
						</exclude>
					</excludes>
				</configuration>
			</plugin>

			<!-- ================================================= -->
			<!-- FIX 6: Maven Surefire Plugin                      -->
			<!-- The __version__ underscores were invalid XML.     -->
			<!-- This plugin tells Maven to discover and run       -->
			<!-- JUnit4 test files ending in Test.java             -->
			<!-- ================================================= -->
			<plugin>
				<groupId>org.apache.maven.plugins</groupId>
				<artifactId>maven-surefire-plugin</artifactId>
				<version>3.2.5</version>
				<configuration>
					<includes>
						<include>**/*Test.java</include>
						<include>**/*Tests.java</include>
					</includes>
				</configuration>
			</plugin>

		</plugins>
	</build>

</project>