<!DOCTYPE html>
<html xmlns:th="http://www.thymeleaf.org" lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>RevPay — Withdraw Money</title>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
<style>
/* ── THEME CORE (FROM DASHBOARD) ── */
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
:root {
    --navy-dark:   #0f172a;
    --navy-subtle: #1e293b;
    --navy-mid:    #111827;
    --accent-blue: #2563eb;
    --gold:        #eab308;
    --white:       #ffffff;
    --glass:       rgba(255,255,255,0.03);
    --border:      rgba(255,255,255,0.08);
    --muted:       rgba(255,255,255,0.5);
    --sidebar-w:   230px;
}
body {
    font-family: 'Inter', sans-serif;
    background: var(--navy-dark);
    color: var(--white);
    line-height: 1.6;
    display: flex; min-height: 100vh;
    -webkit-font-smoothing: antialiased;
}

/* ── SIDEBAR (EXACT COPY) ── */
.sidebar {
    width: var(--sidebar-w); background: var(--navy-subtle);
    border-right: 1px solid var(--border); position: fixed; top: 0; left: 0; bottom: 0;
    z-index: 50; overflow-y: auto; display: flex; flex-direction: column;
}
.sidebar-logo {
    display: flex; align-items: center; gap: 11px; padding: 22px 20px 18px;
    text-decoration: none; position: relative; z-index: 1; border-bottom: 1px solid var(--border); margin-bottom: 8px;
}
.logo-box {
    width: 36px; height: 36px; background: var(--white); color: var(--navy-dark);
    border-radius: 8px; display: flex; align-items: center; justify-content: center;
    font-weight: 800; font-size: 16px; border: 2px solid var(--gold); flex-shrink: 0;
}
.logo-text { display: flex; flex-direction: column; }
.logo-text .s-name { color: white; font-size: 15px; font-weight: 800; }
.logo-text .s-tag  { font-size: 9px; font-weight: 700; letter-spacing: 1.5px; text-transform: uppercase; color: var(--gold); display: block; margin-top: 1px; }

.nav-section { padding: 12px 20px 4px; font-size: 10px; font-weight: 700; color: rgba(255,255,255,0.2); letter-spacing: 2px; text-transform: uppercase; }
.nav-item {
    display: flex; align-items: center; gap: 10px; padding: 9px 12px; margin: 1px 8px;
    text-decoration: none; font-size: 13px; font-weight: 500; color: rgba(255,255,255,0.5);
    border-radius: 6px; transition: all 0.2s;
}
.nav-icon { width: 28px; height: 28px; border-radius: 6px; background: rgba(255,255,255,0.04); display: flex; align-items: center; justify-content: center; font-size: 13px; flex-shrink: 0; }
.nav-item:hover { color: rgba(255,255,255,0.85); background: rgba(255,255,255,0.05); }
.nav-item.active { color: white; background: rgba(37,99,235,0.15); border: 1px solid rgba(37,99,235,0.25); }
.nav-item.active .nav-icon { background: var(--accent-blue); box-shadow: 0 4px 10px rgba(37,99,235,0.35); }
.nav-badge { margin-left: auto; background: #dc2626; color: white; font-size: 10px; font-weight: 700; padding: 2px 7px; border-radius: 10px; }
.sidebar-bottom { margin-top: auto; padding: 10px 0 14px; border-top: 1px solid var(--border); }

/* ── MAIN LAYOUT ── */
.main { margin-left: var(--sidebar-w); flex: 1; display: flex; flex-direction: column; min-height: 100vh; }
.topbar {
    background: rgba(15,23,42,0.95); backdrop-filter: blur(10px); border-bottom: 1px solid var(--border);
    padding: 14px 32px; display: flex; align-items: center; justify-content: space-between; position: sticky; top: 0; z-index: 30;
}
.content { padding: 40px 32px; flex: 1; display: flex; justify-content: center; }

/* ── WITHDRAW FORM CONTENT ── */
.withdraw-card {
    width: 100%; max-width: 450px; background: var(--navy-subtle); border: 1px solid var(--border);
    border-radius: 16px; padding: 32px; height: fit-content;
}
.withdraw-card h2 { font-size: 24px; font-weight: 800; margin-bottom: 8px; letter-spacing: -0.5px; }
.withdraw-card p.subtitle { font-size: 14px; color: var(--muted); margin-bottom: 24px; }

.error-box {
    background: rgba(220, 38, 38, 0.1); color: #f87171; border: 1px solid rgba(220, 38, 38, 0.2);
    padding: 12px; border-radius: 8px; font-size: 13px; font-weight: 600; margin-bottom: 20px;
}

.input-group { margin-bottom: 20px; }
.input-group label { display: block; font-size: 12px; font-weight: 700; color: var(--muted); text-transform: uppercase; margin-bottom: 8px; letter-spacing: 0.5px; }
input[type="number"] {
    width: 100%; background: var(--navy-dark); border: 1px solid var(--border);
    padding: 14px; border-radius: 10px; color: white; font-family: 'Inter', sans-serif;
    font-size: 16px; transition: all 0.2s;
}
input[type="number"]:focus { border-color: var(--accent-blue); outline: none; }

.btn-withdraw {
    width: 100%; padding: 14px; background: var(--accent-blue); color: white;
    border: none; border-radius: 10px; font-size: 15px; font-weight: 700;
    cursor: pointer; transition: all 0.2s;
}
.btn-withdraw:hover { background: #1d4ed8; transform: translateY(-1px); }

@media (max-width: 768px) { .sidebar { display: none; } .main { margin-left: 0; } }
</style>
</head>
<body>

<aside class="sidebar">
  <a th:href="@{/dashboard}" class="sidebar-logo">
    <div class="logo-box">R</div>
    <div class="logo-text">
      <span class="s-name">RevPay</span>
      <span class="s-tag">Personal</span>
    </div>
  </a>
  <div class="nav-section">Main</div>
  <a th:href="@{/dashboard}" class="nav-item"><div class="nav-icon">&#127968;</div>Dashboard</a>
  <a th:href="@{/profile}"   class="nav-item"><div class="nav-icon">&#128100;</div>Profile</a>
  <div class="nav-section">Payments</div>
  <a th:href="@{/send-money}"    class="nav-item"><div class="nav-icon">&#128184;</div>Send Money</a>
  <a th:href="@{/add-money}"     class="nav-item"><div class="nav-icon">&#10133;</div>Add Money</a>
  <a th:href="@{/request-money}" class="nav-item"><div class="nav-icon">&#128232;</div>Request Money</a>
  <a th:href="@{/withdraw-money}"      class="nav-item active"><div class="nav-icon">&#127970;</div>Withdraw Money</a>
  
  <div class="nav-section">Requests</div>
  <a th:href="@{/incoming-requests}" class="nav-item">
    <div class="nav-icon">&#128229;</div>Incoming Requests
    <span class="nav-badge" th:if="${incomingCount != null and incomingCount > 0}" th:text="${incomingCount}"></span>
  </a>
  <a th:href="@{/outgoing-requests}" class="nav-item">
    <div class="nav-icon">&#128228;</div>Outgoing Requests
    <span class="nav-badge" th:if="${outgoingCount != null and outgoingCount > 0}" th:text="${outgoingCount}"></span>
  </a>
  
  <div class="nav-section">History</div>
  <a th:href="@{/transactions}"        class="nav-item"><div class="nav-icon">&#128260;</div>Transactions</a>
  <a th:href="@{/transactions-history}" class="nav-item"><div class="nav-icon">&#128203;</div>Transaction History</a>
  <a th:href="@{/invoices}"            class="nav-item"><div class="nav-icon">&#129534;</div>My Invoices</a>
  
  <div class="nav-section">Account</div>
  <a th:href="@{/payment-methods}" class="nav-item"><div class="nav-icon">&#128179;</div>Payment Methods</a>
  <a th:href="@{/notifications}"   class="nav-item"><div class="nav-icon">&#128276;</div>Notifications</a>
  
  <div class="sidebar-bottom">
    <a th:href="@{/logout}" class="nav-item logout"><div class="nav-icon">&#128682;</div>Logout</a>
  </div>
</aside>

<div class="main">
  <div class="topbar">
    <div>
      <div style="font-weight: 800; font-size: 16px;">Withdraw Funds</div>
      <div style="font-size: 12px; color: var(--muted);">Transfer wallet balance to bank</div>
    </div>
    <div style="display: flex; align-items: center; gap: 10px;">
      <div style="width: 34px; height: 34px; border-radius: 7px; background: var(--accent-blue); color: white; font-weight: 800; font-size: 14px; display: flex; align-items: center; justify-content: center;" 
           th:text="${username != null ? #strings.substring(username,0,1).toUpperCase() : 'U'}">U</div>
    </div>
  </div>

  <div class="content">
    <div class="withdraw-card">
      <h2>Withdraw Money 💸</h2>
      <p class="subtitle">Securely transfer funds from your RevPay wallet.</p>
      
      <div class="error-box" th:if="${error != null}" th:text="${error}"></div>
      
      <form th:action="@{/withdraw-money}" method="post">
        <div class="input-group">
          <label>Amount to Withdraw (INR)</label>
          <input type="number" step="0.01" name="amount" placeholder="0.00" required>
        </div>
        <button type="submit" class="btn-withdraw">Confirm Withdrawal</button>
      </form>
    </div>
  </div>
</div>

</body>
</html>y