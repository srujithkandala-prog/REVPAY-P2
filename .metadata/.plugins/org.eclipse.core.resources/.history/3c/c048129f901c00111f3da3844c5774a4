<!DOCTYPE html>
<html xmlns:th="http://www.thymeleaf.org">

<head>
<meta charset="UTF-8">
<title>Withdraw Money</title>

<!-- Bootstrap -->
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">

<!-- Icons -->
<link rel="stylesheet"
href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">

<style>

body{
background:#f1f5f9;
font-family:'Segoe UI',sans-serif;
}

/* SIDEBAR */

.sidebar{
height:100vh;
width:240px;
position:fixed;
background:linear-gradient(180deg,#0f172a,#020617);
color:white;
padding-top:20px;
}

.sidebar h3{
text-align:center;
margin-bottom:20px;
}

.sidebar a{
display:block;
padding:12px 20px;
color:#cbd5f5;
text-decoration:none;
border-left:3px solid transparent;
transition:0.2s;
}

.sidebar a i{
margin-right:10px;
}

.sidebar a:hover{
background:#1e293b;
border-left:3px solid #38bdf8;
color:white;
}

/* MAIN CONTENT */

.main{
margin-left:240px;
padding:40px;
}

/* CARD */

.withdraw-card{
max-width:420px;
margin:auto;
border-radius:12px;
box-shadow:0 10px 25px rgba(0,0,0,0.08);
}

/* WALLET */

.wallet-box{
background:#2563eb;
color:white;
padding:15px;
border-radius:8px;
margin-bottom:20px;
text-align:center;
font-weight:bold;
}

</style>

</head>

<body>

<!-- SIDEBAR -->

<div class="sidebar">

<!-- Dynamic Title -->

<h3 th:text="${user.role.name() == 'BUSINESS'} ? 'RevPay Business' : 'RevPay'"></h3>

<!-- Dynamic Dashboard -->

<a th:href="${user.role.name() == 'BUSINESS'} ? '/business-dashboard' : '/dashboard'">
<i class="fa-solid fa-chart-line"></i> Dashboard
</a>

<a href="/profile"><i class="fa-solid fa-user"></i> Profile</a>
<a href="/send-money"><i class="fa-solid fa-paper-plane"></i> Send Money</a>
<a href="/add-money"><i class="fa-solid fa-wallet"></i> Add Money</a>
<a href="/withdraw-money"><i class="fa-solid fa-money-bill-wave"></i> Withdraw</a>
<a href="/transactions"><i class="fa-solid fa-money-bill-transfer"></i> Transactions</a>
<a href="/logout"><i class="fa-solid fa-right-from-bracket"></i> Logout</a>

</div>

<!-- MAIN -->

<div class="main">

<div class="d-flex justify-content-between align-items-center mb-4">

<h2>Withdraw Money 💸</h2>

<a th:href="${user.role.name() == 'BUSINESS'} ? '/business-dashboard' : '/dashboard'"
class="btn btn-success">

<i class="fa-solid fa-arrow-left"></i> Dashboard

</a>

</div>

<!-- CARD -->

<div class="card withdraw-card p-4">

<div class="wallet-box">
Wallet Balance: ₹ <span th:text="${wallet}"></span>
</div>

<!-- ERROR -->

<div th:if="${error}" class="alert alert-danger"
th:text="${error}"></div>

<form th:action="@{/withdraw-money}" method="post">

<div class="mb-3">

<label class="form-label">Amount</label>

<input type="number"
step="0.01"
name="amount"
class="form-control"
placeholder="Enter Amount"
required>

</div>

<button class="btn btn-primary w-100">

<i class="fa-solid fa-money-bill-wave"></i>
Withdraw Money

</button>

</form>

<div class="mt-3 d-flex gap-2">

<a href="/send-money" class="btn btn-outline-primary w-50">
Send Money
</a>

<a href="/transactions" class="btn btn-outline-dark w-50">
History
</a>

</div>

</div>

</div>

</body>
</html>