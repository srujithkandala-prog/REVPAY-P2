<!DOCTYPE html>
<html xmlns:th="http://www.thymeleaf.org" lang="en">
<head>
    <meta charset="UTF-8">
    <title>RevPay | Secure Sign In</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Inter', sans-serif; background: #020617; display: flex; justify-content: center; align-items: center; height: 100vh; }
        .login-card { background: #0f172a; padding: 50px; border-radius: 16px; border: 1px solid #1e293b; width: 400px; box-shadow: 0 20px 40px rgba(0,0,0,0.3); }
        h2 { margin-bottom: 25px; color: white; }
        input { width: 100%; padding: 15px; margin: 10px 0; background: #1e293b; border: 1px solid #334155; border-radius: 8px; color: white; box-sizing: border-box; }
        button { width: 100%; padding: 15px; background: #eab308; border: none; border-radius: 8px; font-weight: 700; cursor: pointer; margin-top: 20px; }
        .footer-note { margin-top: 20px; font-size: 12px; color: #64748b; text-align: center; }
    </style>
</head>
<body>
    <div class="login-card">
        <h2>Secure Sign In</h2>
        <form th:action="@{/login}" method="post">
            <input type="text" name="username" placeholder="Customer ID or Email" required>
            <input type="password" name="password" placeholder="Password" required>
            <button type="submit">Authorize Access</button>
        </form>
        <div class="footer-note">
            SSL Secured Connection • RevPay Institutional Banking
        </div>
    </div>
</body>
</html>