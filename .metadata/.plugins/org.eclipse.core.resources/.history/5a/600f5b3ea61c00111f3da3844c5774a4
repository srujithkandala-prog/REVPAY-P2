<style>

*{
box-sizing:border-box;
}

body{
margin:0;
font-family:'Segoe UI',sans-serif;
background:#f1f5f9;
color:#334155;
overflow-x:hidden;
}

/* CONTAINER */

.container{
display:flex;
min-height:100vh;
width:100%;
}

/* SIDEBAR */

.sidebar{
width:240px;
min-width:240px;
background:linear-gradient(180deg,#0f172a,#020617);
color:white;
display:flex;
flex-direction:column;
position:fixed;
top:0;
left:0;
bottom:0;
}

.sidebar h2{
text-align:center;
padding:20px;
border-bottom:1px solid #1e293b;
margin:0;
}

.sidebar a{
display:block;
color:#cbd5f5;
padding:12px 20px;
text-decoration:none;
border-left:3px solid transparent;
}

.sidebar a:hover{
background:#1e293b;
border-left:3px solid #38bdf8;
}

/* MAIN */

.main{
flex:1;
padding:40px;
margin-left:240px;
width:100%;
}

/* HEADER */

.header{
display:flex;
justify-content:space-between;
align-items:center;
margin-bottom:25px;
flex-wrap:wrap;
}

.dashboard-btn{
background:#16a34a;
color:white;
padding:8px 15px;
border-radius:6px;
text-decoration:none;
}

/* CARD */

.card{
background:white;
padding:25px;
border-radius:12px;
box-shadow:0 10px 25px rgba(0,0,0,0.08);
width:100%;
overflow-x:auto;
}

/* FILTERS */

.filters{
display:flex;
flex-wrap:wrap;
gap:10px;
margin-bottom:20px;
}

.filters input,
.filters select{
padding:8px;
border:1px solid #ddd;
border-radius:6px;
}

.filters button{
background:#2563eb;
color:white;
border:none;
padding:8px 15px;
border-radius:6px;
cursor:pointer;
}

/* TABLE */

table{
width:100%;
border-collapse:collapse;
min-width:600px;
}

th{
background:#0f172a;
color:white;
padding:12px;
}

td{
padding:12px;
border-bottom:1px solid #e2e8f0;
word-break:break-word;
}

tr:hover{
background:#f8fafc;
}

/* TYPE BADGES */

.badge{
padding:4px 10px;
border-radius:12px;
font-size:12px;
font-weight:bold;
}

.sent{
background:#fee2e2;
color:#991b1b;
}

.withdraw{
background:#dbeafe;
color:#1e40af;
}

.request{
background:#dcfce7;
color:#166534;
}

.unknown{
background:#e5e7eb;
color:#374151;
}

/* EXPORT BUTTON */

.export{
margin-top:15px;
background:#16a34a;
color:white;
border:none;
padding:8px 15px;
border-radius:6px;
cursor:pointer;
text-decoration:none;
display:inline-block;
}

/* MOBILE FIX */

@media (max-width:900px){

.sidebar{
position:relative;
width:200px;
min-width:200px;
}

.main{
margin-left:200px;
padding:20px;
}

}

@media (max-width:700px){

.container{
flex-direction:column;
}

.sidebar{
width:100%;
position:relative;
flex-direction:row;
overflow-x:auto;
}

.sidebar a{
flex:1;
text-align:center;
border-left:none;
}

.main{
margin-left:0;
padding:20px;
}

}

</style>