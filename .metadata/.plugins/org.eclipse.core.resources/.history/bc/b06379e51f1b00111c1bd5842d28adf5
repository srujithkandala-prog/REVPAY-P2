<!DOCTYPE html>
<html xmlns:th="http://www.thymeleaf.org">

<head>
<meta charset="UTF-8">
<title>Business Dashboard</title>

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">

<style>

body{
margin:0;
font-family:'Segoe UI',sans-serif;
background:#f1f5f9;
color:#334155;
}

/* ===== LAYOUT ===== */

.container{
display:flex;
height:100vh;
overflow:hidden;
}

/* ===== SIDEBAR ===== */

.sidebar{
width:240px;
background:linear-gradient(180deg,#0f172a,#020617);
color:white;
display:flex;
flex-direction:column;
}

.sidebar h2{
text-align:center;
padding:20px;
margin:0;
border-bottom:1px solid #1e293b;
}

.menu{
flex:1;
overflow-y:auto;
}

.sidebar a{
display:block;
color:#cbd5f5;
padding:12px 20px;
text-decoration:none;
font-size:14px;
border-left:3px solid transparent;
transition:0.25s;
}

.sidebar a i{
margin-right:10px;
}

.sidebar a:hover{
background:#1e293b;
border-left:3px solid #38bdf8;
color:white;
padding-left:25px;
}

/* ===== MAIN ===== */

.main{
flex:1;
padding:30px;
overflow-y:auto;
}

/* HEADER */

.dashboard-header{
display:flex;
justify-content:space-between;
align-items:center;
margin-bottom:25px;
}

.dashboard-header h2{
margin:0;
}

/* ===== STAT CARDS ===== */

.stats-grid{
display:grid;
grid-template-columns:repeat(auto-fit,minmax(220px,1fr));
gap:20px;
margin-bottom:25px;
}

.stat-card{
background:white;
padding:20px;
border-radius:12px;
box-shadow:0 8px 20px rgba(0,0,0,0.05);
display:flex;
justify-content:space-between;
align-items:center;
transition:0.2s;
}

.stat-card:hover{
transform:translateY(-4px);
}

.stat-icon{
font-size:28px;
color:#2c7be5;
}

.stat-value{
font-size:24px;
font-weight:bold;
}

/* ===== CARDS ===== */

.card{
background:white;
padding:25px;
border-radius:12px;
box-shadow:0 8px 20px rgba(0,0,0,0.05);
margin-bottom:25px;
}

/* ===== TABLE ===== */

table{
width:100%;
border-collapse:collapse;
margin-top:10px;
}

th{
background:#0f172a;
color:white;
}

table,th,td{
border:1px solid #e2e8f0;
padding:12px;
text-align:left;
}

tr:nth-child(even){
background:#f8fafc;
}

tr:hover{
background:#eef2ff;
}

/* ===== WALLET CARD ===== */

.wallet-card{
background:linear-gradient(135deg,#2563eb,#1e40af);
color:white;
border-radius:12px;
padding:25px;
margin-bottom:25px;
}

.wallet-balance{
font-size:36px;
font-weight:bold;
margin-top:10px;
}

/* ===== RESPONSIVE ===== */

@media(max-width:900px){

.sidebar{
width:200px;
}

}

</style>

</head>

<body>

<div class="container">

<!-- ===== SIDEBAR ===== -->

<div class="sidebar">

<h2>RevPay Business</h2>

<div class="menu">

<a href="/business-dashboard"><i class="fa-solid fa-chart-line"></i>Dashboard</a>
<a href="/profile"><i class="fa-solid fa-user"></i>Profile</a>
<a href="/send-money"><i class="fa-solid fa-paper-plane"></i>Send Money</a>
<a href="/add-money"><i class="fa-solid fa-wallet"></i>Add Money</a>
<a href="/request-money"><i class="fa-solid fa-hand-holding-dollar"></i>Request Money</a>
<a href="/incoming-requests"><i class="fa-solid fa-arrow-down"></i>Incoming Requests</a>
<a href="/outgoing-requests"><i class="fa-solid fa-arrow-up"></i>Outgoing Requests</a>
<a href="/withdraw-money"><i class="fa-solid fa-money-bill-wave"></i>Withdraw Money</a>
<a href="/transactions"><i class="fa-solid fa-money-check-dollar"></i>Transactions</a>
<a href="/transactions-history"><i class="fa-solid fa-clock-rotate-left"></i>Transaction History</a>
<a href="/create-invoice"><i class="fa-solid fa-file-invoice"></i>Create Invoice</a>
<a href="/invoices"><i class="fa-solid fa-file-lines"></i>Invoices</a>
<a href="/apply-loan"><i class="fa-solid fa-coins"></i>Apply Loan</a>
<a href="/my-loans"><i class="fa-solid fa-landmark"></i>My Loans</a>

<a th:href="@{/business/loan-repayments}">
<i class="fa-solid fa-calendar-check"></i>Loan Repayments
</a>

<a href="/payment-methods"><i class="fa-solid fa-credit-card"></i>Payment Methods</a>
<a href="/notifications"><i class="fa-solid fa-bell"></i>Notifications</a>
<a href="/logout"><i class="fa-solid fa-right-from-bracket"></i>Logout</a>

</div>

</div>

<!-- ===== MAIN ===== -->

<div class="main">

<div class="dashboard-header">

<h2>
Welcome,
<span th:text="${user.fullName}"></span> 🚀
</h2>

</div>

<!-- WALLET CARD -->

<div class="wallet-card">

<h3>Wallet Balance</h3>

<div class="wallet-balance">
₹ <span th:text="${wallet}"></span>
</div>

</div>

<!-- STATS -->

<div class="stats-grid">

<div class="stat-card">
<div>
<div>Total Revenue</div>
<div class="stat-value">₹ <span th:text="${revenue}"></span></div>
</div>
<i class="fa-solid fa-chart-line stat-icon"></i>
</div>

<div class="stat-card">
<div>
<div>Total Transactions</div>
<div class="stat-value" th:text="${transactions.size()}"></div>
</div>
<i class="fa-solid fa-money-bill-transfer stat-icon"></i>
</div>

<div class="stat-card">
<div>
<div>Active Loans</div>
<div class="stat-value">2</div>
</div>
<i class="fa-solid fa-landmark stat-icon"></i>
</div>

<div class="stat-card">
<div>
<div>Pending Requests</div>
<div class="stat-value">3</div>
</div>
<i class="fa-solid fa-clock stat-icon"></i>
</div>

</div>

<!-- RECENT PAYMENTS -->

<div class="card">

<h3>Recent Payments</h3>

<table th:if="${transactions.size()>0}">

<tr>
<th>Sender</th>
<th>Receiver</th>
<th>Amount</th>
<th>Date</th>
</tr>

<tr th:each="t,iter : ${transactions}" th:if="${iter.index<5}">

<td th:text="${t.senderEmail}"></td>
<td th:text="${t.receiverEmail}"></td>
<td>₹ <span th:text="${t.amount}"></span></td>

<td th:text="${#temporals.format(t.transactionDate,'dd-MM-yyyy HH:mm')}"></td>

</tr>

</table>

<p th:if="${transactions.size()==0}">
No transactions yet.
</p>

</div>

</div>

</div>

</body>
</html>