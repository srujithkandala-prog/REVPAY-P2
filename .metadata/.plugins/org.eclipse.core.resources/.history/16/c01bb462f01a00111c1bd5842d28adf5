<!DOCTYPE html>
<html xmlns:th="http://www.thymeleaf.org">

<head>
<meta charset="UTF-8">
<title>Profile Settings</title>

<style>

body{
font-family:Arial;
background:#f4f6f9;
margin:0;
}

/* CONTAINER */

.container{
width:700px;
margin:40px auto;
background:white;
padding:30px;
border-radius:10px;
box-shadow:0 0 10px #ddd;
}

/* TITLE */

h1{
text-align:center;
margin-bottom:30px;
}

/* TABS */

.tabs{
display:flex;
border-bottom:2px solid #eee;
margin-bottom:20px;
}

.tab{
flex:1;
padding:12px;
text-align:center;
cursor:pointer;
font-weight:bold;
}

.tab:hover{
background:#f1f5f9;
}

.active{
border-bottom:3px solid #2c7be5;
color:#2c7be5;
}

/* TAB CONTENT */

.tab-content{
display:none;
}

.tab-content.active{
display:block;
}

/* INPUTS */

input{
width:100%;
padding:12px;
margin-top:10px;
margin-bottom:15px;
border:1px solid #ccc;
border-radius:5px;
}

/* BUTTON */

button{
width:100%;
padding:12px;
background:#2c7be5;
border:none;
color:white;
font-size:16px;
border-radius:5px;
cursor:pointer;
}

button:hover{
background:#1b5fcc;
}

</style>

</head>

<body>

<div class="container">

<h1>Profile Settings 👤</h1>

<!-- TABS -->

<div class="tabs">

<div class="tab active" onclick="openTab(event,'profile')">
Profile
</div>

<div class="tab" onclick="openTab(event,'security')">
Security
</div>

<div class="tab" onclick="openTab(event,'pin')">
Transaction PIN
</div>

</div>

<!-- PROFILE TAB -->

<div id="profile" class="tab-content active">

<h3>Update Profile</h3>

<form action="/update-profile" method="post">

<input type="text"
name="fullName"
th:value="${user.fullName}"
placeholder="Full Name"
required>

<input type="text"
name="phone"
th:value="${user.phone}"
placeholder="Phone"
required>

<button type="submit">
Update Profile
</button>

</form>

</div>

<!-- SECURITY TAB -->

<div id="security" class="tab-content">

<h3>Change Password</h3>

<form action="/change-password" method="post">

<input type="password"
name="currentPassword"
placeholder="Current Password"
required>

<input type="password"
name="newPassword"
placeholder="New Password"
required>

<button type="submit">
Change Password
</button>

</form>

</div>

<!-- PIN TAB -->

<div id="pin" class="tab-content">

<h3>Set Transaction PIN 🔒</h3>

<form action="/set-transaction-pin" method="post">

<input type="password"
name="transactionPin"
placeholder="Enter 4 digit PIN"
pattern="[0-9]{4}"
maxlength="4"
required>

<button type="submit">
Save PIN
</button>

</form>

</div>

</div>

<script>

function openTab(evt,tabName){

var i,content,tab;

content=document.getElementsByClassName("tab-content");

for(i=0;i<content.length;i++){
content[i].classList.remove("active");
}

tab=document.getElementsByClassName("tab");

for(i=0;i<tab.length;i++){
tab[i].classList.remove("active");
}

document.getElementById(tabName).classList.add("active");

evt.currentTarget.classList.add("active");

}

</script>

</body>
</html>