<!DOCTYPE html>
<html xmlns:th="http://www.thymeleaf.org" lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>RevPay — Dashboard</title>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
<style>

*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

:root {
    --navy-dark:   #0f172a;
    --navy-subtle: #1e293b;
    --navy-mid:    #111827;
    --accent-blue: #2563eb;
    --gold:        #eab308;
    --white:       #ffffff;
    --glass:       rgba(255,255,255,0.03);
    --border:      rgba(255,255,255,0.08);
    --muted:       rgba(255,255,255,0.5);
    --sidebar-w:   230px;
}

body {
    font-family: 'Inter', sans-serif;
    background: var(--navy-dark);
    color: var(--white);
    line-height: 1.6;
    display: flex; min-height: 100vh;
    -webkit-font-smoothing: antialiased;
}

::-webkit-scrollbar { width: 5px; }
::-webkit-scrollbar-track { background: var(--navy-dark); }
::-webkit-scrollbar-thumb { background: var(--navy-subtle); border-radius: 4px; }

@keyframes fadeInUp {
    from { opacity: 0; transform: translateY(18px); }
    to   { opacity: 1; transform: translateY(0); }
}

/* ── SIDEBAR ── */
.sidebar {
    width: var(--sidebar-w);
    background: var(--navy-subtle);
    border-right: 1px solid var(--border);
    position: fixed; top: 0; left: 0; bottom: 0;
    z-index: 50; overflow-y: auto;
    display: flex; flex-direction: column;
}

.sidebar::before {
    content: '';
    position: absolute; inset: 0;
    background-image:
        linear-gradient(rgba(255,255,255,0.018) 1px, transparent 1px),
        linear-gradient(90deg, rgba(255,255,255,0.018) 1px, transparent 1px);
    background-size: 36px 36px; pointer-events: none;
}

.sidebar-logo {
    display: flex; align-items: center; gap: 11px;
    padding: 22px 20px 18px;
    text-decoration: none; position: relative; z-index: 1;
    border-bottom: 1px solid var(--border); margin-bottom: 8px;
}

.logo-box {
    width: 36px; height: 36px;
    background: var(--white); color: var(--navy-dark);
    border-radius: 8px;
    display: flex; align-items: center; justify-content: center;
    font-weight: 800; font-size: 16px;
    border: 2px solid var(--gold);
    flex-shrink: 0;
}

.logo-text { display: flex; flex-direction: column; }
.logo-text .s-name { color: white; font-size: 15px; font-weight: 800; }
.logo-text .s-tag  {
    font-size: 9px; font-weight: 700; letter-spacing: 1.5px;
    text-transform: uppercase; color: var(--gold);
    display: block; margin-top: 1px;
}

.nav-section {
    padding: 12px 20px 4px;
    font-size: 10px; font-weight: 700;
    color: rgba(255,255,255,0.2);
    letter-spacing: 2px; text-transform: uppercase;
    position: relative; z-index: 1;
}

.nav-item {
    display: flex; align-items: center; gap: 10px;
    padding: 9px 12px; margin: 1px 8px;
    text-decoration: none;
    font-size: 13px; font-weight: 500;
    color: rgba(255,255,255,0.5);
    border-radius: 6px;
    transition: all 0.2s; position: relative; z-index: 1;
}

.nav-icon {
    width: 28px; height: 28px; border-radius: 6px;
    background: rgba(255,255,255,0.04);
    display: flex; align-items: center; justify-content: center;
    font-size: 13px; flex-shrink: 0; transition: background 0.2s;
}

.nav-item:hover { color: rgba(255,255,255,0.85); background: rgba(255,255,255,0.05); }
.nav-item:hover .nav-icon { background: rgba(37,99,235,0.15); }

.nav-item.active {
    color: white; font-weight: 600;
    background: rgba(37,99,235,0.15);
    border: 1px solid rgba(37,99,235,0.25);
}

.nav-item.active .nav-icon {
    background: var(--accent-blue);
    box-shadow: 0 4px 10px rgba(37,99,235,0.35);
}

.nav-badge {
    margin-left: auto;
    background: #dc2626; color: white;
    font-size: 10px; font-weight: 700;
    padding: 2px 7px; border-radius: 10px;
}

.nav-item.logout { color: rgba(239,68,68,0.5); }
.nav-item.logout:hover { color: #ef4444; background: rgba(239,68,68,0.06); }

.sidebar-bottom {
    margin-top: auto; padding: 10px 0 14px;
    border-top: 1px solid var(--border); position: relative; z-index: 1;
}

/* ── MAIN ── */
.main {
    margin-left: var(--sidebar-w);
    flex: 1; display: flex; flex-direction: column; min-height: 100vh;
}

/* ── TOPBAR ── */
.topbar {
    background: rgba(15,23,42,0.95);
    backdrop-filter: blur(10px);
    border-bottom: 1px solid var(--border);
    padding: 14px 32px;
    display: flex; align-items: center; justify-content: space-between;
    position: sticky; top: 0; z-index: 30;
}

.topbar-title { font-size: 16px; font-weight: 800; letter-spacing: -0.3px; }
.topbar-sub   { font-size: 12px; color: var(--muted); margin-top: 1px; }

.topbar-right { display: flex; align-items: center; gap: 10px; }

.tb-badge {
    font-size: 10px; font-weight: 700;
    letter-spacing: 1px; text-transform: uppercase;
    padding: 4px 10px; border-radius: 5px;
}

.tb-badge-blue { background: rgba(37,99,235,0.15); color: #93c5fd; border: 1px solid rgba(37,99,235,0.2); }
.tb-badge-gold { background: rgba(234,179,8,0.1);  color: var(--gold); border: 1px solid rgba(234,179,8,0.2); }

.tb-btn {
    width: 34px; height: 34px; border-radius: 7px;
    background: var(--glass); border: 1px solid var(--border);
    display: flex; align-items: center; justify-content: center;
    font-size: 15px; cursor: pointer; text-decoration: none;
    position: relative; transition: all 0.2s;
}

.tb-btn:hover { border-color: rgba(255,255,255,0.2); }

.notif-dot {
    position: absolute; top: 6px; right: 6px;
    width: 6px; height: 6px;
    background: #dc2626; border-radius: 50%;
    border: 1.5px solid var(--navy-subtle);
}

.tb-avatar {
    width: 34px; height: 34px; border-radius: 7px;
    background: var(--accent-blue);
    color: white; font-weight: 800; font-size: 14px;
    display: flex; align-items: center; justify-content: center;
    box-shadow: 0 2px 8px rgba(37,99,235,0.3); cursor: pointer;
}

/* ── CONTENT ── */
.content { padding: 28px 32px; flex: 1; }

/* ── WELCOME BANNER ── */
.welcome-banner {
    background: linear-gradient(135deg, var(--navy-subtle) 0%, #0f1f38 100%);
    border: 1px solid var(--border);
    border-radius: 16px; padding: 26px 30px;
    display: flex; align-items: center; justify-content: space-between;
    margin-bottom: 20px; position: relative; overflow: hidden;
    animation: fadeInUp 0.3s ease both;
}

.welcome-banner::before {
    content: '';
    position: absolute; inset: 0;
    background-image:
        linear-gradient(rgba(255,255,255,0.015) 1px, transparent 1px),
        linear-gradient(90deg, rgba(255,255,255,0.015) 1px, transparent 1px);
    background-size: 36px 36px; pointer-events: none;
}

.welcome-text h2 { font-size: 20px; font-weight: 800; letter-spacing: -0.5px; margin-bottom: 4px; position: relative; z-index: 1; }
.welcome-text p   { font-size: 13px; color: var(--muted); position: relative; z-index: 1; }
.welcome-actions  { display: flex; gap: 10px; position: relative; z-index: 1; }

/* ── BUTTONS ── */
.btn-blue {
    padding: 10px 18px; background: var(--accent-blue); color: white;
    border: none; border-radius: 7px; font-family: 'Inter', sans-serif;
    font-size: 13px; font-weight: 700; cursor: pointer; text-decoration: none;
    box-shadow: 0 4px 12px rgba(37,99,235,0.3);
    transition: transform 0.2s, box-shadow 0.2s;
    display: inline-flex; align-items: center; gap: 7px;
}
.btn-blue:hover { transform: translateY(-1px); box-shadow: 0 6px 18px rgba(37,99,235,0.4); }

.btn-outline-white {
    padding: 10px 18px; background: var(--glass); color: rgba(255,255,255,0.7);
    border: 1px solid var(--border); border-radius: 7px;
    font-family: 'Inter', sans-serif; font-size: 13px; font-weight: 600;
    cursor: pointer; text-decoration: none; transition: all 0.2s;
    display: inline-flex; align-items: center; gap: 7px;
}
.btn-outline-white:hover { border-color: rgba(255,255,255,0.25); color: white; }

/* ── GRADIENT CARDS ── */
.grad-card {
    border-radius: 16px; padding: 24px 26px;
    position: relative; overflow: hidden;
}

.grad-card::before {
    content: '';
    position: absolute; width: 200px; height: 200px; border-radius: 50%;
    background: rgba(255,255,255,0.06); top: -60px; right: -40px;
}

.grad-wallet  { background: linear-gradient(135deg, #1d4ed8 0%, #5b21b6 100%); }
.grad-revenue { background: linear-gradient(135deg, #065f46 0%, #059669 100%); }

.grad-label {
    font-size: 10.5px; font-weight: 700; color: rgba(255,255,255,0.6);
    letter-spacing: 2px; text-transform: uppercase;
    margin-bottom: 10px; position: relative; z-index: 1;
}

.grad-amount {
    font-size: 34px; font-weight: 800; color: white;
    letter-spacing: -1.5px; position: relative; z-index: 1; margin-bottom: 18px;
}

.grad-amount .sym { font-size: 20px; margin-right: 3px; opacity: 0.75; }

.grad-footer {
    display: flex; align-items: center; justify-content: space-between;
    position: relative; z-index: 1;
}

.grad-footer-meta { font-size: 12px; color: rgba(255,255,255,0.5); }
.grad-actions { display: flex; gap: 8px; }

.grad-btn {
    padding: 7px 14px; border-radius: 7px;
    font-size: 12px; font-weight: 700;
    text-decoration: none; border: none; cursor: pointer;
    font-family: 'Inter', sans-serif; transition: transform 0.2s;
}
.grad-btn:hover { transform: translateY(-1px); }
.grad-btn-white { background: rgba(255,255,255,0.9); color: var(--navy-dark); }
.grad-btn-ghost { background: rgba(255,255,255,0.12); color: white; border: 1px solid rgba(255,255,255,0.15); }

/* ── STAT CARDS ── */
.stat-card {
    background: var(--navy-subtle);
    border: 1px solid var(--border);
    border-radius: 12px; padding: 20px;
    transition: all 0.2s;
}
.stat-card:hover { border-color: rgba(255,255,255,0.15); transform: translateY(-2px); }

.stat-top { display: flex; align-items: center; justify-content: space-between; margin-bottom: 12px; }

.stat-icon { width: 36px; height: 36px; border-radius: 8px; display: flex; align-items: center; justify-content: center; font-size: 15px; }
.ic-red   { background: rgba(220,38,38,0.1); }
.ic-green { background: rgba(5,150,105,0.1); }
.ic-blue  { background: rgba(37,99,235,0.1); }
.ic-gold  { background: rgba(234,179,8,0.1); }

.stat-tag { font-size: 10px; font-weight: 700; letter-spacing: 0.5px; text-transform: uppercase; padding: 3px 8px; border-radius: 5px; }
.tg-red   { background: rgba(220,38,38,0.1);  color: #f87171; }
.tg-green { background: rgba(5,150,105,0.1);  color: #34d399; }
.tg-blue  { background: rgba(37,99,235,0.1);  color: #93c5fd; }
.tg-gold  { background: rgba(234,179,8,0.1);  color: var(--gold); }

.stat-val   { font-size: 22px; font-weight: 800; letter-spacing: -0.8px; margin-bottom: 4px; }
.vl-red     { color: #f87171; }
.vl-green   { color: #34d399; }
.vl-blue    { color: #93c5fd; }
.vl-gold    { color: var(--gold); }
.stat-label { font-size: 12px; color: var(--muted); }

/* ── CARD ── */
.card {
    background: var(--navy-subtle);
    border: 1px solid var(--border);
    border-radius: 14px; padding: 22px;
}

.sec-hdr {
    display: flex; align-items: center; justify-content: space-between; margin-bottom: 16px;
}
.sec-hdr h3 { font-size: 14px; font-weight: 800; }
.sec-hdr a  { font-size: 12px; font-weight: 600; color: #93c5fd; text-decoration: none; }
.sec-hdr a:hover { text-decoration: underline; }

/* ── QUICK ACTIONS ── */
.quick-grid { display: grid; gap: 10px; }
.qg-5 { grid-template-columns: repeat(5, 1fr); }
.qg-6 { grid-template-columns: repeat(6, 1fr); }

.quick-item {
    display: flex; flex-direction: column; align-items: center; gap: 7px;
    padding: 14px 6px; border-radius: 10px;
    border: 1px solid var(--border); background: var(--glass);
    text-decoration: none; transition: all 0.2s;
}
.quick-item:hover { border-color: rgba(37,99,235,0.3); background: rgba(37,99,235,0.06); transform: translateY(-2px); }

.quick-icon { width: 38px; height: 38px; border-radius: 9px; display: flex; align-items: center; justify-content: center; font-size: 17px; }
.qi-1 { background: rgba(37,99,235,0.12); }
.qi-2 { background: rgba(5,150,105,0.12); }
.qi-3 { background: rgba(234,179,8,0.1); }
.qi-4 { background: rgba(139,92,246,0.12); }
.qi-5 { background: rgba(220,38,38,0.1); }
.qi-6 { background: rgba(6,182,212,0.1); }

.quick-label { font-size: 11px; font-weight: 600; color: rgba(255,255,255,0.6); text-align: center; }

/* ── TRANSACTIONS ── */
.txn-row { display: flex; align-items: center; gap: 12px; padding: 12px 0; border-bottom: 1px solid rgba(255,255,255,0.04); }
.txn-row:last-child { border-bottom: none; }
.txn-icon { width: 36px; height: 36px; border-radius: 9px; display: flex; align-items: center; justify-content: center; font-size: 15px; flex-shrink: 0; }
.txn-info { flex: 1; }
.txn-name { font-size: 13px; font-weight: 700; }
.txn-date { font-size: 11px; color: var(--muted); margin-top: 2px; }
.txn-amount { font-size: 13.5px; font-weight: 800; }
.amt-credit { color: #34d399; }
.amt-debit  { color: #f87171; }

/* ── TABLE ── */
table { width: 100%; border-collapse: collapse; }
thead th { font-size: 10.5px; font-weight: 700; color: var(--muted); letter-spacing: 1px; text-transform: uppercase; padding: 0 0 10px; text-align: left; border-bottom: 1px solid var(--border); }
tbody td  { font-size: 13px; color: rgba(255,255,255,0.75); padding: 11px 0; border-bottom: 1px solid rgba(255,255,255,0.04); }
tbody tr:last-child td { border-bottom: none; }

/* ── BADGES ── */
.badge { font-size: 10px; font-weight: 700; padding: 3px 9px; border-radius: 5px; letter-spacing: 0.5px; text-transform: uppercase; }
.badge-paid    { background: rgba(5,150,105,0.12); color: #34d399; }
.badge-pending { background: rgba(234,179,8,0.1);  color: var(--gold); }
.badge-overdue { background: rgba(220,38,38,0.1);  color: #f87171; }

/* ── EMPTY STATE ── */
.empty-state { text-align: center; padding: 36px 20px; color: var(--muted); }
.empty-icon  { font-size: 38px; margin-bottom: 12px; opacity: 0.35; display: block; }
.empty-state p { font-size: 13px; line-height: 1.7; }

/* ── INVOICE ROW ── */
.inv-row {
    display: flex; align-items: center; justify-content: space-between;
    padding: 10px 12px; border-radius: 8px;
    background: var(--glass); border: 1px solid var(--border);
    margin-bottom: 8px; transition: border-color 0.2s;
}
.inv-row:last-child { margin-bottom: 0; }
.inv-row:hover { border-color: rgba(255,255,255,0.15); }
.inv-left { display: flex; align-items: center; gap: 10px; }
.inv-icon { width: 30px; height: 30px; border-radius: 7px; background: rgba(37,99,235,0.1); display: flex; align-items: center; justify-content: center; font-size: 13px; }
.inv-name { font-size: 13px; font-weight: 700; }
.inv-date { font-size: 11px; color: var(--muted); margin-top: 1px; }

/* ── GRID HELPERS ── */
.grid-2 { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
.grid-3 { display: grid; grid-template-columns: repeat(3, 1fr); gap: 14px; }
.grid-4 { display: grid; grid-template-columns: repeat(4, 1fr); gap: 14px; }
.mb-20  { margin-bottom: 20px; }

/* ── RESPONSIVE ── */
@media (max-width: 768px) {
    .sidebar { display: none; }
    .main    { margin-left: 0; }
    .content { padding: 20px 16px; }
    .topbar  { padding: 14px 16px; }
    .grid-2, .grid-3, .grid-4 { grid-template-columns: 1fr; }
    .qg-5, .qg-6 { grid-template-columns: repeat(3, 1fr); }
    .welcome-actions { display: none; }
}

</style>
</head>
<body>

<aside class="sidebar">
  <a th:href="@{/dashboard}" class="sidebar-logo">
    <div class="logo-box">R</div>
    <div class="logo-text">
      <span class="s-name">RevPay</span>
      <span class="s-tag">Personal</span>
    </div>
  </a>

  <div class="nav-section">Main</div>
  <a th:href="@{/dashboard}" class="nav-item active"><div class="nav-icon">&#127968;</div>Dashboard</a>
  <a th:href="@{/profile}"   class="nav-item"><div class="nav-icon">&#128100;</div>Profile</a>

  <div class="nav-section">Payments</div>
  <a th:href="@{/send-money}"    class="nav-item"><div class="nav-icon">&#128184;</div>Send Money</a>
  <a th:href="@{/add-money}"     class="nav-item"><div class="nav-icon">&#10133;</div>Add Money</a>
  <a th:href="@{/request-money}" class="nav-item"><div class="nav-icon">&#128232;</div>Request Money</a>
  <a th:href="@{/withdraw}"      class="nav-item"><div class="nav-icon">&#127970;</div>Withdraw Money</a>

  <div class="nav-section">Requests</div>
  <a th:href="@{/incoming-requests}" class="nav-item">
    <div class="nav-icon">&#128229;</div>Incoming Requests
    <span class="nav-badge" th:if="${incomingCount != null and incomingCount > 0}" th:text="${incomingCount}"></span>
  </a>
  <a th:href="@{/outgoing-requests}" class="nav-item">
    <div class="nav-icon">&#128228;</div>Outgoing Requests
    <span class="nav-badge" th:if="${outgoingCount != null and outgoingCount > 0}" th:text="${outgoingCount}"></span>
  </a>

  <div class="nav-section">History</div>
  <a th:href="@{/transactions}"        class="nav-item"><div class="nav-icon">&#128260;</div>Transactions</a>
  <a th:href="@{/transaction-history}" class="nav-item"><div class="nav-icon">&#128203;</div>Transaction History</a>
  <a th:href="@{/invoices}"            class="nav-item"><div class="nav-icon">&#129534;</div>My Invoices</a>

  <div class="nav-section">Account</div>
  <a th:href="@{/payment-methods}" class="nav-item"><div class="nav-icon">&#128179;</div>Payment Methods</a>
  <a th:href="@{/notifications}"   class="nav-item"><div class="nav-icon">&#128276;</div>Notifications</a>

  <div class="sidebar-bottom">
    <a th:href="@{/logout}" class="nav-item logout"><div class="nav-icon">&#128682;</div>Logout</a>
  </div>
</aside>

<div class="main">
  <div class="topbar">
    <div>
      <div class="topbar-title">Dashboard</div>
      <div class="topbar-sub" th:text="${#dates.format(#dates.createNow(),'EEEE, dd MMMM yyyy')}">Sunday, 08 June 2026</div>
    </div>
    <div class="topbar-right">
      <span class="tb-badge tb-badge-blue">PERSONAL</span>
      <a th:href="@{/notifications}" class="tb-btn">&#128276;<div class="notif-dot"></div></a>
      <div class="tb-avatar" th:text="${#strings.substring(username,0,1).toUpperCase()}">R</div>
    </div>
  </div>

  <div class="content">

    <div class="welcome-banner">
      <div class="welcome-text">
        <h2>Welcome back, <span th:text="${username}">rajashekar</span> &#128075;</h2>
        <p>Here's your financial overview for today.</p>
      </div>
      <div class="welcome-actions">
        <a th:href="@{/send-money}" class="btn-blue">&#128184; Send Money</a>
        <a th:href="@{/add-money}"  class="btn-outline-white">&#10133; Add Money</a>
      </div>
    </div>

    <div class="grad-card grad-wallet mb-20">
      <div class="grad-label">Wallet Balance</div>
      <div class="grad-amount"><span class="sym">&#8377;</span><span th:text="${walletBalance}">0.00</span></div>
      <div class="grad-footer">
        <div class="grad-footer-meta">Personal Wallet</div>
        <div class="grad-actions">
          <a th:href="@{/add-money}" class="grad-btn grad-btn-white">+ Add Money</a>
          <a th:href="@{/withdraw}"  class="grad-btn grad-btn-ghost">Withdraw</a>
        </div>
      </div>
    </div>

    <div class="grid-3 mb-20">
      <div class="stat-card">
        <div class="stat-top"><div class="stat-icon ic-red">&#128228;</div><span class="stat-tag tg-red">Outgoing</span></div>
        <div class="stat-val vl-red">&#8377; <span th:text="${totalSent}">0.0</span></div>
        <div class="stat-label">Total Sent</div>
      </div>
      <div class="stat-card">
        <div class="stat-top"><div class="stat-icon ic-green">&#128229;</div><span class="stat-tag tg-green">Incoming</span></div>
        <div class="stat-val vl-green">&#8377; <span th:text="${totalReceived}">0.0</span></div>
        <div class="stat-label">Total Received</div>
      </div>
      <div class="stat-card">
        <div class="stat-top"><div class="stat-icon ic-blue">&#128260;</div><span class="stat-tag tg-blue">All Time</span></div>
        <div class="stat-val vl-blue" th:text="${totalTransactions}">0</div>
        <div class="stat-label">Total Transactions</div>
      </div>
    </div>

    <div class="card mb-20">
      <div class="sec-hdr"><h3>Quick Actions</h3></div>
      <div class="quick-grid qg-5">
        <a th:href="@{/send-money}"          class="quick-item"><div class="quick-icon qi-1">&#128184;</div><span class="quick-label">Send Money</span></a>
        <a th:href="@{/request-money}"       class="quick-item"><div class="quick-icon qi-2">&#128232;</div><span class="quick-label">Request Money</span></a>
        <a th:href="@{/add-money}"           class="quick-item"><div class="quick-icon qi-3">&#10133;</div><span class="quick-label">Add Money</span></a>
        <a th:href="@{/payment-methods}"     class="quick-item"><div class="quick-icon qi-4">&#128179;</div><span class="quick-label">Cards</span></a>
        <a th:href="@{/transaction-history}" class="quick-item"><div class="quick-icon qi-5">&#128203;</div><span class="quick-label">History</span></a>
      </div>
    </div>

    <div class="card">
      <div class="sec-hdr">
        <h3>Recent Transactions</h3>
        <a th:href="@{/transaction-history}">View all &#8594;</a>
      </div>
      <div class="empty-state" th:if="${#lists.isEmpty(recentTransactions)}">
        <span class="empty-icon">&#128269;</span>
        <p>No transactions yet.<br>Start by sending or adding money.</p>
      </div>
      <div th:each="txn : ${recentTransactions}" class="txn-row">
        <div class="txn-icon" th:style="${txn.type == 'credit'} ? 'background:rgba(5,150,105,0.12)' : 'background:rgba(220,38,38,0.1)'">
          <span th:text="${txn.type == 'credit'} ? '&#128229;' : '&#128228;'">&#128229;</span>
        </div>
        <div class="txn-info">
          <span th:text="${txn.type}"></span>
          <div class="txn-date" th:text="${txn.date}">Jun 08, 2026</div>
        </div>
        <div class="txn-amount" th:classappend="${txn.type == 'credit'} ? 'amt-credit' : 'amt-debit'"
             th:text="${(txn.type == 'credit' ? '+' : '-') + '&#8377;' + txn.amount}">+&#8377;500</div>
      </div>
    </div>

  </div>
</div>
</body>
</html>